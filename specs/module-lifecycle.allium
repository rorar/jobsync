-- allium: 3
-- module-lifecycle.allium

-- Scope: Module Lifecycle Manager for the Connector/Module ecosystem
-- Includes: Module Manifest (registration contract), Settings propagation,
--           Activation/Deactivation lifecycle, Health monitoring, Dependency management,
--           Automation degradation (CB escalation, run failures, auth failures)
-- Excludes:
--   - Connector implementation details (covered by DataSourceConnector / AIProviderConnector interfaces)
--   - Module-internal logic (each module's bounded context)
--   - UI rendering (Settings pages, Marketplace layout)
--   - Resilience implementation (Cockatiel/circuit-breaker internals)
-- Dependencies: Automation entity defined in jobsync.allium

-- =============================================================================
-- Enums
-- =============================================================================

enum ConnectorType { job_discovery | ai_provider | data_enrichment | reference_data }
-- Future: kalender | communication | geo | webhook | workflow | bewertungsportal | dokumentenworkflow

enum ModuleStatus { active | inactive | error }

enum HealthStatus { healthy | degraded | unreachable | unknown }

enum CredentialType { api_key | endpoint_url | none }
-- oauth_token removed: no module uses OAuth tokens. If eID/AusweisApp
-- is added later, a new type can be introduced.

enum CircuitBreakerState { closed | open | half_open }

enum AutomationPauseReason { module_deactivated | auth_failure | consecutive_failures | cb_escalation }

enum NotificationType { module_deactivated | module_reactivated | module_unreachable | cb_escalation | consecutive_failures | auth_failure }

enum RetryBackoffStrategy { exponential | linear | none }

enum CacheScope { shared | per_user }

enum AutomationType { discovery | maintenance }

enum SearchField { keywords | location }

enum ConnectorParamType { string | number | boolean | select | multiselect }

enum SettingsFieldType { string | number | boolean | select }

-- =============================================================================
-- Contracts (Published Language)
-- =============================================================================

-- The base contract every module must fulfill when registering with its connector.
-- This is the Published Language (DDD) between the Connector domain boundary
-- and its Module implementations.

contract ModuleManifest {
    -- Identity
    id: String
    name: String
    manifest_version: Integer
    connector_type: ConnectorType

    -- Credentials
    credential: CredentialRequirement

    -- Settings
    settings_schema: SettingsSchema

    -- Health
    health_check: HealthCheckConfig

    -- Resilience
    resilience: ResilienceConfig

    -- Caching (ROADMAP 0.9 Stufe 1)
    cache_policy: CachePolicy

    -- Dependencies
    dependencies: DependencyHealthCheck

    -- i18n
    i18n: ModuleI18n

    @guidance
        -- Modules register as active. Users deactivate explicitly via ModuleMarketplace.
        -- Connector-specific extensions (JobDiscoveryManifest, AiManifest,
        -- DataEnrichmentManifest, ReferenceDataManifest) add fields for
        -- automation type, connector params schema, search field overrides,
        -- model selection, supported dimensions, and taxonomy.
        -- These are modeled as separate value types composed alongside the manifest.
}

-- =============================================================================
-- Value Types (Settings Declaration)
-- =============================================================================

value CredentialRequirement {
    type: CredentialType
    module_id: String
    required: Boolean
    env_fallback: String?
    default_value: String?
    sensitive: Boolean
    placeholder: String?
}

value SettingsSchema {
    fields: Set<SettingsField>
}

value SettingsField {
    key: String
    label: String
    type: SettingsFieldType
    default_value: String?
    options: Set<String>
    validation: String?
}

value HealthCheckConfig {
    endpoint: String?
    timeout_ms: Integer
    interval_ms: Integer
}

value ResilienceConfig {
    retry_attempts: Integer
    retry_backoff: RetryBackoffStrategy
    circuit_breaker: Boolean
    circuit_breaker_threshold: Integer
    circuit_breaker_cooldown_ms: Integer
    timeout_ms: Integer
    rate_limit_tokens: Integer?
    rate_limit_refill_ms: Integer?
    max_concurrent: Integer?
}

value CachePolicy {
    ttl: Integer
    scope: CacheScope
    locale_sensitive: Boolean
}

value ModelSelectionConfig {
    default_model: String?
    list_endpoint: String?
}

value DependencyHealthCheck {
    id: String
    name: String
    endpoint: String
    timeout_ms: Integer
    required: Boolean
    used_for: String
}

value ModuleI18n {
    -- Map of locale code to display strings
    -- Each entry: { name: String, description: String, credential_hint: String? }
    -- credential_hint: UI hint for API key/endpoint settings field (optional, only for modules with credentials)
    -- Example: { en: { name: "EURES", description: "EU job search", credential_hint: "Enter your API key..." } }
    locale_data: String
}

value ConnectorParamField {
    key: String
    type: ConnectorParamType
    label: String
    default_value: String?
    options: Set<String>
    required: Boolean
    min: Integer?
    max: Integer?
    placeholder: String?
}

value SearchFieldOverride {
    field: SearchField
    widget_id: String
}

-- Connector-specific extensions (composed alongside the base manifest)

value JobDiscoveryExtension {
    automation_type: AutomationType
    connector_params_schema: Set<ConnectorParamField>
    search_field_overrides: Set<SearchFieldOverride>
}

value AiExtension {
    model_selection: ModelSelectionConfig
}

value DataEnrichmentExtension {
    supported_dimensions: Set<String>
}

value ReferenceDataExtension {
    taxonomy: String
}

-- =============================================================================
-- Entities
-- =============================================================================

entity RegisteredModule {
    manifest_id: String
    manifest_name: String
    manifest_version: Integer
    connector_type: ConnectorType
    credential: CredentialRequirement
    settings_schema: SettingsSchema?
    health_check_config: HealthCheckConfig?
    resilience_config: ResilienceConfig?
    cache_policy: CachePolicy?
    dependency_checks: Set<DependencyHealthCheck>
    module_i18n: ModuleI18n?

    -- Connector-specific extensions
    job_discovery_ext: JobDiscoveryExtension?
    ai_ext: AiExtension?
    data_enrichment_ext: DataEnrichmentExtension?
    reference_data_ext: ReferenceDataExtension?

    status: ModuleStatus
    health_status: HealthStatus
    last_health_check: Timestamp?
    last_successful_connection: Timestamp?
    activated_at: Timestamp?
    activated_by: String?

    -- Circuit breaker runtime state (observable)
    -- These fields reflect the CB state provisioned from manifest.resilience.
    -- Whether stored in-memory or persisted is implementation; the spec cares that
    -- the state is observable and can trigger automation degradation.
    circuit_breaker_state: CircuitBreakerState
    consecutive_failures: Integer
    circuit_breaker_open_since: Timestamp?

    -- Derived
    is_configured: credential.type = none or credential.default_value != null
    is_operational: status = active and health_status != unreachable
    has_cb_enabled: resilience_config != null and resilience_config.circuit_breaker = true
    cb_escalation_due: has_cb_enabled and consecutive_failures >= config.cb_escalation_threshold

    transitions status {
        active -> inactive
        active -> error
        inactive -> active
        error -> active
        terminal: error
    }
}

entity Notification {
    id: String
    user_id: String
    type: NotificationType
    message: String
    module_id: String?
    automation_id: String?
    read: Boolean
    created_at: Timestamp
}

entity ConnectorGroup {
    type: ConnectorType
    modules: RegisteredModule with connector_type = type

    -- Derived status: active when at least one module is active
    is_active: modules.any(m => m.status = active)
}

-- Reference to existing entity (defined in jobsync.allium)
external entity Automation {
    job_board: String
    status: active | paused
    user_id: String
    name: String
    pause_reason: AutomationPauseReason?
}

-- Reference to existing entity (defined in jobsync.allium)
external entity AutomationRun {
    automation_id: String
    status: running | completed | completed_with_errors | failed | blocked | rate_limited
    error_message: String?
    started_at: Timestamp
    completed_at: Timestamp?
}

-- =============================================================================
-- Config
-- =============================================================================

config {
    health_check_interval_ms: Integer = 300000
    health_check_timeout_ms: Integer = 5000
    max_health_failures_before_error: Integer = 3
    cb_escalation_threshold: Integer = 3
    consecutive_run_failure_threshold: Integer = 5
    notification_retention_days: Integer = 30
}

-- =============================================================================
-- Rules: Registration
-- =============================================================================

rule ModuleRegistration {
    -- "When a module registers, it provides its manifest to the connector."
    -- Registration happens at application startup, not at runtime.
    when: RegisterModule(module_id, module_name, module_connector_type)
    requires: not exists RegisteredModule{manifest_id: module_id}
        -- Module IDs must be unique across the entire system
    requires: module_id != ""
    requires: module_name != ""

    ensures: RegisteredModule.created(
        manifest_id: module_id,
        manifest_name: module_name,
        connector_type: module_connector_type,
        status: active,
        health_status: unknown,
        circuit_breaker_state: closed,
        consecutive_failures: 0,
        read: false
    )

    @guidance
        -- Modules register as active. Users deactivate explicitly via ModuleMarketplace.
        -- This preserves the existing startup behavior where all modules are immediately usable.
}

rule ManifestDrivesSettingsUI {
    -- "The settings UI is generated from module manifests, not hardcoded."
    -- When the settings page loads, it queries registered modules for their manifests.
    when: LoadSettingsPage(requested_connector_type)
    let modules = RegisteredModules where connector_type = requested_connector_type

    ensures:
        for module in modules:
            SettingsRendered(
                module_id: module.manifest_id,
                credential_field: module.credential,
                settings_fields: module.settings_schema
            )

    @guidance
        -- Replaces the hardcoded MODULES array in ApiKeySettings.tsx
        -- The UI iterates over registered manifests instead of a static list
}

-- =============================================================================
-- Rules: Settings Propagation (PUSH pattern)
-- =============================================================================

rule SettingsPushOnInstantiation {
    -- "When a module is instantiated for use, settings are resolved and pushed to it."
    -- This replaces the current PULL pattern where modules call resolveApiKey() ad-hoc.
    when: InstantiateModule(module_id, user_id)
    let module = RegisteredModule{manifest_id: module_id}
    requires: exists module
    requires: module.status = active

    let credential = resolve_credential(module_id, user_id, module.credential)
        -- Resolution priority: 1. User DB  2. Env var  3. Default

    requires: credential != null or module.credential.required = false
        -- If credential is required but not found, instantiation fails

    ensures: ModuleInstantiated(
        module_id: module_id,
        credential: credential,
        user_id: user_id
    )

    @guidance
        -- Phase 2: credential push implemented
        -- Phase 3: full settings push (UserSettings) planned
        -- The module receives its settings at creation time (constructor injection)
        -- It never reaches out to resolve settings itself
        -- This is Dependency Inversion: the system pushes, the module receives
}

rule ConnectorParamsValidation {
    -- "When an automation is created or updated, its connectorParams are validated
    --  against the module's declared schema."
    when: SaveAutomation(saved_automation, connector_params)
    let module = RegisteredModule{manifest_id: saved_automation.job_board}
    requires: exists module
    requires: module.status = active
        -- Only active modules accept automation configuration (security: prevents
        -- saving automations against deactivated or errored modules)
    requires: module.job_discovery_ext != null
        -- Only job discovery modules have connectorParams

    ensures: ConnectorParamsValidated(
        automation: saved_automation,
        module_id: module.manifest_id,
        params: connector_params
    )

    @guidance
        -- Prevents invalid connectorParams from reaching the module at search time
        -- The Automation Wizard renders dynamic form fields from the ConnectorParamField array
        -- Keys present in connectorParams but not declared in the schema are stripped
        -- before persistence (extraneous key stripping prevents injection of unexpected params)
}

-- =============================================================================
-- Rules: Activation / Deactivation
-- =============================================================================

rule ModuleActivation {
    -- "When a module is activated, its connector group becomes active."
    when: ActivateModule(module_id, admin_user_id)
    let module = RegisteredModule{manifest_id: module_id}
    requires: exists module
    requires: module.status = inactive or module.status = error
    requires: module.is_configured
        -- Cannot activate without required credentials

    ensures: module.status = active
    ensures: module.activated_at = now
    ensures: module.activated_by = admin_user_id

    @guidance
        -- Only admins can activate modules. See invariant AdminOnlyModuleLifecycle.
        -- Connector auto-activation is derived: ConnectorGroup.is_active recalculates
        -- because at least this module is now active.
}

rule ModuleDeactivation {
    -- "When a module is deactivated and automations use it, those automations are paused."
    when: DeactivateModule(module_id, admin_user_id)
    let module = RegisteredModule{manifest_id: module_id}
    requires: exists module
    requires: module.status = active

    ensures: module.status = inactive

    -- Dependency chain: pause affected automations
    let affected_automations = Automations where job_board = module_id and status = active

    ensures:
        for automation in affected_automations:
            automation.status = paused
            automation.pause_reason = module_deactivated
            Notification.created(
                user_id: automation.user_id,
                type: module_deactivated,
                message: "Automation paused because module was deactivated",
                module_id: module_id
            )

    @guidance
        -- Only admins can deactivate modules. See invariant AdminOnlyModuleLifecycle.
}

rule ConnectorDeactivation {
    -- "When a connector group is deactivated, warn if modules are still active."
    when: DeactivateConnector(requested_connector_type, admin_user_id)
    let active_modules = RegisteredModules where connector_type = requested_connector_type and status = active

    requires: active_modules.count = 0
        or confirmed_deactivation = true

    ensures:
        for module in active_modules:
            DeactivateModule(module_id: module.manifest_id, admin_user_id: admin_user_id)
            -- Cascading deactivation triggers ModuleDeactivation rule for each

    @guidance
        -- The UI should confirm with the user before cascading deactivation.
        -- "Deactivating this connector will also deactivate N active module(s). Continue?"
}

rule DeactivatedModulesHidden {
    -- "Deactivated modules do not appear in the Automation Wizard module selector."
    when: LoadModuleSelector(requested_connector_type)
    let available_modules = RegisteredModules
        where connector_type = requested_connector_type
        and status = active

    ensures: ActiveModulesListed(modules: available_modules)

    @guidance
        -- Only active modules appear in the selector.
        -- Deactivated and errored modules are filtered out.
}

rule ReactivationIsManual {
    -- "Automations paused by module deactivation are NOT auto-restarted on reactivation."
    when: module: RegisteredModule.status transitions_to active
    let previously_paused = Automations where job_board = module.manifest_id and status = paused

    ensures: Notification.created(
        user_id: module.activated_by,
        type: module_reactivated,
        message: "Module is active again. Paused automations remain paused -- reactivate them manually."
    )

    @guidance
        -- Paused automations keep their status unchanged.
        -- User must manually reactivate each automation.
}

-- =============================================================================
-- Rules: Health Monitoring
-- =============================================================================

rule HealthCheckExecution {
    -- "Active modules with a health check config are periodically checked."
    when: HealthCheckDue(check_module_id)
    let module = RegisteredModule{manifest_id: check_module_id}
    requires: exists module
    requires: module.status = active
    requires: module.health_check_config != null

    let result = probe_health(module.health_check_config.endpoint, module.health_check_config.timeout_ms)

    ensures:
        if result = true:
            module.health_status = healthy
            module.last_successful_connection = now
        else if module.consecutive_failures < config.max_health_failures_before_error:
            module.health_status = degraded
        else:
            module.health_status = unreachable
    ensures: module.last_health_check = now
}

rule HealthStatusEscalation {
    -- "When a module becomes unreachable, affected automations are notified (but not paused)."
    when: module: RegisteredModule.health_status transitions_to unreachable
    let affected_automations = Automations where job_board = module.manifest_id and status = active

    ensures:
        for automation in affected_automations:
            Notification.created(
                user_id: automation.user_id,
                type: module_unreachable,
                message: "Module is unreachable. Automations using it may fail."
            )

    @guidance
        -- This rule is notification-only. There are two distinct failure signals:
        --
        --   Health CHECK = "can I reach you?" (periodic ping)
        --     -> Notification only. The module may recover. Keeps existing behaviour.
        --
        --   CB state / Run failures = "are you actually working?" (real request outcomes)
        --     -> CAN trigger automation pause. See CircuitBreakerEscalation,
        --       ConsecutiveRunFailureEscalation, and AuthFailureEscalation rules.
        --
        -- Health checks are leading indicators; CB/run failures are lagging confirmation.
        -- Only the latter justify pausing automations because they reflect actual work failing.
}

rule DependencyHealthDegradation {
    -- "When a module's dependency becomes unreachable, the module's health degrades."
    -- Dependencies are checked alongside the module's primary health check.
    -- A failed dependency can degrade the parent but NEVER make it unreachable --
    -- only the primary health check controls the unreachable transition.
    when: DependencyCheckDue(check_module_id)
    let module = RegisteredModule{manifest_id: check_module_id}
    requires: exists module
    requires: module.status = active
    requires: module.dependency_checks.count > 0

    let any_dep_failed = check_dependencies(module.dependency_checks)

    ensures:
        if any_dep_failed = true and module.health_status = healthy:
            module.health_status = degraded
            -- max() semantics: if the module is already unreachable (from its own health check),
            -- it stays unreachable. If it was healthy, it becomes degraded.

    @guidance
        -- This rule runs as part of the regular health check cycle (HealthCheckExecution).
        -- The primary health check determines the base status (healthy/degraded/unreachable).
        -- Dependency checks can only RAISE the status to degraded, never lower it.
        -- This preserves the distinction: primary = "can I reach you?",
        -- dependency = "can your features work fully?"
}

-- =============================================================================
-- Rules: Circuit Breaker State
-- =============================================================================

rule CircuitBreakerStateTransition {
    -- "When a module's circuit breaker opens, the observable state is updated."
    -- The Connector provisions CB policies from manifest.resilience at instantiation.
    -- This rule captures the observable state change, not the CB implementation.
    when: CircuitBreakerTripped(tripped_module_id)
    let module = RegisteredModule{manifest_id: tripped_module_id}
    requires: exists module
    requires: module.status = active
    requires: module.has_cb_enabled

    ensures: module.circuit_breaker_state = open
    ensures: module.circuit_breaker_open_since = now
    ensures: module.consecutive_failures = module.consecutive_failures + 1
}

rule CircuitBreakerRecovery {
    -- "When a module's circuit breaker closes after successful half-open probe."
    when: CircuitBreakerRecovered(recovered_module_id)
    let module = RegisteredModule{manifest_id: recovered_module_id}
    requires: exists module
    requires: module.circuit_breaker_state = open or module.circuit_breaker_state = half_open

    ensures: module.circuit_breaker_state = closed
    ensures: module.consecutive_failures = 0
    ensures: module.circuit_breaker_open_since = null
}

rule CircuitBreakerHalfOpen {
    -- "When the cooldown expires, the CB transitions to half-open for a probe request."
    when: CircuitBreakerCooldownExpired(cooldown_module_id)
    let module = RegisteredModule{manifest_id: cooldown_module_id}
    requires: exists module
    requires: module.circuit_breaker_state = open

    ensures: module.circuit_breaker_state = half_open
}

-- =============================================================================
-- Rules: Automation Degradation
-- =============================================================================

rule CircuitBreakerEscalation {
    -- "When a module's CB has opened too many times, pause automations using it."
    -- Fires once when cb_escalation_due transitions from false to true
    -- (standard derived condition trigger semantics).
    when: module: RegisteredModule.cb_escalation_due
    requires: module.status = active

    let affected_automations = Automations where job_board = module.manifest_id and status = active

    ensures:
        for automation in affected_automations:
            automation.status = paused
            automation.pause_reason = cb_escalation
            Notification.created(
                user_id: automation.user_id,
                type: cb_escalation,
                message: "Automation paused: module circuit breaker has opened too many times consecutively.",
                module_id: module.manifest_id,
                automation_id: automation.id
            )

    @guidance
        -- The threshold is config.cb_escalation_threshold (default 3).
        -- A single CB open event is normal resilience behaviour.
        -- Repeated CB opens without recovery indicate a systemic problem.
        -- Recovery (CircuitBreakerRecovery) resets consecutive_failures to 0,
        -- which resets cb_escalation_due to false, allowing re-fire if the module
        -- degrades again after recovery.
}

rule ConsecutiveRunFailureEscalation {
    -- "When an automation's recent runs have all been terminal failures, pause it."
    when: run: AutomationRun.status becomes failed
    let automation = Automation{id: run.automation_id}
    requires: exists automation
    requires: automation.status = active

    let recent_failure_count = count_recent_failures(run.automation_id, config.consecutive_run_failure_threshold)

    requires: recent_failure_count >= config.consecutive_run_failure_threshold

    ensures: automation.status = paused
    ensures: automation.pause_reason = consecutive_failures
    ensures: Notification.created(
        user_id: automation.user_id,
        type: consecutive_failures,
        message: "Automation paused after consecutive failed runs.",
        automation_id: automation.id
    )

    @guidance
        -- This catches modules that are "reachable" (health check passes) but
        -- consistently fail during actual work (e.g., API returns errors, parsing fails).
        -- The threshold is per-automation, not per-module, because different automations
        -- may exercise different code paths in the same module.
        -- Also fires for blocked and rate_limited terminal statuses in implementation.
}

rule AuthFailureEscalation {
    -- "When a module's credential becomes invalid during operation, pause affected automations."
    when: AuthenticationFailed(failed_module_id, error_detail)
    let module = RegisteredModule{manifest_id: failed_module_id}
    requires: exists module
    requires: module.status = active
    requires: module.credential.required = true

    ensures: module.status = error

    let affected_automations = Automations where job_board = failed_module_id and status = active

    ensures:
        for automation in affected_automations:
            automation.status = paused
            automation.pause_reason = auth_failure
            Notification.created(
                user_id: automation.user_id,
                type: auth_failure,
                message: "Automation paused: module authentication failed. Please check your credentials.",
                module_id: failed_module_id,
                automation_id: automation.id
            )

    @guidance
        -- Auth failures are immediate: a single failure pauses because there is no
        -- point retrying with the same invalid credential. Distinct from CB escalation
        -- where transient failures are expected and the threshold allows recovery.
        -- The module transitions to error status, requiring reconfiguration before reactivation.
}

-- =============================================================================
-- Invariants
-- =============================================================================

invariant UniqueModuleIds {
    for a in RegisteredModules:
        for b in RegisteredModules:
            a != b implies a.manifest_id != b.manifest_id
}

invariant NoOrphanAutomations {
    for automation in Automations:
        automation.status = active implies
            exists RegisteredModule{manifest_id: automation.job_board}
}

invariant PausedAutomationHasReason {
    for automation in Automations:
        automation.status = paused implies automation.pause_reason != null
}

-- Prose invariant: AdminOnlyModuleLifecycle
-- Only admins can activate or deactivate a module.
-- Introduced by Sprint 1.5 CRIT-S-04. Previously the ActivateModule and
-- DeactivateModule rules checked only by: User -- ANY authenticated user
-- passed the gate. Because modules are shared singletons (not per-user),
-- and because deactivation cascades into every tenant's active automations
-- (see rule ModuleDeactivation), non-admin callers could pause every other
-- user's job-discovery pipeline from a single browser Server Action call.
--
-- Admin authorization uses a tiered rule:
--   Tier A: ADMIN_USER_IDS env var (comma-separated user ids)
--   Tier B: single-user implicit (userCount = 1 and sole user matches caller)
--   Tier C: fail-closed (multi-user without ADMIN_USER_IDS = denied)
--
-- Every admin call emits an AdminAuditLog entry
--   naming {actorId, action, targetId, tier, allowed, ts}
-- Admin-action rate limited to 10 per minute per actor.
--
-- Implemented in src/lib/auth/admin.ts (requireAdmin/authorizeAdminAction)
-- Rate limit implemented in src/lib/auth/admin-rate-limit.ts
-- Enforcement sites: src/actions/module.actions.ts (activateModule, deactivateModule)
-- JobSync has NO role model -- tiered rule preserves zero-config single-user UX
-- while closing the multi-tenant gap
-- runHealthCheck is intentionally EXCLUDED from this gate -- confirmed-safe by Sprint 3 Stream C audit.
--   Reason: checkModuleHealth writes only module.healthStatus (HEALTHY/DEGRADED/UNREACHABLE),
--   NOT module.status (ACTIVE/INACTIVE). Health-status writes have zero automation-pause cascade.
--   Bounded by checkHealthCheckRateLimit (per-user). See docs/BUGS.md Sprint 1.5 follow-up (closed).

-- Prose invariant: SettingsFromManifest
-- Settings UI for any module is derived from its ModuleManifest.
-- No hardcoded module lists in UI components.
-- known_violation resolved: ApiKeySettings.tsx now queries registry via getCredentialModules()
-- resolved: DESCRIPTION_KEYS replaced by manifest.i18n credentialHint (ADR-028, 2026-04-08)

-- =============================================================================
-- Actor Declarations
-- =============================================================================

actor EndUser {
    identified_by: Automation where user_id != null
    -- Activates/deactivates modules, configures settings, views health status
}

actor SystemActor {
    identified_by: RegisteredModule where status != null
    -- Propagates settings, monitors health, pauses automations on deactivation,
    -- tracks circuit breaker state, escalates degradation
}

-- =============================================================================
-- Surfaces
-- =============================================================================

surface ModuleMarketplace {
    facing viewer: EndUser

    exposes:
        viewer.user_id

    provides:
        ActivateModule(module_id, admin_user_id)
        DeactivateModule(module_id, admin_user_id)

    @guarantee ModulesFromRegistry
        -- All displayed modules come from the registry, not hardcoded lists
        -- New modules appear automatically after registration

    @guidance
        -- Exposes: connectorType, connectorStatus (derived),
        -- modules (per connector): id, name, status, healthStatus, lastSuccessfulConnection,
        -- isConfigured, circuitBreakerState, consecutiveFailures
        -- Also provides ConfigureModule(moduleId, settings)
        -- Related: AutomationWizard, SettingsPage
}

surface AutomationWizard {
    facing viewer: EndUser

    exposes:
        viewer.user_id

    provides:
        SaveAutomation(saved_automation, connector_params)
        LoadModuleSelector(requested_connector_type)

    @guarantee DynamicFormFields
        -- Form fields for connectorParams are generated from the ConnectorParamField array
        -- Search field widgets are swapped per SearchFieldOverride declarations
        -- Not hardcoded per module

    @guidance
        -- Exposes: availableModules (RegisteredModule where status = active and connectorType = job_discovery),
        -- selectedModule.connectorParamsSchema, selectedModule.searchFieldOverrides,
        -- selectedModule.automationType
}

surface NotificationInbox {
    facing viewer: EndUser

    exposes:
        viewer.user_id

    provides:
        MarkAsRead(notification_id)
        MarkAllAsRead()
        DismissNotification(notification_id)

    @guarantee PersistentNotifications
        -- Notifications persist across sessions (DB-backed, not ephemeral toasts)
        -- Users see alerts even when not actively using the app

    @guidance
        -- Exposes: unread count, notification list (newest first),
        -- type, message, moduleId, automationId, createdAt, read status
}

surface ModuleHealthOverview {
    facing viewer: EndUser

    exposes:
        viewer.user_id

    provides:
        HealthCheckDue(check_module_id)

    @guarantee AllModulesVisible
        -- Shows ALL registered modules regardless of credential type or connector type
        -- Keyless modules (EURES, Arbeitsagentur, ESCO, Eurostat) are visible
        -- Key-based modules show credential status alongside health
        -- Dependencies shown as tree structure under parent module

    @guidance
        -- The ModuleMarketplace surface handles activation/deactivation and configuration.
        -- This surface is a read-oriented health dashboard that ensures no module is invisible
        -- just because it has credential.type = none and therefore no Settings panel entry.
        -- credential.type is exposed so the UI can distinguish key-based from keyless modules
        -- and avoid showing a "configure credentials" action for modules that need none.
        -- Exposes: all registered modules grouped by connectorType,
        -- per module: id, name, healthStatus, lastHealthCheck, lastSuccessfulConnection,
        --   circuitBreakerState, credential.type,
        --   dependencies: per dep: id, name, healthStatus, required, usedFor
}

