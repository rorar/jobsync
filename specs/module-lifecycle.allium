-- allium: 3
-- module-lifecycle.allium

-- Scope: Module Lifecycle Manager for the Connector/Module ecosystem
-- Includes: Module Manifest (registration contract), Settings propagation,
--           Activation/Deactivation lifecycle, Health monitoring, Dependency management,
--           Automation degradation (CB escalation, run failures, auth failures)
-- Excludes:
--   - Connector implementation details (covered by DataSourceConnector / AIProviderConnector interfaces)
--   - Module-internal logic (each module's bounded context)
--   - UI rendering (Settings pages, Marketplace layout)
--   - Resilience implementation (Cockatiel/circuit-breaker internals)
-- Dependencies: Automation entity defined in jobsync.allium

-- =============================================================================
-- Actors
-- =============================================================================

actor User {
  -- Activates/deactivates modules, configures settings, views health status
}

actor System {
  -- Propagates settings, monitors health, pauses automations on deactivation,
  -- tracks circuit breaker state, escalates degradation
}

-- =============================================================================
-- Enums
-- =============================================================================

enum ConnectorType { job_discovery | ai_provider | data_enrichment | reference_data }
-- Future: kalender | communication | geo | webhook | workflow | bewertungsportal | dokumentenworkflow

enum ModuleStatus { active | inactive | error }

enum HealthStatus { healthy | degraded | unreachable | unknown }

enum CredentialType { api_key | endpoint_url | none }
-- oauth_token removed: no module uses OAuth tokens. If eID/AusweisApp
-- is added later, a new type can be introduced.

enum CircuitBreakerState { closed | open | half_open }

enum AutomationPauseReason { module_deactivated | auth_failure | consecutive_failures | cb_escalation }

enum NotificationType { module_deactivated | module_reactivated | module_unreachable | cb_escalation | consecutive_failures | auth_failure }

-- =============================================================================
-- Contracts (Published Language)
-- =============================================================================

-- The base contract every module must fulfill when registering with its connector.
-- This is the Published Language (DDD) between the Connector domain boundary
-- and its Module implementations.

contract ModuleManifest {
  -- Identity
  id: String                          -- unique module identifier (e.g. "eures", "ollama")
  name: String                        -- human-readable display name
  manifestVersion: Integer            -- schema version for breaking changes (starts at 1)
  connectorType: ConnectorType        -- which connector this module belongs to

  -- Credentials
  credential: CredentialRequirement   -- what this module needs to authenticate

  -- Settings
  settingsSchema: SettingsSchema?     -- module-specific user-configurable settings

  -- Health
  healthCheck: HealthCheckConfig?     -- how to verify the module is reachable

  -- Resilience
  resilience: ResilienceConfig?       -- retry, circuit breaker, rate limit defaults

  -- Caching (ROADMAP 0.9 Stufe 1)
  cachePolicy: CachePolicy?           -- response caching policy; null = no caching

  -- Dependencies
  dependencies: DependencyHealthCheck[]?  -- external services this module depends on
                                          -- declared dependencies are health-checked alongside the module
                                          -- and exposed in the Module Health Overview surface

  -- i18n
  i18n: ModuleI18n?                     -- per-locale translations for UI display
                                        -- keyed by locale code (e.g. "en", "de", "fr", "es")
                                        -- UI reads manifest.i18n[locale].name instead of global i18n dictionaries
}

-- Connector-specific extensions of the base contract.
-- Each connector type defines what additional settings its modules can declare.

contract JobDiscoveryManifest extends ModuleManifest {
  automationType: discovery | maintenance = discovery
    -- discovery: find new vacancies; maintenance: update existing vacancy data
  connectorParamsSchema: ConnectorParamField[]?
    -- Ordered array of typed field descriptors for module-specific search filters
    -- (e.g. umkreis, publicationPeriod). Validated against automation.connectorParams
    -- before search execution. The Automation Wizard renders form fields from this array.
  searchFieldOverrides: SearchFieldOverride[]?
    -- Modules may replace the standard keywords/location search fields with
    -- specialised widgets (e.g. EURES replaces keywords with ESCO occupation combobox)
}

contract AiManifest extends ModuleManifest {
  modelSelection: ModelSelectionConfig  -- how models are discovered and selected
}

contract DataEnrichmentManifest extends ModuleManifest {
  supportedDimensions: String[]         -- enrichment dimensions this module can serve (e.g. "logo", "deep_link")
                                        -- empty array [] for health-only modules (status monitoring, no enrichment)
}

contract ReferenceDataManifest extends ModuleManifest {
  taxonomy: String                      -- which taxonomy this module provides (e.g. "esco_occupations", "nuts_regions")
  -- Note: No connector interface yet (health-only modules).
  -- A lookup() interface will be added when the first consumer needs programmatic access
  -- (e.g. Skillsets 4.1, CareerBERT 9.1). Until then, reference data is consumed via
  -- API proxy routes, not through the connector layer.
}

-- =============================================================================
-- Value Types (Settings Declaration)
-- =============================================================================

value CredentialRequirement {
  type: CredentialType                -- what kind of credential
  moduleId: String                    -- API key table lookup key (e.g. "openai", "rapidapi")
  required: Boolean                   -- must be present for module to function
  envFallback: String?                -- environment variable name (e.g. "OPENAI_API_KEY")
  defaultValue: String?               -- default value if no credential provided (e.g. localhost URL)
  sensitive: Boolean = true           -- whether to mask in UI (false for URLs like Ollama)
  placeholder: String?               -- UI hint (e.g. "sk-...", "http://127.0.0.1:11434")
}

value SettingsSchema {
  fields: SettingsField[]             -- ordered list of configurable fields
}

value SettingsField {
  key: String                         -- field identifier
  label: String                       -- i18n key for display label
  type: string | number | boolean | select
  defaultValue: String?               -- default value
  options: String[]?                  -- for enum type: allowed values
  validation: String?                 -- validation rule (e.g. "min:0, max:200")
}

value HealthCheckConfig {
  endpoint: String?                   -- URL or relative path to probe (absolute for public APIs, relative for configurable base URLs)
  timeoutMs: Integer = 5000          -- milliseconds
  intervalMs: Integer = 300000       -- how often to check (ms), default 5 min
}

value ResilienceConfig {
  retryAttempts: Integer = 0          -- 0 = no retry
  retryBackoff: exponential | linear | none = none
  circuitBreaker: Boolean = false
  circuitBreakerThreshold: Integer = 5   -- failures before opening
  circuitBreakerCooldownMs: Integer = 30000  -- ms before half-open
  timeoutMs: Integer = 15000          -- request timeout ms
  rateLimitTokens: Integer?           -- token bucket size (null = no limit)
  rateLimitRefillMs: Integer?         -- token refill interval
  maxConcurrent: Integer?             -- bulkhead limit
}

value CachePolicy {
  ttl: Integer                          -- cache time-to-live in seconds
  scope: shared | per_user              -- shared = global cache; per_user = user-specific cache
  localeSensitive: Boolean              -- whether locale affects cache key
}

value ModelSelectionConfig {
  defaultModel: String?               -- e.g. "llama3.2"
  listEndpoint: String?               -- API path to list available models (e.g. "/models")
}

value DependencyHealthCheck {
  id: String                            -- stable identifier (e.g. "esco_classification")
  name: String                          -- human-readable display name
  endpoint: String                      -- health probe URL (absolute)
  timeoutMs: Integer = 5000            -- probe timeout in milliseconds
  required: Boolean = false             -- true = hard dependency (module cannot function without it)
                                        -- false = soft dependency (module degrades gracefully)
  usedFor: String                       -- human-readable purpose (e.g. "Occupation search in Automation Wizard")
}

value ModuleI18n {
  -- Map of locale code to display strings
  -- Each entry: { name: String, description: String, credentialHint: String? }
  -- credentialHint: UI hint for API key/endpoint settings field (optional, only for modules with credentials)
  -- Example: { en: { name: "EURES", description: "EU job search", credentialHint: "Enter your API key..." } }
}

value ConnectorParamField {
  key: String                         -- field identifier (e.g. "umkreis", "publicationPeriod")
  type: string | number | boolean | select | multiselect
  label: String                       -- i18n key (e.g. "automations.params.umkreis")
  defaultValue: Any?                  -- default value for the field
  options: (String | Number)[]?       -- allowed values for select/multiselect types
  required: Boolean = false           -- whether the field must be provided
  min: Number?                        -- minimum value constraint (number type)
  max: Number?                        -- maximum value constraint (number type)
  placeholder: String?                -- UI hint text
}

value SearchFieldOverride {
  field: keywords | location          -- which standard search field to replace
  widgetId: String                    -- identifier of the replacement widget (e.g. "eures-occupation")
}

-- =============================================================================
-- Entities
-- =============================================================================

entity RegisteredModule {
  manifest: ModuleManifest            -- declared at registration time (immutable)
  status: ModuleStatus = active       -- lifecycle state (modules register as active)
  healthStatus: HealthStatus = unknown
  lastHealthCheck: DateTime?
  lastSuccessfulConnection: DateTime?
  activatedAt: DateTime?
  activatedBy: User?

  -- Circuit breaker runtime state (observable)
  -- These fields reflect the CB state provisioned from manifest.resilience.
  -- Whether stored in-memory or persisted is implementation; the spec cares that
  -- the state is observable and can trigger automation degradation.
  circuitBreakerState: CircuitBreakerState = closed
  consecutiveFailures: Integer = 0
  circuitBreakerOpenSince: DateTime?

  -- Derived
  isConfigured: credential resolved or credential not required
  isOperational: status = active and healthStatus != unreachable
  hasCbEnabled: manifest.resilience != null and manifest.resilience.circuitBreaker = true
  cbEscalationDue: hasCbEnabled and consecutiveFailures >= config.CB_ESCALATION_THRESHOLD
}

entity Notification {
  id: String
  userId: String
  type: NotificationType
  message: String
  moduleId: String?
  automationId: String?
  read: Boolean = false
  createdAt: DateTime
}

entity ConnectorGroup {
  type: ConnectorType                 -- job_discovery | ai_provider | ...
  modules: RegisteredModule[]         -- all modules registered under this connector

  -- Derived status: active when at least one module is active
  status: active | inactive
  isActive: exists module in modules where module.status = active
}

-- Reference to existing entity (defined in jobsync.allium)
external entity Automation {
  jobBoard: String                    -- module ID used for search
  status: active | paused | ...
  userId: String
  name: String
  pauseReason: AutomationPauseReason? -- set when status transitions to paused
}

-- Reference to existing entity (defined in jobsync.allium)
external entity AutomationRun {
  automationId: String
  status: running | completed | completed_with_errors | failed | blocked | rate_limited
  errorMessage: String?
  startedAt: DateTime
  completedAt: DateTime?
}

-- =============================================================================
-- Config
-- =============================================================================

config {
  HEALTH_CHECK_INTERVAL_MS: Integer = 300000       -- 5 minutes
  HEALTH_CHECK_TIMEOUT_MS: Integer = 5000          -- 5 seconds
  MAX_HEALTH_FAILURES_BEFORE_ERROR: Integer = 3    -- consecutive failures before status = error
  CB_ESCALATION_THRESHOLD: Integer = 3             -- consecutive CB open events before pausing automations
  CONSECUTIVE_RUN_FAILURE_THRESHOLD: Integer = 5   -- consecutive failed runs per automation before pausing
  NOTIFICATION_RETENTION_DAYS: Integer = 30        -- auto-delete notifications older than 30 days
}

-- =============================================================================
-- Rules: Registration
-- =============================================================================

rule ModuleRegistration {
  -- "When a module registers, it provides its manifest to the connector."
  -- Registration happens at application startup, not at runtime.
  when: RegisterModule(manifest: ModuleManifest)
  requires: not exists RegisteredModule where manifest.id = manifest.id
    -- Module IDs must be unique across the entire system
  requires: manifest.id != ""
  requires: manifest.name != ""

  let connector = ConnectorGroup where type = manifest.connectorType

  ensures: RegisteredModule.created(
    manifest: manifest,
    status: active,
    healthStatus: unknown,
    circuitBreakerState: closed,
    consecutiveFailures: 0
  )
  ensures: connector.modules includes new RegisteredModule

  @guidance
    -- Modules register as active. Users deactivate explicitly via ModuleMarketplace.
    -- This preserves the existing startup behavior where all modules are immediately usable.
}

rule ManifestDrivesSettingsUI {
  -- "The settings UI is generated from module manifests, not hardcoded."
  -- When the settings page loads, it queries registered modules for their manifests.
  when: LoadSettingsPage(connectorType: ConnectorType)
  let modules = RegisteredModule where manifest.connectorType = connectorType

  ensures: for_each module in modules:
    SettingsPanel.rendered(
      moduleId: module.manifest.id,
      credentialField: module.manifest.credential,
      settingsFields: module.manifest.settingsSchema
    )

  @guidance
    -- Replaces the hardcoded MODULES array in ApiKeySettings.tsx
    -- The UI iterates over registered manifests instead of a static list
}

-- =============================================================================
-- Rules: Settings Propagation (PUSH pattern)
-- =============================================================================

rule SettingsPushOnInstantiation {
  -- "When a module is instantiated for use, settings are resolved and pushed to it."
  -- This replaces the current PULL pattern where modules call resolveApiKey() ad-hoc.
  when: InstantiateModule(moduleId: String, userId: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = active

  let credential = CredentialResolver.resolve(
    moduleId: moduleId,
    userId: userId,
    requirement: module.manifest.credential
    -- Resolution priority: 1. User DB  2. Env var  3. Default
  )

  requires: credential != null or module.manifest.credential.required = false
    -- If credential is required but not found, instantiation fails

  ensures: ModuleInstance.created(
    moduleId: moduleId,
    credential: credential,
    settings: UserSettings where userId = userId and moduleId = moduleId
  )

  @phase Phase 2: credential push implemented
  @phase Phase 3: full settings push (UserSettings) planned

  @guidance
    -- The module receives its settings at creation time (constructor injection)
    -- It never reaches out to resolve settings itself
    -- This is Dependency Inversion: the system pushes, the module receives
}

rule ConnectorParamsValidation {
  -- "When an automation is created or updated, its connectorParams are validated
  --  against the module's declared schema."
  when: SaveAutomation(automation: Automation)
  let module = RegisteredModule where manifest.id = automation.jobBoard
  requires: module.status = active
    -- Only active modules accept automation configuration (security: prevents
    -- saving automations against deactivated or errored modules)
  requires: module is JobDiscoveryManifest
    -- Only job discovery modules have connectorParams

  let schema = module.manifest.connectorParamsSchema

  requires: schema = null or automation.connectorParams validates_against schema
    -- If the module declares a schema, params must conform

  @guidance
    -- Prevents invalid connectorParams from reaching the module at search time
    -- The Automation Wizard renders dynamic form fields from the ConnectorParamField array
    -- Keys present in connectorParams but not declared in the schema are stripped
    -- before persistence (extraneous key stripping prevents injection of unexpected params)
}

-- =============================================================================
-- Rules: Activation / Deactivation
-- =============================================================================

rule ModuleActivation {
  -- "When a module is activated, its connector group becomes active."
  when: ActivateModule(moduleId: String, by: User)
  requires: by is authorized as admin  -- see invariant AdminOnlyModuleLifecycle
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = inactive or module.status = error
  requires: module.isConfigured
    -- Cannot activate without required credentials

  ensures: module.status = active
  ensures: module.activatedAt = now()
  ensures: module.activatedBy = by

  -- Connector auto-activation (derived)
  let connector = ConnectorGroup where type = module.manifest.connectorType
  ensures: connector.isActive = true
    -- Always true after activation since at least this module is active
}

rule ModuleDeactivation {
  -- "When a module is deactivated and automations use it, those automations are paused."
  when: DeactivateModule(moduleId: String, by: User)
  requires: by is authorized as admin  -- see invariant AdminOnlyModuleLifecycle
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = active

  ensures: module.status = inactive

  -- Dependency chain: pause affected automations
  let affectedAutomations = Automation where jobBoard = moduleId and status = active

  ensures: for_each automation in affectedAutomations:
    automation.status = paused
    automation.pauseReason = module_deactivated
    Notification.created(
      userId: automation.userId,
      type: module_deactivated,
      message: "Automation '{automation.name}' paused because module '{module.manifest.name}' was deactivated",
      moduleId: moduleId
    )
}

rule ConnectorDeactivation {
  -- "When a connector group is deactivated, warn if modules are still active."
  when: DeactivateConnector(connectorType: ConnectorType, by: User)
  let connector = ConnectorGroup where type = connectorType
  let activeModules = RegisteredModule where manifest.connectorType = connectorType and status = active

  requires: activeModules | count = 0
    or UserConfirmed("Deactivating this connector will also deactivate {activeModules | count} active module(s). Continue?")

  ensures: for_each module in activeModules:
    DeactivateModule(moduleId: module.manifest.id, by: by)
    -- Cascading deactivation triggers ModuleDeactivation rule for each
}

rule DeactivatedModulesHidden {
  -- "Deactivated modules do not appear in the Automation Wizard module selector."
  when: LoadModuleSelector(connectorType: ConnectorType)
  let availableModules = RegisteredModule
    where manifest.connectorType = connectorType
    and status = active

  ensures: only availableModules are shown in selector
}

rule ReactivationIsManual {
  -- "Automations paused by module deactivation are NOT auto-restarted on reactivation."
  when: ActivateModule(moduleId: String, by: User)
  let previouslyPaused = Automation where jobBoard = moduleId and status = paused

  ensures: for_each automation in previouslyPaused:
    automation.status = paused
    -- Status unchanged. User must manually reactivate each automation.

  ensures: Notification.created(
    userId: by,
    type: module_reactivated,
    message: "Module '{moduleId}' is active again. {previouslyPaused | count} automation(s) remain paused — reactivate them manually."
  )
}

-- =============================================================================
-- Rules: Health Monitoring
-- =============================================================================

rule HealthCheckExecution {
  -- "Active modules with a health check config are periodically checked."
  when: HealthCheckDue(moduleId: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = active
  requires: module.manifest.healthCheck != null

  let result = HealthProbe.execute(
    endpoint: module.manifest.healthCheck.endpoint,
    timeout: module.manifest.healthCheck.timeoutMs
  )

  ensures:
    if result.success:
      module.healthStatus = healthy
      module.lastSuccessfulConnection = now()
    else if module.consecutiveFailures < config.MAX_HEALTH_FAILURES_BEFORE_ERROR:
      module.healthStatus = degraded
    else:
      module.healthStatus = unreachable
  ensures: module.lastHealthCheck = now()
}

rule HealthStatusEscalation {
  -- "When a module becomes unreachable, affected automations are notified (but not paused)."
  when: module: RegisteredModule.healthStatus transitions_to unreachable
  let affectedAutomations = Automation where jobBoard = module.manifest.id and status = active

  ensures: for_each automation in affectedAutomations:
    Notification.created(
      userId: automation.userId,
      type: module_unreachable,
      message: "Module '{module.manifest.name}' is unreachable. Automations using it may fail."
    )
  -- Note: This rule is notification-only. There are two distinct failure signals:
  --
  --   Health CHECK = "can I reach you?" (periodic ping)
  --     → Notification only. The module may recover. Keeps existing behaviour.
  --
  --   CB state / Run failures = "are you actually working?" (real request outcomes)
  --     → CAN trigger automation pause. See CircuitBreakerEscalation,
  --       ConsecutiveRunFailureEscalation, and AuthFailureEscalation rules.
  --
  -- Health checks are leading indicators; CB/run failures are lagging confirmation.
  -- Only the latter justify pausing automations because they reflect actual work failing.
}

rule DependencyHealthDegradation {
  -- "When a module's dependency becomes unreachable, the module's health degrades."
  -- Dependencies are checked alongside the module's primary health check.
  -- A failed dependency can degrade the parent but NEVER make it unreachable —
  -- only the primary health check controls the unreachable transition.
  when: HealthCheckDue(moduleId: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = active
  requires: module.manifest.dependencies != null

  let depResults = for_each dep in module.manifest.dependencies:
    HealthProbe.execute(endpoint: dep.endpoint, timeout: dep.timeoutMs)

  ensures:
    if any depResult in depResults is not success:
      module.healthStatus = max(module.healthStatus, degraded)
        -- max() means: if the module is already unreachable (from its own health check),
        -- it stays unreachable. If it was healthy, it becomes degraded.

  @guidance
    -- This rule runs as part of the regular health check cycle (HealthCheckExecution).
    -- The primary health check determines the base status (healthy/degraded/unreachable).
    -- Dependency checks can only RAISE the status to degraded, never lower it.
    -- This preserves the distinction: primary = "can I reach you?",
    -- dependency = "can your features work fully?"
}

-- =============================================================================
-- Rules: Circuit Breaker State
-- =============================================================================

rule CircuitBreakerStateTransition {
  -- "When a module's circuit breaker opens, the observable state is updated."
  -- The Connector provisions CB policies from manifest.resilience at instantiation.
  -- This rule captures the observable state change, not the CB implementation.
  when: CircuitBreakerTripped(moduleId: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = active
  requires: module.hasCbEnabled

  ensures: module.circuitBreakerState = open
  ensures: module.circuitBreakerOpenSince = now()
  ensures: module.consecutiveFailures = module.consecutiveFailures + 1
}

rule CircuitBreakerRecovery {
  -- "When a module's circuit breaker closes after successful half-open probe."
  when: CircuitBreakerRecovered(moduleId: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.circuitBreakerState = open or module.circuitBreakerState = half_open

  ensures: module.circuitBreakerState = closed
  ensures: module.consecutiveFailures = 0
  ensures: module.circuitBreakerOpenSince = null
}

rule CircuitBreakerHalfOpen {
  -- "When the cooldown expires, the CB transitions to half-open for a probe request."
  when: CircuitBreakerCooldownExpired(moduleId: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.circuitBreakerState = open

  ensures: module.circuitBreakerState = half_open
}

-- =============================================================================
-- Rules: Automation Degradation
-- =============================================================================

rule CircuitBreakerEscalation {
  -- "When a module's CB has opened too many times, pause automations using it."
  -- Fires once when cbEscalationDue transitions from false to true
  -- (standard derived condition trigger semantics).
  when: module: RegisteredModule.cbEscalationDue
  requires: module.status = active

  let affectedAutomations = Automation where jobBoard = module.manifest.id and status = active

  ensures: for_each automation in affectedAutomations:
    automation.status = paused
    automation.pauseReason = cb_escalation
    Notification.created(
      userId: automation.userId,
      type: cb_escalation,
      message: "Automation '{automation.name}' paused: module '{module.manifest.name}' circuit breaker has opened {module.consecutiveFailures} times consecutively.",
      moduleId: module.manifest.id,
      automationId: automation.id
    )

  @guidance
    -- The threshold is config.CB_ESCALATION_THRESHOLD (default 3).
    -- A single CB open event is normal resilience behaviour.
    -- Repeated CB opens without recovery indicate a systemic problem.
    -- Recovery (CircuitBreakerRecovery) resets consecutiveFailures to 0,
    -- which resets cbEscalationDue to false, allowing re-fire if the module
    -- degrades again after recovery.
}

rule ConsecutiveRunFailureEscalation {
  -- "When an automation's recent runs have all been terminal failures, pause it."
  when: run: AutomationRun.status becomes failed or blocked or rate_limited
  let automation = Automation where id = run.automationId and status = active
  requires: automation != null

  let recentRuns = AutomationRun
    where automationId = run.automationId
    order_by startedAt descending
    limit config.CONSECUTIVE_RUN_FAILURE_THRESHOLD

  requires: recentRuns | count = config.CONSECUTIVE_RUN_FAILURE_THRESHOLD
  requires: recentRuns.all(r => r.status in { failed, blocked, rate_limited })

  ensures: automation.status = paused
  ensures: automation.pauseReason = consecutive_failures
  ensures: Notification.created(
    userId: automation.userId,
    type: consecutive_failures,
    message: "Automation '{automation.name}' paused after {config.CONSECUTIVE_RUN_FAILURE_THRESHOLD} consecutive failed runs.",
    automationId: automation.id
  )

  @guidance
    -- This catches modules that are "reachable" (health check passes) but
    -- consistently fail during actual work (e.g., API returns errors, parsing fails).
    -- The threshold is per-automation, not per-module, because different automations
    -- may exercise different code paths in the same module.
}

rule AuthFailureEscalation {
  -- "When a module's credential becomes invalid during operation, pause affected automations."
  when: AuthenticationFailed(moduleId: String, errorDetail: String)
  let module = RegisteredModule where manifest.id = moduleId
  requires: module.status = active
  requires: module.manifest.credential.required = true

  ensures: module.status = error

  let affectedAutomations = Automation where jobBoard = moduleId and status = active

  ensures: for_each automation in affectedAutomations:
    automation.status = paused
    automation.pauseReason = auth_failure
    Notification.created(
      userId: automation.userId,
      type: auth_failure,
      message: "Automation '{automation.name}' paused: module '{module.manifest.name}' authentication failed. Please check your credentials.",
      moduleId: moduleId,
      automationId: automation.id
    )

  @guidance
    -- Auth failures are immediate: a single failure pauses because there is no
    -- point retrying with the same invalid credential. Distinct from CB escalation
    -- where transient failures are expected and the threshold allows recovery.
    -- The module transitions to error status, requiring reconfiguration before reactivation.
}

-- =============================================================================
-- Invariants
-- =============================================================================

invariant UniqueModuleIds {
  ensures: no two RegisteredModule have the same manifest.id
  note: "Module IDs are globally unique across all connector types"
}

invariant ConnectorStatusDerived {
  ensures: for_each connector in ConnectorGroup:
    connector.isActive = exists module in connector.modules where module.status = active
  note: "Connector status is never set directly — always derived from module states"
}

invariant NoOrphanAutomations {
  ensures: for_each automation in Automation where status = active:
    exists RegisteredModule where manifest.id = automation.jobBoard and status = active
  note: "An active automation always references an active module"
  note: "Enforced by ModuleDeactivation, CircuitBreakerEscalation, ConsecutiveRunFailureEscalation, and AuthFailureEscalation rules"
  known_violation: "Currently automations can reference modules that don't exist in the registry"
  fix: "ModuleDeactivation rule pauses affected automations (implemented in this spec)"
}

invariant PausedAutomationHasReason {
  ensures: for_each automation in Automation where status = paused:
    automation.pauseReason != null
  note: "Every paused automation records why it was paused (AutomationPauseReason)"
  note: "Enables the UI to show actionable messages: reconfigure credentials vs. wait for recovery vs. reactivate module"
}

invariant SettingsFromManifest {
  ensures: Settings UI for any module is derived from its ModuleManifest
  note: "No hardcoded module lists in UI components"
  -- known_violation resolved: ApiKeySettings.tsx now queries registry via getCredentialModules()
  -- resolved: DESCRIPTION_KEYS replaced by manifest.i18n credentialHint (ADR-028, 2026-04-08)
}

invariant AdminOnlyModuleLifecycle {
  -- "Only admins can activate or deactivate a module."
  -- Introduced by Sprint 1.5 CRIT-S-04. Previously the `ActivateModule` and
  -- `DeactivateModule` rules checked only `by: User` — ANY authenticated user
  -- passed the gate. Because modules are shared singletons (not per-user),
  -- and because deactivation cascades into every tenant's active automations
  -- (see rule ModuleDeactivation), non-admin callers could pause every other
  -- user's job-discovery pipeline from a single browser Server Action call.
  ensures: for_each call in (ActivateModule, DeactivateModule):
    call.by is authorized as admin
      via AdminAuthorizationRule(
        explicit_list = env.ADMIN_USER_IDS,  -- Tier A
        implicit_single_user = userCount() = 1 and sole User.id = call.by.id,  -- Tier B
        otherwise = denied  -- Tier C (fail-closed)
      )
  ensures: every admin call emits an AdminAuditLog entry
    naming {actorId, action, targetId, tier, allowed, ts}
  ensures: admin-action rate <= 10 per minute per actor
  note: "Implemented in src/lib/auth/admin.ts (requireAdmin/authorizeAdminAction)"
  note: "Rate limit implemented in src/lib/auth/admin-rate-limit.ts"
  note: "Enforcement sites: src/actions/module.actions.ts (activateModule, deactivateModule)"
  note: "JobSync has NO role model — tiered rule preserves zero-config single-user UX while closing the multi-tenant gap"
  note: "runHealthCheck is intentionally EXCLUDED from this gate — confirmed-safe by Sprint 3 Stream C audit."
  note: "  Reason: checkModuleHealth writes only module.healthStatus (HEALTHY/DEGRADED/UNREACHABLE),"
  note: "  NOT module.status (ACTIVE/INACTIVE). Health-status writes have zero automation-pause cascade."
  note: "  Bounded by checkHealthCheckRateLimit (per-user). See docs/BUGS.md Sprint 1.5 follow-up (closed)."
  related_adr: "ADR-015 (IDOR ownership), ADR-018 (env-var security pattern), ADR-019 (use-server export security)"
}

-- =============================================================================
-- Surfaces
-- =============================================================================

surface ModuleMarketplace {
  facing actor: User
  context entity: ConnectorGroup[]

  exposes:
    connectorType, connectorStatus (derived),
    modules (per connector): id, name, status, healthStatus, lastSuccessfulConnection, isConfigured,
      circuitBreakerState, consecutiveFailures

  provides:
    ActivateModule(moduleId),
    DeactivateModule(moduleId),
    ConfigureModule(moduleId, settings)

  related: AutomationWizard, SettingsPage

  @guarantee ModulesFromRegistry
    -- All displayed modules come from the registry, not hardcoded lists
    -- New modules appear automatically after registration
}

surface AutomationWizard {
  facing actor: User
  context entity: Automation (new or existing)

  exposes:
    availableModules: RegisteredModule where status = active and connectorType = job_discovery,
    selectedModule.connectorParamsSchema: ConnectorParamField[]?,
    selectedModule.searchFieldOverrides: SearchFieldOverride[]?,
    selectedModule.automationType: discovery | maintenance

  provides:
    SelectModule(moduleId),
    ConfigureConnectorParams(params validated against module.connectorParamsSchema)

  @guarantee DynamicFormFields
    -- Form fields for connectorParams are generated from the ConnectorParamField array
    -- Search field widgets are swapped per SearchFieldOverride declarations
    -- Not hardcoded per module
}

surface NotificationInbox {
  facing actor: User
  context entity: Notification[]

  exposes:
    unread count, notification list (newest first),
    type, message, moduleId, automationId, createdAt, read status

  provides:
    MarkAsRead(notificationId),
    MarkAllAsRead(),
    DismissNotification(notificationId)

  @guarantee PersistentNotifications
    -- Notifications persist across sessions (DB-backed, not ephemeral toasts)
    -- Users see alerts even when not actively using the app
}

surface ModuleHealthOverview {
  facing actor: User
  context entity: RegisteredModule[]

  exposes:
    all registered modules grouped by connectorType,
    per module: id, name, healthStatus, lastHealthCheck, lastSuccessfulConnection,
      circuitBreakerState, credential.type,
      dependencies: per dep: id, name, healthStatus, required, usedFor

  provides:
    TriggerHealthCheck(moduleId)
      -- Manual re-check: runs the module's health probe on demand

  @guarantee AllModulesVisible
    -- Shows ALL registered modules regardless of credential type or connector type
    -- Keyless modules (EURES, Arbeitsagentur, ESCO, Eurostat) are visible
    -- Key-based modules show credential status alongside health
    -- Dependencies shown as tree structure under parent module

  @guidance
    -- The ModuleMarketplace surface handles activation/deactivation and configuration.
    -- This surface is a read-oriented health dashboard that ensures no module is invisible
    -- just because it has credential.type = none and therefore no Settings panel entry.
    -- credential.type is exposed so the UI can distinguish key-based from keyless modules
    -- and avoid showing a "configure credentials" action for modules that need none.
}

