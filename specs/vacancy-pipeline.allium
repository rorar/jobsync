-- allium: 3
-- vacancy-pipeline.allium

-- Scope: Vacancy Pipeline — Staging, Processing, Promotion, Archive, Trash
-- Includes: StagedVacancy lifecycle, Promotion to Job, Dedup (hash-based),
--           Bulk actions (partial-success), Undo pattern, DSGVO retention,
--           Domain events (VacancyPromoted, etc.)
-- Excludes:
--   - Job tracking lifecycle (status workflow, interviews, CRM — separate aggregate)
--   - Connector/Module internals (covered by module-lifecycle.allium)
--   - UI rendering (Staging page layout, JobDeck swipe mechanics)
--   - LLM match scoring implementation (AI Connector concern)
--   - Notification dispatch (covered by notification-dispatch.allium, future 0.6)
-- Dependencies:
--   - Job entity (tracking aggregate — target of promotion)
--   - Automation entity (source of automated intake)
--   - DiscoveredVacancy value type (connector output)
--   - User entity (owner of all staged vacancies)

-- =============================================================================
-- Actors
-- =============================================================================

actor User {
  -- Reviews staged vacancies, promotes to Job, dismisses, archives, restores.
  -- Creates manual vacancies that bypass staging (direct to Job).
}

actor Automation {
  -- Discovers vacancies via Job Discovery Connectors and stages them.
  -- Runs on a schedule, produces batches of StagedVacancy records.
}

-- =============================================================================
-- Enums
-- =============================================================================

enum StagedVacancyStatus { staged | processing | ready | promoted | dismissed }
-- staged:     Raw intake, not yet reviewed
-- processing: Currently being evaluated (LLM match in progress, or user is reviewing)
-- ready:      Reviewed and approved, awaiting promotion
-- promoted:   Promoted to Job (terminal — immutable after this)
-- dismissed:  User decided not to pursue (reversible via restore)

enum VacancySource { manual | automation }
-- manual:     User created via Add Job or Quick-Add
-- automation: Discovered by an Automation run

enum BulkActionType { promote | dismiss | archive | restore | delete }

-- =============================================================================
-- Config
-- =============================================================================

config {
  RETENTION_DAYS: Integer = 90
    -- Days before trashed StagedVacancy data is purged. Hash is retained.
  UNDO_WINDOW_SECONDS: Integer = 10
    -- Seconds after a destructive action during which undo is available.
  DEDUP_HASH_ALGORITHM: String = "sha256"
    -- One-way hash algorithm for dedup keys after retention purge.
  MAX_BULK_SIZE: Integer = 100
    -- Maximum items per bulk action.
  DISMISSED_RETENTION_DAYS: Integer = 30
    -- Days before dismissed vacancies are purged (shorter than trash).
}

-- =============================================================================
-- Value Types
-- =============================================================================

value DedupKey {
  userId: String
  sourceBoard: String               -- connector module ID (e.g. "eures", "jsearch")
  externalId: String                -- source system's native job ID
  -- Together these form the composite unique key for dedup.
  -- When externalId is absent, sourceUrl hash is used as fallback.
}

value PromotionInput {
  stagedVacancyId: String
  -- Optional overrides (user can adjust before promotion):
  jobTitleOverride: String?         -- override extracted title
  companyOverride: String?          -- override extracted employer
  locationOverride: String?         -- override extracted location
  tagsToApply: String[]?            -- tags to attach to the promoted Job
}

value BulkActionResult {
  totalRequested: Integer
  succeeded: Integer
  failed: Integer
  errors: BulkItemError[]           -- per-item errors for failed items
}

value BulkItemError {
  itemId: String
  reason: String
}

value UndoToken {
  id: String                        -- UUID, used to reference the token for undo/expiry
  actionType: BulkActionType
  compensationFn: CompensationFunction
    -- The function that reverses the action. Captured at action time.
    -- Must be idempotent — calling it multiple times has the same effect as calling once.
  itemIds: String[]                 -- IDs of affected StagedVacancy records
  previousStatuses: String[]        -- status before the action (for rollback)
  expiresAt: DateTime               -- now() + config.UNDO_WINDOW_SECONDS
  batchId: String?                  -- Links items from the same bulk operation.
                                    -- null for single-item actions.
                                    -- All items in a batch share one UndoToken.
}

value CompensationFunction {
  -- A closure that reverses a domain action.
  -- Captured at the time the action is performed (holds the previous state).
  -- Must be idempotent: calling compensate() N times = calling it once.
  compensate: (itemIds: String[], previousStatuses: String[]) -> Void
}

-- =============================================================================
-- Entities
-- =============================================================================

entity StagedVacancy {
  -- Discovery Context aggregate root.
  -- Raw vacancy intake — no Company FK, no JobStatus, no Resume.
  -- Those belong to the Job (Tracking) aggregate and are created at promotion time.

  id: String                        -- UUID
  userId: String                    -- owner

  -- Discovery identity (dedup key)
  sourceBoard: String               -- module ID: "eures", "arbeitsagentur", "jsearch", "manual"
  externalId: String?               -- source system's native ID (null for manual)
  sourceUrl: String?                -- original job posting URL

  -- Vacancy data (raw from connector or manual entry)
  title: String                     -- REQUIRED: only mandatory field for fast queue intake
  employerName: String?
  location: String?                 -- free-text location label
  description: String?
  salary: String?
  employmentType: String?           -- "full_time" | "part_time" | "contract"
  postedAt: DateTime?
  applicationDeadline: String?
  applicationInstructions: String?

  -- Source tracking
  source: VacancySource             -- manual or automation
  automationId: String?             -- FK to Automation (null for manual)

  -- Match data (optional — only populated when LLM is available)
  matchScore: Integer?              -- 0-100, from AI Connector
  matchData: String?                -- JSON blob with match reasoning

  -- Pipeline state
  status: StagedVacancyStatus = staged

  -- Promotion link (set once, immutable after)
  promotedToJobId: String?          -- FK to Job, set on promotion

  -- Archive / Trash lifecycle
  archivedAt: DateTime?
  trashedAt: DateTime?

  -- Timestamps
  discoveredAt: DateTime = now()    -- when the vacancy entered the system
  createdAt: DateTime = now()
  updatedAt: DateTime               -- auto-updated on any change
}

entity DedupHash {
  -- Privacy-preserving dedup record.
  -- Retained after StagedVacancy data is purged (DSGVO Art. 25 Privacy by Design).
  -- One-way hash — original data is not reconstructable.

  id: String
  userId: String
  hash: String                      -- sha256(sourceBoard + ":" + externalId)
  sourceBoard: String               -- retained for partitioned dedup queries
  createdAt: DateTime = now()
}

-- Reference to existing entities (defined in jobsync domain)
external entity Job {
  -- Tracking aggregate. Target of promotion.
  -- Created by promoteStagedVacancyToJob with clean tracking fields.
  id: String
  userId: String
}

external entity Automation {
  -- Produces StagedVacancy records via the runner.
  id: String
  userId: String
  jobBoard: String                  -- module ID used for search
}

-- =============================================================================
-- Rules: Intake
-- =============================================================================

rule AutomatedVacancyIntake {
  -- "When an automation discovers a vacancy, it is staged for review."
  -- Called by the runner after connector.search() + optional AI matching.
  when: AutomationRunCompleted(automationId: String, vacancies: DiscoveredVacancy[])
  let automation = Automation where id = automationId

  for_each vacancy in vacancies:
    let dedupKey = DedupKey(userId: automation.userId, sourceBoard: vacancy.sourceBoard, externalId: vacancy.externalId)

    -- Dedup check: skip if already staged or promoted
    requires: not exists StagedVacancy where userId = automation.userId
      and sourceBoard = vacancy.sourceBoard
      and externalId = vacancy.externalId
      and status != dismissed
    -- Dismissed vacancies are NOT deduped — rediscovery creates a new staged entry.
    -- Also check DedupHash table for purged records.
    requires: not exists DedupHash where userId = automation.userId
      and hash = hash(dedupKey)

    ensures: StagedVacancy.created(
      userId: automation.userId,
      sourceBoard: vacancy.sourceBoard,
      externalId: vacancy.externalId,
      sourceUrl: vacancy.sourceUrl,
      title: vacancy.title,
      employerName: vacancy.employerName,
      location: vacancy.location,
      description: vacancy.description,
      salary: vacancy.salary,
      employmentType: vacancy.employmentType,
      postedAt: vacancy.postedAt,
      applicationDeadline: vacancy.applicationDeadline,
      applicationInstructions: vacancy.applicationInstructions,
      source: automation,
      automationId: automation.id,
      matchScore: vacancy.matchScore,
      matchData: vacancy.matchData,
      status: staged,
      discoveredAt: now()
    )

  @guidance
    -- If externalId is null (connector doesn't provide it), fall back to
    -- hash(sourceUrl) as the dedup key. This is less reliable (URLs change)
    -- but better than no dedup.
    -- Upsert semantics: if a dismissed vacancy is rediscovered, it creates
    -- a new staged entry (not upsert). The user explicitly dismissed it,
    -- so rediscovery is a new signal.
    -- On rediscovery of an existing non-dismissed vacancy, matchScore and matchData
    -- are updated (upsert semantics). This refreshes AI match data when automations
    -- re-run with overlapping results. No new StagedVacancy is created.
}

rule ManualVacancyBypass {
  -- "Manually created jobs bypass staging entirely."
  -- The existing addJob() flow creates a Job directly.
  -- This rule documents the design decision, not a new behavior.
  when: UserCreatesManualJob(data: JobFormData)

  ensures: Job.created(data)
  -- No StagedVacancy is created. Manual jobs are already "reviewed" by the user.

  @guidance
    -- Future option (ROADMAP): User can choose "Add to Queue" for manual jobs
    -- if they want to batch-review later. This would create a StagedVacancy
    -- with source = manual instead of a Job.
}

-- =============================================================================
-- Rules: Pipeline Transitions
-- =============================================================================

rule VacancyPromotion {
  -- "When a user promotes a staged vacancy, a Job is created in the Tracking aggregate."
  -- This is the explicit boundary crossing between Discovery and Tracking contexts.
  when: PromoteVacancy(input: PromotionInput, by: User)
  let vacancy = StagedVacancy where id = input.stagedVacancyId

  requires: vacancy.userId = by.id
    -- Only the owner can promote their own vacancies
  requires: vacancy.status = staged or vacancy.status = ready
    -- Cannot promote dismissed, archived, or already-promoted vacancies
  requires: vacancy.promotedToJobId = null
    -- Cannot promote twice

  -- Transition to processing during the operation
  ensures: vacancy.status = processing

  -- Find-or-create reference data (Tracking context concerns)
  let jobTitle = JobTitle.findOrCreate(
    title: input.jobTitleOverride or vacancy.title,
    userId: by.id
  )
  let company = Company.findOrCreate(
    name: input.companyOverride or vacancy.employerName or "Unknown",
    userId: by.id
  )
  let location = Location.findOrCreate(
    label: input.locationOverride or vacancy.location,
    userId: by.id
  )
  let jobSource = JobSource.findOrCreate(
    name: vacancy.sourceBoard,
    userId: by.id
  )
  let defaultStatus = JobStatus where value = "bookmarked"

  -- Create clean Job (no discovery fields)
  ensures: Job.created(
    userId: by.id,
    jobUrl: vacancy.sourceUrl,
    description: vacancy.description,
    jobType: vacancy.employmentType or "Full-time",
    applied: false,
    statusId: defaultStatus.id,
    jobTitleId: jobTitle.id,
    companyId: company.id,
    locationId: location.id,
    jobSourceId: jobSource.id,
    salaryRange: vacancy.salary,
    tags: input.tagsToApply
  )

  -- Link back (immutable reference for audit)
  ensures: vacancy.promotedToJobId = Job.id
  ensures: vacancy.status = promoted

  -- Domain event
  ensures: VacancyPromoted.emitted(
    stagedVacancyId: vacancy.id,
    jobId: Job.id,
    userId: by.id
  )

  @guidance
    -- The entire promotion (find-or-create + Job.create + vacancy update)
    -- runs in a single database transaction for atomicity.
    -- If any step fails, the vacancy remains in its previous status.
    --
    -- VacancyPromoted is the key domain event that downstream consumers
    -- (0.6 Event Bus) will subscribe to for:
    --   - CompanyNeeded → Data Enrichment (1.13)
    --   - DocumentsAvailable → Document Generators (4.2)
    --   - CrmChanceCreated → CRM (5)
}

rule VacancyDismissal {
  -- "User decides not to pursue this vacancy."
  when: DismissVacancy(vacancyId: String, by: User)
  let vacancy = StagedVacancy where id = vacancyId

  requires: vacancy.userId = by.id
  requires: vacancy.status = staged or vacancy.status = ready
    -- Cannot dismiss promoted or already-dismissed vacancies

  ensures: vacancy.status = dismissed
  ensures: VacancyDismissed.emitted(stagedVacancyId: vacancy.id, userId: by.id)
  ensures: UndoToken.created(
    actionType: dismiss,
    itemIds: [vacancy.id],
    previousStatuses: [vacancy.status],
    expiresAt: now() + config.UNDO_WINDOW_SECONDS.seconds
  )
}

rule VacancyRestore {
  -- "User restores a previously dismissed vacancy."
  when: RestoreVacancy(vacancyId: String, by: User)
  let vacancy = StagedVacancy where id = vacancyId

  requires: vacancy.userId = by.id
  requires: vacancy.status = dismissed
    -- Can only restore dismissed vacancies

  ensures: vacancy.status = staged
  -- Restored vacancies return to the beginning of the pipeline.
}

-- =============================================================================
-- Rules: Undo
-- =============================================================================

rule UndoAction {
  -- "User undoes a recent destructive action within the undo window."
  when: Undo(token: UndoToken, by: User)

  requires: token.expiresAt > now()
    -- Undo window has not expired
  requires: by owns all StagedVacancy in token.itemIds

  ensures: for_each (itemId, previousStatus) in zip(token.itemIds, token.previousStatuses):
    let vacancy = StagedVacancy where id = itemId
    vacancy.status = previousStatus

  ensures: token is invalidated
    -- Each UndoToken can only be used once

  @guidance
    -- Implementation: optimistic UI updates immediately on the client.
    -- If undo is triggered, server reverts the status.
    -- If undo window expires without undo, the action is permanent.
    -- For bulk actions, one UndoToken covers the entire batch.
}

rule UndoExpiry {
  -- "An UndoToken becomes invalid after its TTL (default 10 seconds, configurable)."
  -- After expiry, the undo window closes and the action becomes permanent.
  -- The token is removed from the in-memory UndoStore.
  when: now() >= token.expiresAt
  let token = UndoToken where expiresAt <= now()

  ensures: token is removed from UndoStore
  ensures: token.compensationFn can no longer be invoked
  ensures: the original action is permanent (no rollback possible)

  @guidance
    -- The default TTL is config.UNDO_WINDOW_SECONDS (10 seconds).
    -- This is configurable per user in UserSettings (future: per-action TTL).
    -- Implementation: setTimeout or periodic sweep of expired tokens.
    -- The UndoStore is in-memory — tokens are lost on server restart.
    -- This is acceptable for a 10-second window.
}

rule UndoExecution {
  -- "The compensation function is idempotent and restores previous state."
  -- Calling undo twice on the same token has no additional effect.
  -- The compensation function restores each item to its pre-action status.
  when: Undo(token: UndoToken, by: User)

  requires: token.expiresAt > now()
  requires: by owns all StagedVacancy in token.itemIds

  ensures: token.compensationFn.compensate(token.itemIds, token.previousStatuses)
    -- Each item's status is reverted to its previousStatus.
    -- For archive: archivedAt is set back to null.
    -- For trash: trashedAt is set back to null.
    -- For dismiss: status reverts from dismissed to the previous status.

  ensures: token is invalidated after first successful invocation
    -- Prevents double-undo. The token is removed from UndoStore.

  ensures: if token was already invalidated: no-op (idempotent)

  @guidance
    -- Idempotency is critical because the user might double-click the Undo button,
    -- or Ctrl+Z might fire while the first undo is still processing.
    -- Implementation: check token existence in UndoStore before executing.
    -- If already removed (expired or previously undone), return silently.
}

rule CtrlZBinding {
  -- "Ctrl+Z keyboard shortcut pops the most recent unexpired token from the undo stack."
  -- The undo system maintains a stack (LIFO) of active UndoTokens.
  -- Ctrl+Z pops and executes the most recent one.
  when: User presses Ctrl+Z (or Cmd+Z on macOS)

  requires: UndoStore has at least one unexpired token for the current user
  requires: keyboard focus is NOT in a text input, textarea, or contenteditable element
    -- Prevents conflict with browser/editor undo in form fields.

  let token = UndoStore.popMostRecent(userId: currentUser.id)
  requires: token != null and token.expiresAt > now()

  ensures: UndoExecution(token, currentUser)

  @guidance
    -- Implementation: useUndoStack() React hook registers a global keydown listener.
    -- The hook checks document.activeElement to avoid capturing undo in form inputs.
    -- After popping, the toast for that token is dismissed.
    -- If the stack is empty or all tokens are expired, Ctrl+Z is a no-op
    -- (does not preventDefault — allows browser undo to work in inputs).
}

-- =============================================================================
-- Rules: Bulk Actions
-- =============================================================================

rule BulkAction {
  -- "User performs the same action on multiple vacancies at once."
  when: ExecuteBulkAction(actionType: BulkActionType, vacancyIds: String[], by: User)

  requires: vacancyIds | count > 0
  requires: vacancyIds | count <= config.MAX_BULK_SIZE

  -- Partial-success semantics: each item is validated individually.
  -- Invalid items are skipped, not the whole batch.
  ensures: for_each vacancyId in vacancyIds:
    try:
      if actionType = promote: PromoteVacancy(vacancyId, by)
      if actionType = dismiss: DismissVacancy(vacancyId, by)
      if actionType = archive: ArchiveVacancy(vacancyId, by)
      if actionType = restore: RestoreVacancy(vacancyId, by)
      if actionType = delete:  TrashVacancy(vacancyId, by)
    catch: record BulkItemError(itemId: vacancyId, reason: error.message)

  ensures: BulkActionResult.returned(
    totalRequested: vacancyIds | count,
    succeeded: count of successful items,
    failed: count of failed items,
    errors: collected BulkItemError[]
  )

  -- One UndoToken per batch (not per item)
  ensures: UndoToken.created(
    actionType: actionType,
    itemIds: successfully processed vacancyIds,
    previousStatuses: statuses before the action,
    expiresAt: now() + config.UNDO_WINDOW_SECONDS.seconds
  )

  -- One domain event per batch (not N individual events)
  ensures: BulkActionCompleted.emitted(
    actionType: actionType,
    itemIds: successfully processed vacancyIds,
    userId: by.id,
    result: BulkActionResult
  )
}

rule BulkPartialSuccess {
  -- "Each item is validated individually; invalid items are skipped; the batch continues."
  -- A bulk action does NOT use a single database transaction for all items.
  -- Each item is processed independently. Failure of item N does not rollback items 1..N-1.
  when: ExecuteBulkAction(actionType, vacancyIds, by)

  ensures: for_each vacancyId in vacancyIds:
    -- Item-level validation (ownership, status preconditions) happens per item.
    -- If validation fails for one item, it is recorded as a BulkItemError
    -- and processing continues with the next item.
    vacancyId is processed independently of other items in the batch

  ensures: BulkActionResult.failed >= 0
    -- Zero failures is the happy path. Partial failure is not an error state.

  ensures: BulkActionResult.succeeded + BulkActionResult.failed = BulkActionResult.totalRequested

  @guidance
    -- Why not a single transaction? A 100-item bulk dismiss where 1 item is
    -- already promoted should not fail the other 99. Partial success is the
    -- expected behavior for bulk operations.
    -- The UI shows a summary: "95 dismissed, 5 skipped (already promoted)".
    -- Each BulkItemError includes the reason so the user can investigate.
}

rule BatchUndoGranularity {
  -- "One UndoToken per batch. Ctrl+Z reverses the entire batch."
  -- When a bulk action succeeds (partially or fully), a single UndoToken
  -- is created covering ALL successfully processed items.
  -- Undoing the batch reverts ALL items in the batch, not individual ones.
  when: ExecuteBulkAction completes with succeeded > 0

  ensures: exactly one UndoToken is created per batch
  ensures: UndoToken.batchId is set to a unique batch identifier
  ensures: UndoToken.itemIds contains only the successfully processed IDs
    -- Failed items are not included (nothing to undo for them)

  ensures: Undo(token) reverts ALL items in the batch atomically
    -- Either all items are restored or none (undo itself is transactional)

  @guidance
    -- This means a user who bulk-dismisses 50 items and presses Ctrl+Z
    -- gets all 50 items restored, not just one.
    -- Individual item undo is not supported for bulk actions.
    -- The toast shows: "50 vacancies dismissed. Undo" — one undo for the batch.
}

rule BulkActionEvent {
  -- "One BulkActionCompleted event per batch with the full item ID list."
  -- The event bus receives a single event summarizing the entire batch,
  -- not N individual VacancyDismissed/VacancyArchived events.
  when: ExecuteBulkAction completes

  ensures: exactly one BulkActionCompleted event is published per batch
  ensures: event.itemIds contains all successfully processed item IDs
  ensures: no individual per-item events (VacancyDismissed, etc.) are emitted for bulk items
    -- This prevents N notifications for a single bulk action.
    -- The NotificationDispatcher handles BulkActionCompleted as a single summary.

  @guidance
    -- Consumers that need per-item granularity can iterate event.itemIds.
    -- The actionType field tells consumers what happened (dismiss, archive, etc.).
    -- This is a deliberate trade-off: simpler event stream at the cost of
    -- consumers needing to understand BulkActionCompleted semantics.
}

-- =============================================================================
-- Rules: Archive & Trash
-- =============================================================================

rule ArchiveVacancy {
  -- "User archives a vacancy for later reference."
  when: Archive(vacancyId: String, by: User)
  let vacancy = StagedVacancy where id = vacancyId

  requires: vacancy.userId = by.id
  requires: vacancy.status != promoted
    -- Promoted vacancies live in the Job aggregate, not in staging archive

  ensures: vacancy.archivedAt = now()
  ensures: VacancyArchived.emitted(stagedVacancyId: vacancy.id, userId: by.id)
}

rule TrashVacancy {
  -- "User moves a vacancy to trash."
  when: Trash(vacancyId: String, by: User)
  let vacancy = StagedVacancy where id = vacancyId

  requires: vacancy.userId = by.id
  requires: vacancy.status != promoted

  ensures: vacancy.trashedAt = now()
  ensures: VacancyTrashed.emitted(stagedVacancyId: vacancy.id, userId: by.id)
  ensures: UndoToken.created(
    actionType: delete,
    itemIds: [vacancy.id],
    previousStatuses: [vacancy.status],
    expiresAt: now() + config.UNDO_WINDOW_SECONDS.seconds
  )
}

rule RestoreFromTrash {
  -- "User restores a vacancy from trash."
  when: RestoreFromTrash(vacancyId: String, by: User)
  let vacancy = StagedVacancy where id = vacancyId

  requires: vacancy.userId = by.id
  requires: vacancy.trashedAt != null

  ensures: vacancy.trashedAt = null
}

-- =============================================================================
-- Rules: DSGVO Retention & Dedup
-- =============================================================================

rule RetentionConfig {
  -- "Retention period is configurable per user (default 90 days)."
  -- Users can adjust how long trashed and dismissed vacancies are kept
  -- before automatic purge. The default is config.RETENTION_DAYS (90 days).
  when: UserUpdatesRetentionSettings(userId: String, retentionDays: Integer)

  requires: retentionDays >= 7
    -- Minimum 7 days to prevent accidental immediate purge.
  requires: retentionDays <= 365
    -- Maximum 1 year. Beyond that, consider archiving.

  ensures: UserSettings where userId = userId:
    retentionDays = retentionDays

  @guidance
    -- Stored in UserSettings JSON blob alongside notification preferences.
    -- If user has no custom setting, config.RETENTION_DAYS (90) applies.
    -- The retention service reads the user's custom setting when running cleanup.
    -- Dismissed vacancy retention (DISMISSED_RETENTION_DAYS) is always shorter
    -- than trash retention: min(30, retentionDays / 3).
}

rule RetentionCleanup {
  -- "After retention period: delete StagedVacancy data, preserve hash in DedupHash."
  -- This is the main retention rule combining purge + hash preservation.
  -- Runs as a scheduled background job (piggybacking on automation scheduler).
  -- DSGVO Art. 25 (Privacy by Design) + Art. 5(1)(c) (Datenminimierung)
  when: RetentionCheckDue
  let expired = StagedVacancy
    where trashedAt != null
    and trashedAt + config.RETENTION_DAYS.days <= now()

  ensures: for_each vacancy in expired:
    -- Step 1: Retain dedup hash before deletion
    if vacancy.externalId != null:
      DedupHash.created(
        userId: vacancy.userId,
        hash: hash(config.DEDUP_HASH_ALGORITHM, vacancy.sourceBoard + ":" + vacancy.externalId),
        sourceBoard: vacancy.sourceBoard
      )
    -- Step 2: Delete the vacancy data (all PII removed)
    vacancy.deleted()

  -- Step 3: Emit domain event summarizing the cleanup
  ensures: RetentionCompleted.emitted(
    userId: aggregated per user,
    purgedCount: count of deleted vacancies,
    hashesCreated: count of new DedupHash records
  )

  @guidance
    -- The hash is one-way (SHA-256, not reconstructable) — no personal data retained.
    -- Process in batches of 100 to avoid long-running DB transactions on large datasets.
    -- Yield between batches (setTimeout/setImmediate) to avoid blocking the event loop.
    -- This runs as a scheduled job (piggyback on existing automation scheduler
    -- or as a standalone cron route triggered by external cron).
}

rule DismissedRetentionPurge {
  -- "Dismissed vacancies are purged after a shorter retention period."
  when: RetentionCheckDue
  let expired = StagedVacancy
    where status = dismissed
    and updatedAt + config.DISMISSED_RETENTION_DAYS.days <= now()

  ensures: for_each vacancy in expired:
    if vacancy.externalId != null:
      DedupHash.created(
        userId: vacancy.userId,
        hash: hash(config.DEDUP_HASH_ALGORITHM, vacancy.sourceBoard + ":" + vacancy.externalId),
        sourceBoard: vacancy.sourceBoard
      )
    vacancy.deleted()
}

rule DedupCheck {
  -- "Before staging a vacancy, check if it was already seen (even after purge)."
  -- This is a precondition of AutomatedVacancyIntake, extracted for clarity.
  when: CheckDedup(userId: String, sourceBoard: String, externalId: String)

  let hashValue = hash(config.DEDUP_HASH_ALGORITHM, sourceBoard + ":" + externalId)

  -- Also check promoted Jobs by URL to prevent re-staging already-promoted vacancies.
  -- This is a cross-aggregate dedup that the spec's StagedVacancy-only check misses.

  ensures:
    if exists DedupHash where userId = userId and hash = hashValue:
      result = duplicate
    else if exists StagedVacancy where userId = userId and sourceBoard = sourceBoard
      and externalId = externalId and status != dismissed:
      result = duplicate
    else:
      result = new

  @guidance
    -- Dual-key dedup: checks both externalId (primary) and normalized sourceUrl (fallback).
    -- A vacancy with a different externalId but the same URL is treated as a duplicate.
}

rule DedupHashCheck {
  -- "Runner checks DedupHash before inserting a new StagedVacancy."
  -- After retention purge deletes old StagedVacancy records, the DedupHash table
  -- retains the one-way hash. The runner must check this table to avoid
  -- re-staging vacancies that were already processed and purged.
  when: AutomatedVacancyIntake attempts to stage vacancy with (userId, sourceBoard, externalId)

  let hashValue = hash(config.DEDUP_HASH_ALGORITHM, sourceBoard + ":" + externalId)

  if exists DedupHash where userId = userId and hash = hashValue:
    ensures: vacancy is NOT staged (silently skipped)
    ensures: runner increments jobsDeduplicated counter

  @guidance
    -- This check runs BEFORE the StagedVacancy existence check.
    -- DedupHash lookup is an indexed query (hash + userId composite index).
    -- The sourceBoard field on DedupHash enables partitioned queries
    -- (only check hashes from the same source board for performance).
    -- If externalId is null, the runner falls back to hashing sourceUrl.
    -- DedupHash records have no expiry — they persist indefinitely
    -- because they contain no PII (one-way hash only).
}

-- =============================================================================
-- Domain Events
-- =============================================================================

-- Events are published for downstream consumers (0.6 Event Bus).
-- In Phase 1, they are stubs (console.debug). 0.6 replaces with real bus.

event VacancyStaged {
  stagedVacancyId: String
  userId: String
  sourceBoard: String
  automationId: String?
}

event VacancyPromoted {
  stagedVacancyId: String
  jobId: String
  userId: String
  -- Downstream consumers:
  --   CompanyNeeded → Data Enrichment (1.13)
  --   DocumentsAvailable → Document Generators (4.2)
  --   CrmChanceCreated → CRM (5)
}

event VacancyDismissed {
  stagedVacancyId: String
  userId: String
}

event VacancyArchived {
  stagedVacancyId: String
  userId: String
}

event VacancyTrashed {
  stagedVacancyId: String
  userId: String
}

event BulkActionCompleted {
  actionType: BulkActionType
  itemIds: String[]
  userId: String
  succeeded: Integer
  failed: Integer
}

event RetentionCompleted {
  userId: String
  purgedCount: Integer
  hashesCreated: Integer
}

-- =============================================================================
-- Invariants
-- =============================================================================

invariant UniqueDedup {
  ensures: no two StagedVacancy have the same (userId, sourceBoard, externalId)
    where externalId != null and status != dismissed
  note: "Composite unique constraint. Dismissed vacancies are excluded — rediscovery creates new entries."
  note: "Enforced by database unique index with partial filter."
}

invariant PromotedVacancyImmutable {
  ensures: for_each vacancy in StagedVacancy where status = promoted:
    vacancy.status cannot change
    vacancy.promotedToJobId cannot change
  note: "Once promoted, a StagedVacancy is frozen. The Job aggregate owns the lifecycle from here."
}

invariant NoDuplicatePromotion {
  ensures: for_each vacancy in StagedVacancy:
    vacancy.promotedToJobId is unique or null
  note: "Each StagedVacancy maps to at most one Job. One-to-one relationship."
}

invariant ManualJobsBypassStaging {
  ensures: User can create Job directly without StagedVacancy
  note: "The addJob() flow is independent. Manual jobs are already reviewed by the user."
  note: "This invariant documents the design boundary between Discovery and Tracking."
}

invariant TrashRetentionCompliance {
  ensures: no StagedVacancy exists where trashedAt + config.RETENTION_DAYS.days < now()
  note: "DSGVO Art. 5(1)(e): storage limitation. Enforced by RetentionPurge rule."
  note: "DedupHash records are not personal data (one-way hash) and are retained indefinitely."
}

-- =============================================================================
-- Surfaces
-- =============================================================================

surface StagingQueue {
  facing actor: User
  context entity: StagedVacancy[]

  exposes:
    -- Tabs:
    tab "Neu": StagedVacancy where status in (staged, processing, ready) and archivedAt = null and trashedAt = null
    tab "Abgelehnt": StagedVacancy where status = dismissed and trashedAt = null
    tab "Archiv": StagedVacancy where archivedAt != null
    tab "Papierkorb": StagedVacancy where trashedAt != null

    -- Per vacancy: title, employerName, location, matchScore, sourceBoard, discoveredAt, status

    -- Filters: status, sourceBoard, date range, matchScore range
    -- Sort: discoveredAt desc (default), matchScore desc, title asc

  provides:
    DismissVacancy(vacancyId),
    RestoreVacancy(vacancyId),
    ArchiveVacancy(vacancyId),
    TrashVacancy(vacancyId),
    RestoreFromTrash(vacancyId),
    PromoteVacancy(vacancyId) -> opens PromotionDialog,
    ExecuteBulkAction(actionType, vacancyIds),
    Undo(token)

  @guarantee MultiSelect
    -- User can select multiple vacancies via checkboxes for bulk actions.
    -- A floating BulkActionBar appears when 1+ items are selected.

  @guarantee UndoFeedback
    -- After every destructive action, a toast with "Undo" button appears.
    -- Countdown shows remaining seconds. Click reverts the action.
}

surface PromotionDialog {
  facing actor: User
  context entity: StagedVacancy (single)

  exposes:
    -- Pre-filled from StagedVacancy:
    title, employerName, location, description, matchScore, sourceUrl

    -- Editable overrides:
    jobTitleOverride (text input, pre-filled from title),
    companyOverride (text input, pre-filled from employerName),
    locationOverride (text input, pre-filled from location),
    tagsToApply (tag multi-select)

  provides:
    ConfirmPromotion(input: PromotionInput),
    Cancel()

  @guarantee PreviewBeforeCommit
    -- User sees what will be created before confirming.
    -- No Job is created until the user clicks "Promote".
}

surface BulkActionBar {
  -- Floating action bar that appears when one or more vacancies are selected.
  facing actor: User
  context entity: StagedVacancy[] (selected subset)

  exposes:
    -- Selection state:
    selectedCount: Integer,           -- number of currently selected items
    selectedIds: String[],            -- IDs of selected StagedVacancy records
    allSelected: Boolean              -- whether "select all" is active (current page or all pages)

  provides:
    -- Bulk operations (available buttons depend on current tab):
    BulkDismiss(vacancyIds)           -- dismiss all selected (Neu tab)
    BulkPromote(vacancyIds)           -- promote all selected (opens batch PromotionDialog)
    BulkArchive(vacancyIds)           -- archive all selected
    BulkTrash(vacancyIds)             -- move all selected to trash
    BulkRestore(vacancyIds)           -- restore selected (Abgelehnt/Papierkorb tabs)
    SelectAll()                       -- select all items on current page
    DeselectAll()                     -- clear selection

  @guarantee ContextualButtons
    -- Only show operations valid for the current tab:
    -- Neu tab: Dismiss, Promote, Archive, Trash
    -- Abgelehnt tab: Restore, Trash
    -- Archiv tab: Restore (from archive), Trash
    -- Papierkorb tab: Restore (from trash), Permanent Delete (future)
    -- Buttons for invalid operations are hidden, not disabled.

  @guarantee FloatingPosition
    -- The bar floats at the bottom of the viewport (sticky bottom).
    -- Appears with a slide-up animation when first item is selected.
    -- Disappears when selection is cleared.
    -- Does not overlap with the UndoToast.

  @guarantee SelectionPersistence
    -- Selection persists across tab pagination (scrolling/page changes).
    -- Selection is cleared when switching tabs (different data set).
    -- Checkbox state is synced with selectedIds.

  @guarantee AccessibleSelection
    -- Each vacancy card has a checkbox with aria-label: "Select {title}"
    -- BulkActionBar has role="toolbar" with aria-label: "{count} items selected"
    -- All buttons have descriptive aria-labels
}

surface UndoToast {
  -- Toast notification with countdown timer and Undo button.
  -- Appears after every destructive action (dismiss, trash, archive, bulk action).
  facing actor: User
  context entity: UndoToken

  exposes:
    -- Toast content:
    message: String,                  -- e.g. "3 vacancies dismissed" or "Moved to trash"
    countdown: Integer,               -- remaining seconds (ticks down in real time)
    progress: Float,                  -- 0.0 to 1.0 for visual countdown bar

  provides:
    Undo()                            -- triggers UndoExecution for the associated token
    Dismiss()                         -- manually close the toast (token remains valid until expiry)

  @guarantee CountdownVisual
    -- A visual countdown (progress bar or circular timer) shows remaining time.
    -- Countdown ticks every second. When it reaches 0, the toast auto-dismisses.
    -- The countdown is synchronized with the UndoToken.expiresAt.

  @guarantee StackBehavior
    -- Multiple toasts can be visible simultaneously (stacked vertically).
    -- Newest toast appears at the bottom of the stack.
    -- Each toast has its own independent countdown.
    -- Ctrl+Z undoes the most recent (bottommost) toast.

  @guarantee AnimatedTransitions
    -- Toast enters with a slide-up animation.
    -- Toast exits with a fade-out animation when:
    --   a) countdown expires (auto-dismiss)
    --   b) user clicks Undo (action reverted)
    --   c) user clicks Dismiss (manual close)

  @guarantee AccessibleToast
    -- role="alert" for screen readers
    -- aria-live="polite" (does not interrupt current reading)
    -- Undo button is keyboard-focusable
    -- Toast does not block interaction with the page below
}

-- =============================================================================
-- Open Questions
-- =============================================================================

-- Resolved: "Undo implementation: Command Pattern or timer-based soft-revert?"
-- Answer: Timer-based soft-revert with compensation functions (AD-2 from design spec).
-- UndoToken with configurable TTL (default 10s). See UndoExpiry, UndoExecution rules.

open question "Should dismissed vacancies that are rediscovered create a notification? ('A vacancy you dismissed was found again on a different board.')"

open question "Super-Like in JobDeck Queue mode (→ 2.7): should it trigger immediate promotion without the PromotionDialog, or always show the dialog?"

open question "Should StagedVacancy support tags for pre-promotion categorization, or only apply tags during promotion?"
