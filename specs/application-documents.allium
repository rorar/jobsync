-- allium: 3
-- application-documents.allium

-- Scope: Application document generators + the application bundle (ROADMAP 4.2
--   Dokumenten-Generatoren). An ApplicationBundle groups, per Job, the CV plus
--   LLM-GENERATED documents (cover letter / Anschreiben, motivation, Exposé,
--   title page) and uploaded attachments (certificates). Covers generation
--   (from CvDocument + Job, format-localized, salutation-aware), the document
--   lifecycle (draft -> generated -> edited -> final), template management,
--   and export to file artifacts.
-- Includes: ApplicationBundle, GeneratedDocument, DocumentTemplate, Attachment,
--   ApplicationFile; generation triggers (mode-gated: manual + reactive
--   VacancyPromoted per AutomationMode/9.4), edit/finalize, format localization
--   (DIN 5008 etc.), gender-aware salutation, export naming.
-- Excludes:
--   - The CV itself (see cv-document.allium — a GeneratedDocument is generated
--     FROM a CvDocument; the CV is the bundle's source, not a generated doc)
--   - PDF/DOCX rendering engine (pdfme — implementation, ROADMAP 4.2.1)
--   - AI provider internals + redaction algorithm (see ai-provider.allium)
--   - Shared-link / public exposure mechanics (see shared-surface, 2.18.2;
--     reused for sharing a bundle, defined there)
--   - E-mail application sending (see ROADMAP 4.9 — a consumer of final docs)
--   - File storage paths (implementation; see src/lib/storage.ts)
-- Dependencies: User, Job (shared); CvDocument (cv-document.allium); AiProvider
--   (ai-provider.allium); Person (CRM, crm.allium — salutation gender);
--   DocType + CvArtifactNaming convention (cv-document.allium / ROADMAP 4.3).
--   (G3 resolved: application files use the own ApplicationFile entity below,
--    NOT the Gsync `File` model — keeps upstream schema untouched.)
-- Owner: ApplicationDocuments Aggregate (src/actions/applicationDocument.actions.ts — to build)

-- Graph review (JobSync /understand-anything, 2026-06-14) — gaps this spec assumes:
--   G1 RESOLVED — no new `DocumentsAvailable` auto-trigger; mode-gated on the
--      existing VacancyPromoted (AutomationMode/9.4). See PrepareDocumentsOnPromotion.
--   G2 AI has resume/match + resume/review routes only — NO generation route.
--      Generation is a new AI flow (GenerateDocument rule) — implementation gap.
--   G3 RESOLVED — own ApplicationFile entity (not the Gsync 1:1-Resume File model).
--   G4 No ApplicationBundle concept exists — fully new (this spec).
--   G5 CvDocument is spec-only (unbuilt) — generators depend on it (ordering).

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity User {
    -- Authenticated user. Owns every bundle and generated document (ADR-015).
}

external entity Job {
    -- The job application a bundle targets. One bundle per (user, job).
}

external entity CvDocument {
    -- cv-document.allium. The CV that is the bundle's source and the input for
    -- LLM document generation. Carries the application's identity + language.
    user: User
    language: String
}

external entity AiProvider {
    -- ai-provider.allium. Generates document drafts from CV + Job text. Cloud
    -- providers are third-party recipients; PII redacted before transfer.
    is_local: Boolean              -- true = Ollama (full fidelity, no redaction)
}

external entity Person {
    -- crm.allium contact (recruiter / hiring manager). Supplies the addressee
    -- + gender for a localized salutation, when known.
    gender: String?                -- nullable; absent -> neutral salutation
    full_name: FullName?
}

external entity SharedLink {
    -- shared-surface (2.18.2). A whole bundle (or a single final document) can
    -- be shared via a revocable link. Mechanics defined there.
    target_type: String
    target_id: String
    revoked: Boolean
}

external entity FullName {
    -- Value from crm.allium (last_name used for the salutation).
    last_name: String
}

------------------------------------------------------------
-- Enums
------------------------------------------------------------

enum GeneratedDocType {
    -- The LLM-generated document kinds. The CV is NOT here (cv-document.allium).
    -- Maps to the shared filename DocType tokens (cover_letter->CoverLetter, ...).
    cover_letter
    motivation
    expose
    title_page
}

enum DocumentStatus {
    draft           -- created, not yet generated (placeholder / manual start)
    generating      -- LLM generation in progress
    generated       -- LLM produced a draft; awaiting user review
    edited          -- user modified the generated content
    final           -- approved; ready to render/send (immutable content)
}

enum BundleStatus {
    assembling      -- being put together (docs generated/edited)
    ready           -- all required documents are final
    submitted       -- sent / handed over for the application
    archived        -- closed application, retained
}

enum SalutationForm {
    -- Resolved address form for a localized letter.
    formal_named    -- e.g. "Sehr geehrte Frau Müller" — gender + name known
    neutral_named   -- e.g. "Guten Tag, Frau Müller" / "Dear Alex Müller"
    neutral_generic -- e.g. "Sehr geehrte Damen und Herren" / "Dear Sir or Madam"
}

enum ApplicationFileKind {
    -- An ApplicationFile is either a rendered output or a user upload (G3).
    rendered        -- PDF/DOCX produced by ExportDocument
    uploaded        -- a certificate / supporting document the user uploaded
}

enum AutomationMode {
    -- Automation level (ROADMAP 9.4), set per automation or globally. Gates
    -- whether document preparation is user-initiated or auto-triggered (G1).
    manual          -- LLM prepares nothing; user opens bundle + generates
    semi_yolo       -- LLM auto-generates drafts on promotion; PAUSES for review
    yolo            -- full autopilot: auto-generate + auto-send within safeguards
}

------------------------------------------------------------
-- Value Objects
------------------------------------------------------------

value FormatLocale {
    -- The localized letter-format rules applied when rendering a document.
    language: String               -- ISO 639-1 (content language)
    letter_standard: String        -- e.g. "DIN-5008" (DE), country convention
    include_photo: Boolean         -- cultural convention (DE/FR yes, UK no)
}

value GeneratedContent {
    -- The produced document content. Stored opaquely (rich text / JSON), but
    -- the addressee + salutation are domain-meaningful.
    body: String                   -- rich-text / structured body (opaque)
    salutation: SalutationForm
    addressee: Person?             -- the CRM contact addressed, if any
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity ApplicationBundle {
    user: User
    job: Job
    cv: CvDocument?                -- the source CV; null if it was later deleted
    status: BundleStatus
    preparation_mode: AutomationMode  -- the mode that opened it (9.4 audit / review queue)

    -- Relationships
    documents: GeneratedDocument with bundle = this
    attachments: Attachment with bundle = this

    created_at: Timestamp
    updated_at: Timestamp

    @invariant TenantIsolation
        -- A bundle and all its documents/attachments are scoped to user
        -- (ADR-015). Never queried by id alone.

    @invariant OneBundlePerUserPerJob
        -- At most one ApplicationBundle per (user, job). Re-applying reopens
        -- the existing bundle rather than forking a second.

    @invariant BundleCvOwnedBySameUser
        -- When cv is set, bundle.cv.user = bundle.user — a bundle's CV belongs
        -- to its owner. cv may be null after the source CV is deleted (see
        -- GeneratedDocumentsSurviveCvDeletion).
}

entity GeneratedDocument {
    bundle: ApplicationBundle
    doc_type: GeneratedDocType
    language: String               -- ISO 639-1; MAY differ from the CV's language
    format_locale: FormatLocale
    status: DocumentStatus
    content: GeneratedContent
    generated_by: AiProvider?      -- which AI module produced the draft (audit)
    template: DocumentTemplate?    -- optional template the render uses
    rendered_file: ApplicationFile?  -- set once exported to PDF/DOCX

    created_at: Timestamp
    updated_at: Timestamp

    @invariant GeneratedFromCvAndJob
        -- A generated document's source is its bundle's cv + job. The LLM input
        -- is CvDocument.data + Job text (+ addressee). It is never authored from
        -- nothing — generation always has the CV + Job as context.

    @invariant FinalContentImmutable
        -- content may change only while status in {draft, generated, edited}.
        -- A `final` document is frozen; re-opening requires an explicit edit
        -- transition back to `edited`.

    @invariant PerDocumentLanguage
        -- Each document carries its own language (e.g. "EN CV + DE Anschreiben").
        -- The filename + format_locale follow this content language, not the
        -- UI language (ROADMAP 4.3 / cv-document CvArtifactNaming).
}

entity DocumentTemplate {
    user: User
    doc_type: GeneratedDocType
    name: String
    country: String?               -- template specialised per country/standard
    template_data: String          -- pdfme Template JSON (4.2.1)
    created_at: Timestamp
    updated_at: Timestamp

    @invariant TemplateOwnedByUser
        -- User templates are tenant-scoped. System templates (seeded) are the
        -- starting point; users create/edit/version their own (4.2 pagebuilder).
}

entity Attachment {
    bundle: ApplicationBundle
    file: ApplicationFile          -- uploaded certificate / supporting document
    label: String
    created_at: Timestamp

    @invariant AttachmentFileOwnership
        -- The attached file belongs to the bundle's user (ADR-015 chain).
}

entity ApplicationFile {
    -- G3 resolution: a file owned by THIS aggregate (rendered output or upload),
    -- distinct from the Gsync `File` model (which stays 1:1 with Resume). Keeps
    -- the upstream schema untouched; gives generated docs + attachments proper
    -- per-bundle ownership.
    bundle: ApplicationBundle
    kind: ApplicationFileKind
    file_name: String
    file_path: String              -- server filesystem path (src/lib/storage.ts)
    file_type: String              -- MIME / extension
    created_at: Timestamp

    @invariant FileOwnedViaBundle
        -- Ownership chain ApplicationFile -> ApplicationBundle -> User (ADR-015).

    @invariant FilePathNeverInResponses
        -- file_path is a server path and is NEVER returned in API responses
        -- (same rule as the Gsync File model). Serve via an authenticated route.
}

entity OutreachMessage {
    -- The channel-AGNOSTIC submission message (the cover note) the user sends
    -- with the application. CONTENT lives here (bundle artifact, reviewed in
    -- Semi-YOLO alongside the docs). The CHANNEL, recipient resolution and
    -- actual delivery are the Communication Connector's concern (ROADMAP 1.12),
    -- NOT here. The attachments ARE the bundle's GeneratedDocuments + Attachments
    -- (not duplicated). One per bundle.
    bundle: ApplicationBundle
    body: String                   -- LLM-generated cover note; same content per channel
    status: DocumentStatus         -- reuse draft/generated/edited/final (review lifecycle)
    generated_by: AiProvider?
    created_at: Timestamp
    updated_at: Timestamp

    @invariant OneOutreachMessagePerBundle
        -- At most one OutreachMessage per bundle. It is reviewed and finalized
        -- together with the generated documents (Semi-YOLO review covers docs +
        -- CV + this message); body is immutable once final (mirrors
        -- FinalContentImmutable for GeneratedDocument).
}

------------------------------------------------------------
-- Rules — bundle assembly
------------------------------------------------------------

rule OpenApplicationBundle {
    when: OpenApplicationBundle(user, job, cv)

    requires: exists job where job.user = user
    requires: exists cv where cv.user = user
    requires: not exists ApplicationBundle{user: user, job: job}

    ensures:
        ApplicationBundle.created(
            user: user,
            job: job,
            cv: cv,
            status: assembling,
            preparation_mode: manual,
            created_at: now,
            updated_at: now
        )

    @guidance
        -- Manual mode (G1): the bundle is opened on demand when the user starts
        -- preparing an application. In Semi-YOLO/YOLO it is opened reactively on
        -- promotion (see PrepareDocumentsOnPromotion). Idempotent per (user, job)
        -- — OneBundlePerUserPerJob.
}

rule PrepareDocumentsOnPromotion {
    -- Subscribes to the VacancyPromoted domain event (vacancy-pipeline.allium),
    -- which carries IDs only. Entities + the effective mode are resolved here.
    when: VacancyPromoted(staged_vacancy_id, job_id, user_id)

    let mode = EffectiveAutomationMode.of(user_id, staged_vacancy_id)

    requires: not exists ApplicationBundle{user: User{id: user_id}, job: Job{id: job_id}}

    ensures:
        -- Semi-YOLO / YOLO (G1): a vacancy promoted by an automation auto-opens
        -- the bundle AND auto-generates its drafts. Manual mode does nothing here.
        if mode != manual:
            let cv = DefaultCv.for(user_id, job_id)
            let bundle = ApplicationBundle.created(
                user: User{id: user_id},
                job: Job{id: job_id},
                cv: cv,
                status: assembling,
                preparation_mode: mode,
                created_at: now,
                updated_at: now
            )
            -- Auto-generate the cover-letter draft via AI (the user's request).
            -- Fires GenerateDocument; the draft stops at status = generated.
            -- Semi-YOLO pauses for review; YOLO continues to finalize+send
            -- (OnlyYoloAutoFinalizesAndSends + automation-modes safeguards).
            GenerateDocument(
                User{id: user_id},
                bundle,
                cover_letter,
                JobLanguage.of(job_id),
                ActiveAiProvider.of(User{id: user_id})
            )
            -- Also draft the channel-agnostic outreach message (cover note) for
            -- review. Delivery channel/recipient are resolved later by the
            -- Communication Connector (1.12), not here.
            OutreachMessage.created(
                bundle: bundle,
                body: Llm.outreachMessage(bundle, JobLanguage.of(job_id)),
                status: generated,
                generated_by: ActiveAiProvider.of(User{id: user_id}),
                created_at: now,
                updated_at: now
            )

    @guidance
        -- G1 RESOLVED — the trigger is the existing VacancyPromoted signal; no
        -- new `DocumentsAvailable` event. The effective AutomationMode (9.4) is
        -- looked up (per-automation or global setting — EffectiveAutomationMode
        -- is a black box, not part of the event payload):
        --   manual    -> no auto-prep (a notification nudge may use JobStatusChanged)
        --   semi_yolo -> auto-open + auto-generate DRAFTS, then PAUSE for review
        --   yolo      -> auto-open + auto-generate + auto-finalize + auto-send,
        --                within 9.4 safeguards (daily limit, blacklist,
        --                match-score min, kill-switch).
        -- Generation itself = GenerateDocument; finalisation/sending is gated by
        -- OnlyYoloAutoFinalizesAndSends.
}

------------------------------------------------------------
-- Rules — generation (new AI flow; gap G2)
------------------------------------------------------------

rule GenerateDocument {
    when: GenerateDocument(user, bundle, doc_type, language, provider)

    requires: exists bundle where bundle.user = user
    requires: bundle.status = assembling
    requires: bundle.cv != null

    ensures:
        -- LLM generation from CV + Job. PII redacted unless the provider is
        -- local (fail-safe: redact when locality unknown). Cloud providers are
        -- third-party recipients (ai-provider.allium CloudTransferDataMinimization).
        let source =
            if provider.is_local:
                CvJob.context(bundle.cv.data, bundle.job)
            else:
                Pii.redact(CvJob.context(bundle.cv.data, bundle.job))

        -- Salutation is a black box: it resolves the addressee (the CRM contact
        -- for this job) and picks the gender-aware / neutral form. The spec
        -- pins the inputs + outcome (SalutationLocalizedAndGendered), not the
        -- algorithm.
        GeneratedDocument.created(
            bundle: bundle,
            doc_type: doc_type,
            language: language,
            format_locale: FormatLocale.for(language),
            status: generated,
            generated_by: provider,
            content: GeneratedContent(
                body: Llm.generate(doc_type, source, provider),
                salutation: Salutation.resolve(considering: { bundle.job, Person.gender, Person.full_name }),
                addressee: Salutation.addressee(bundle.job)
            ),
            created_at: now,
            updated_at: now
        )

    @guidance
        -- New AI flow (no generation route exists today — only resume match +
        -- review). The cover letter / Anschreiben is written by the LLM FROM the
        -- bundle's CV + Job. Salutation is gender-aware when a CRM contact is the
        -- addressee, neutral otherwise (SalutationLocalizedAndGendered).
}

rule EditGeneratedDocument {
    when: EditGeneratedDocument(user, document, new_content)

    requires: exists document where document.bundle.user = user
    requires: document.status in {generated, edited, final}
    requires: new_content != null

    ensures:
        document.updated(content: new_content, status: edited, updated_at: now)

    @guidance
        -- The user refines the generated draft (character limits for cover
        -- letters apply at the UI per ROADMAP 3.3). Editing a `final` document
        -- transitions it back to `edited`.
}

rule FinalizeDocument {
    when: FinalizeDocument(user, document)

    requires: exists document where document.bundle.user = user
    requires: document.status in {generated, edited}

    ensures:
        document.updated(status: final, updated_at: now)

    @guidance
        -- Approves the document; content becomes immutable (FinalContentImmutable)
        -- until an explicit edit re-opens it.
}

rule AddAttachment {
    when: AddAttachment(user, bundle, file_name, file_path, file_type, label)

    requires: exists bundle where bundle.user = user
    requires: file_name != null

    ensures:
        let uploaded = ApplicationFile.created(
            bundle: bundle,
            kind: uploaded,
            file_name: file_name,
            file_path: file_path,
            file_type: file_type,
            created_at: now
        )
        Attachment.created(bundle: bundle, file: uploaded, label: label, created_at: now)

    @guidance
        -- Certificates / references uploaded by the user join the bundle as an
        -- ApplicationFile (kind: uploaded) — not the Gsync File model (G3).
}

rule ReadyBundle {
    when: ReadyBundle(user, bundle)

    requires: exists bundle where bundle.user = user
    requires: not exists GeneratedDocument{bundle: bundle} where GeneratedDocument.status != final

    ensures:
        bundle.updated(status: ready, updated_at: now)

    @guidance
        -- A bundle is ready when every generated document in it is final.
        -- Attachments need no finalisation.
}

rule ShareBundle {
    when: ShareBundle(user, bundle, expires_at?, password?)

    requires: exists bundle where bundle.user = user
    requires: bundle.status in {ready, submitted}

    ensures:
        -- Sharing reuses the shared-surface domain (2.18.2) — revocable, audited.
        SharedLink.created(target_type: "application_bundle", target_id: bundle, revoked: false)

    @guidance
        -- A whole bundle (or a single final document) can be shared with a
        -- contact/company via a revocable shared-surface link
        -- (BundleSharingViaSharedSurface). Token mechanics live in shared-surface.
}

------------------------------------------------------------
-- Rules — export
------------------------------------------------------------

rule ExportDocument {
    when: ExportDocument(user, document, format)

    requires: exists document where document.bundle.user = user
    requires: document.status = final

    ensures:
        -- Rendered via the DocumentRenderingConnector (4.2.1, pdfme/Gotenberg)
        -- into an ApplicationFile named per the shared 4.3 convention.
        let artifact = ApplicationFile.created(
            bundle: document.bundle,
            kind: rendered,
            file_name: Render.filename(document, format),
            file_path: Render.path(document, format),
            file_type: format,
            created_at: now
        )
        document.updated(rendered_file: artifact, updated_at: now)

    @guidance
        -- The render engine + filename convention are shared with the CV
        -- (ROADMAP 4.2.1 + 4.3; cv-document CvArtifactNaming). The doc_type
        -- token is language-independent ASCII; LANG is the document's content
        -- language. format in {pdf, docx, html}.
}

------------------------------------------------------------
-- Top-level Invariants
------------------------------------------------------------

invariant CloudGenerationRedactsPii {
    -- Any CV/Job content sent to a non-local AiProvider for document generation
    -- passes through Pii.redact first. Full fidelity only for provider.is_local.
    -- Mirrors ai-provider.allium CloudTransferDataMinimization for the new
    -- generation flow.
}

invariant SalutationLocalizedAndGendered {
    -- A generated letter's salutation is gender-aware when a CRM addressee with
    -- known gender exists (formal_named), name-only when gender is unknown
    -- (neutral_named), and generic otherwise (neutral_generic). No letter
    -- guesses gender.
}

invariant OnlyYoloAutoFinalizesAndSends {
    -- G1 / ROADMAP 9.4: in manual and semi_yolo modes a generated document is
    -- never finalized or sent without explicit user approval (the Semi-YOLO
    -- review pause). Only yolo may auto-finalize + auto-send, and only within
    -- its safeguards (daily application limit, company blacklist, match-score
    -- minimum, kill-switch, dry-run). Semi-YOLO auto-GENERATES drafts but
    -- always stops before sending.
}

invariant GeneratedDocumentsSurviveCvDeletion {
    -- A GeneratedDocument captures its content (GeneratedContent.body) at
    -- generation time, so it is independent of the source CV thereafter.
    -- Hard-deleting the CvDocument (cv-document.allium DeleteCvDocument) nulls
    -- bundle.cv but NEVER destroys existing generated documents or attachments.
    -- (Re)generation requires a non-null cv (GenerateDocument). This keeps the
    -- aggregates decoupled — cv-document does not know about bundles.
}

invariant BundleSharingViaSharedSurface {
    -- Sharing a bundle (or a final document) with a contact/company reuses the
    -- shared-surface domain (2.18.2) — revocable, audited — not a bespoke link.
}

invariant DocumentFilenameFollowsConvention {
    -- Exported documents follow the single ROADMAP 4.3 naming convention
    -- (shared with the CV): {Last}_{First}_{DocType}_{LANG}[_{Company}][_v{N}],
    -- ASCII-safe, language-independent DocType token.
}

------------------------------------------------------------
-- Resolved Decisions (G1, G3 — 2026-06-14)
------------------------------------------------------------

-- G1 Trigger: RESOLVED — no new `DocumentsAvailable` auto-trigger. Preparation
--    is gated by AutomationMode (ROADMAP 9.4): manual = user-initiated
--    (OpenApplicationBundle); semi_yolo/yolo = reactive on the existing
--    VacancyPromoted signal (PrepareDocumentsOnPromotion). Finalisation/sending
--    is gated by OnlyYoloAutoFinalizesAndSends (semi-yolo pauses for review;
--    yolo auto-sends within 9.4 safeguards). A manual-mode notification nudge
--    may reuse JobStatusChanged (no new event needed).
-- G3 File model: RESOLVED — generated output + attachments use the own
--    ApplicationFile entity (per-bundle ownership, file_path never in responses),
--    NOT the Gsync `File` model (which stays 1:1 with Resume) — keeps the
--    upstream schema untouched (Strangler Fig).

------------------------------------------------------------
-- Open Questions (remaining)
------------------------------------------------------------

open question "OutreachMessage vs cover_letter overlap: in some flows the submission message body IS the cover letter (Anschreiben inline), in others it is a short cover note with the Anschreiben as a separate attached document. Is OutreachMessage.body always distinct from the cover_letter GeneratedDocument, or may it be derived from / replaced by it per channel (e.g. email body = Anschreiben text; portal upload = Anschreiben PDF + short note)?"

open question "Template management scope: is DocumentTemplate (create/edit/version/share via the 4.2 manifest pagebuilder) substantial enough to warrant its own spec, or does it stay here? It overlaps the CV template system (4.2.1 pdfme templates) — shared template aggregate?"

open question "Auto-prep CV resolution: VacancyPromoted carries no CV, so PrepareDocumentsOnPromotion resolves one via DefaultCv.for(user_id, job_id). Which CV is it — the user's default working CvDocument, or one language-matched to the job's detected language (4.2 auto-detection)? And if the user has no CV yet, does semi-yolo/yolo prep skip, or generate from Profile identity only?"

open question "EffectiveAutomationMode source: the mode is looked up (per-automation OR global default, 9.4). Does it live on the Automation entity, a global UserSetting, or both with automation overriding global? (Defines what EffectiveAutomationMode.of resolves.)"

open question "Required-document policy: ReadyBundle treats every generated document as required. Should a bundle declare which doc_types are required for a given Job/country (e.g. DE often expects CV + cover letter + Anlagen) vs optional?"

open question "Address formatting: ROADMAP 4.2 names @fragaria/address-formatter as the address single-source. Is the rendered address block part of GeneratedContent (domain) or purely a render-time concern (implementation)?"
