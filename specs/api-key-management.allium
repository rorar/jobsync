-- allium: 3
-- api-key-management.allium

-- Scope: API key management — both Module API keys (for external services)
--   and Public API keys (for the REST API v1)
-- Includes: Key creation, encryption, storage, retrieval, revocation,
--   Ollama URL validation, credential resolution
-- Excludes:
--   - Public API v1 endpoint logic (see public-api-v1.allium)
--   - Module lifecycle (see module-lifecycle.allium)
--   - Credential PUSH flow (see module-lifecycle.allium)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity User {
    -- Authenticated user. Governed by auth spec.
    public_api_keys: PublicApiKey with user = this
}

external entity ModuleRegistry {
    -- Unified registry of all modules. Used to derive sensitive flag from manifest.
    -- See module-lifecycle.allium.
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value EncryptionResult {
    encrypted: String       -- format: "salt:<hex>:<base64-payload>"
    iv: String              -- base64-encoded IV
}

------------------------------------------------------------
-- Contracts
------------------------------------------------------------

contract KeyManagementSecurity {
    encrypt: (plaintext: String) -> EncryptionResult
    decrypt: (encrypted_data: String) -> String

    @invariant EncryptionKeyRequired
        -- ENCRYPTION_KEY environment variable MUST be set.
        -- Missing key causes immediate error on encrypt/decrypt, not silent failure.

    @invariant SensitiveFlagFromManifest
        -- The sensitive flag for a ModuleApiKey is derived from the module manifest
        -- at save time, NEVER from client input. Unknown modules default to sensitive=true.

    @invariant LegacySaltReadOnly
        -- The hardcoded LEGACY_SALT is used ONLY for decrypting records that were
        -- encrypted before the per-record salt migration. No new encryption uses it.

    @invariant OllamaUrlValidation
        -- The Ollama base URL is validated both at storage (saveApiKey) and
        -- at retrieval (getOllamaBaseUrl). Invalid URLs fall back to the default.
        -- This prevents SSRF even if the database is compromised.

    @guidance
        -- PBKDF2 at 100_000 iterations is computationally expensive (~10ms per call).
        -- Implementations MAY cache derived keys in a bounded, process-scoped
        -- in-memory cache keyed by salt to avoid redundant derivation on the same record.
        -- The cache MUST be cleared on process restart (no persistent key cache).
        -- Cache size MUST be bounded to prevent unbounded memory growth.
        -- The encrypt/decrypt functions SHOULD be async to avoid blocking the event loop.
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum ApiKeyModuleId {
    -- Only modules that require user-provided credentials
    -- EURES and Arbeitsagentur use public APIs, no key needed
    rapidapi               -- shared by JSearch and other RapidAPI modules
    ollama                 -- special: stores a base URL, not a secret key
    openai
    deepseek
}

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity ModuleApiKey {
    -- API key for an external module (AI provider, job board, etc.)
    user: User
    module_id: ApiKeyModuleId
    encrypted_key: String   -- AES-256-GCM encrypted (or plaintext for non-sensitive)
    iv: String              -- empty string for non-sensitive keys
    last4: String           -- last 4 chars of the plaintext key
    label: String?
    last_used_at: Timestamp?

    is_sensitive: iv != ""

    @invariant UniquePerUserModule
        -- (userId, moduleId) is unique. One key per module per user.
        -- Sensitive flag derived from module manifest, NEVER from client input.
}

entity PublicApiKey {
    -- API key for the Public REST API v1.
    user: User
    name: String            -- max 100 chars
    key_hash: String        -- SHA-256 hash (one-way)
    key_prefix: String      -- "pk_live_..." prefix for display
    permissions: Set<String> -- currently unused (empty array)
    revoked_at: Timestamp?
    last_used_at: Timestamp?

    is_active: revoked_at = null

    @invariant ShowOncePolicy
        -- The full plaintext key is returned ONCE at creation, then lost.
        -- Only the hash is stored. Verification is hash-based.
        -- Max 10 active keys per user.
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    -- Encryption parameters
    pbkdf2_iterations: Integer = 100_000
    salt_length: Integer = 16               -- bytes, random per encryption
    iv_length: Integer = 12                 -- bytes
    key_length: Integer = 32                -- bytes
    auth_tag_length: Integer = 16           -- bytes

    -- Public API key limits
    max_active_keys_per_user: Integer = 10

    -- Ollama defaults
    default_ollama_base_url: String = "http://127.0.0.1:11434"
    -- URL validation rules (see security-rules.allium for details):
    -- Only http/https protocols allowed
    -- No embedded credentials in URL
    -- Malformed URLs rejected
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- === Module API Keys ===

rule SaveModuleApiKey {
    when: SaveModuleApiKey(user, module_id, key, label?)

    requires: length(key) > 0

    let is_sensitive = is_module_sensitive(module_id)

    ensures:
        if is_sensitive:
            let result = encrypt(key)
            ModuleApiKey.created(
                user: user,
                module_id: module_id,
                encrypted_key: result.encrypted,
                iv: result.iv,
                last4: last4(key),
                label: label
            )
        else:
            -- Non-sensitive: stored as plaintext (e.g. Ollama base URL)
            ModuleApiKey.created(
                user: user,
                module_id: module_id,
                encrypted_key: key,
                iv: "",
                last4: key,
                label: label
            )

    @guidance
        -- If a key already exists for (user, module_id), it is replaced (upsert).
        -- The sensitive flag is derived from the module manifest via
        -- ModuleRegistry, NEVER from client input. Unknown modules default
        -- to sensitive=true as a fail-safe.
}

rule GetUserApiKeys {
    when: GetUserApiKeys(user)

    ensures: UserApiKeysReturned(
        user: user,
        keys: user_module_keys
    )

    @guidance
        -- Sensitive keys show only last4, NEVER the encrypted value.
        -- Non-sensitive keys include the plaintext as displayValue.
        -- All keys for the requesting user are returned.
}

rule DeleteModuleApiKey {
    when: DeleteModuleApiKey(user, module_id)

    let target = ModuleApiKey{user: user, module_id: module_id}
    requires: exists target

    ensures: not exists target
}

rule ResolveOllamaBaseUrl {
    when: ResolveOllamaBaseUrl(user)

    let stored_key = ModuleApiKey{user: user, module_id: ollama}

    ensures:
        if exists stored_key:
            let url = decrypt_or_read(stored_key)
            if validate_url(url):
                OllamaBaseUrlResolved(user: user, url: url)
            else:
                OllamaBaseUrlResolved(user: user, url: config.default_ollama_base_url)
        else:
            OllamaBaseUrlResolved(user: user, url: config.default_ollama_base_url)

    @guidance
        -- SSRF protection: URL validated before every use, not just at storage.
        -- See security-rules.allium for validation rules.
        -- Invalid URLs fall back to the configured default.
}

-- === Public API Keys ===

rule CreatePublicApiKey {
    when: CreatePublicApiKey(user, name)

    requires: length(name) > 0
    requires: length(name) <= 100

    let active_keys = user.public_api_keys where revoked_at = null
    requires: active_keys.count < config.max_active_keys_per_user

    let plaintext = generate_api_key()

    ensures: PublicApiKey.created(
        user: user,
        name: name,
        key_hash: sha256(plaintext),
        key_prefix: key_prefix(plaintext),
        permissions: {}
    )
    ensures: PublicApiKeyCreated(
        user: user,
        plaintext: plaintext
    )
    -- After this response, the plaintext is irrecoverable.

    @guidance
        -- The full plaintext key is returned exactly once in the response.
        -- Subsequent reads show only the prefix. There is no "reveal"
        -- or "regenerate" operation.
}

rule ListPublicApiKeys {
    when: ListPublicApiKeys(user)

    ensures: PublicApiKeysListed(
        user: user,
        keys: user_public_keys
    )

    @guidance
        -- Keys returned with id, name, prefix, permissions, timestamps.
        -- key_hash is NEVER exposed in the response.
}

rule RevokePublicApiKey {
    when: RevokePublicApiKey(user, key)

    requires: key.user = user
    requires: key.is_active

    ensures: key.revoked_at = now
    -- Soft delete -- key remains for audit trail but is no longer valid.
}

rule DeletePublicApiKey {
    when: DeletePublicApiKey(user, key)

    requires: key.user = user
    requires: not key.is_active

    ensures: not exists key
    -- Only revoked keys can be permanently deleted.
    -- This enforces a two-step process: revoke then delete.
}

-- === Encryption ===

rule EncryptKey {
    when: EncryptKey(plaintext)

    ensures:
        let result = encrypt(plaintext)
        KeyEncrypted(encrypted: result.encrypted, iv: result.iv)

    @guidance
        -- Random salt generated (16 bytes per record).
        -- Key derived via PBKDF2(secret, salt, 100000, 32, sha256).
        -- Plaintext encrypted with AES-256-GCM (random IV, auth tag appended).
        -- Output format: "salt:<hex>:<base64-payload>".
        -- Per-record random salt prevents pre-computation attacks.
}

rule DecryptKey {
    when: DecryptKey(encrypted_data)

    ensures:
        let plaintext = decrypt(encrypted_data)
        KeyDecrypted(plaintext: plaintext)

    @guidance
        -- If encrypted_data starts with "salt:", extract salt, derive key, decrypt.
        -- Otherwise, legacy format: use hardcoded LEGACY_SALT for backwards compatibility.
        -- Legacy salt "jobsync-api-key-encryption" kept ONLY for reading old records.
        -- All new encryptions use random per-record salts.
        -- AES-256-GCM decrypt with auth tag verification.
        --
        -- PBKDF2 at 100_000 iterations is computationally expensive (~10ms per call).
        -- Implementations MAY cache derived keys in a bounded, process-scoped
        -- in-memory cache keyed by salt to avoid redundant derivation on the same record.
        -- The cache MUST be cleared on process restart (no persistent key cache).
        -- Cache size MUST be bounded to prevent unbounded memory growth.
        -- The encrypt/decrypt functions SHOULD be async to avoid blocking the event loop.
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should UseServerExportBoundary be enforced via a lint rule or remain a prose constraint? Functions accepting raw userId MUST NOT reside in 'use server' files -- they are callable from the browser. Functions that remain in 'use server' files and accept userId MUST verify caller === userId via getCurrentUser() before returning data."
