-- allium: 3
-- ai-provider.allium

-- Scope: AI Provider Connector — unified interface for AI model providers
-- Includes: AIProviderConnector interface, Ollama module, OpenAI module,
--   DeepSeek module, model selection, health checks, Ollama proxy with
--   field allowlisting, job-resume matching endpoint
-- Excludes:
--   - Module lifecycle (activation/deactivation, see module-lifecycle.allium)
--   - Automation pipeline orchestration (see scheduler-coordination.allium)
--   - API key storage (see api-key-management.allium)
--   - AI rate limiting internals (see connector rate-limiter)

-- Owner: AI Provider Connector (src/lib/connector/ai-provider/)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity ModuleRegistry {
    -- Unified module registry. AI Provider modules register their manifests
    -- and factories here. See module-lifecycle.allium.
}

external entity Resume {
    -- Resume data used for job matching. See profile-resume.allium.
}

external entity Job {
    -- Job data used for job matching. See job-aggregate.allium.
}

external entity ApiKey {
    -- Encrypted API key for cloud providers. See api-key-management.allium.
    -- Resolved via resolveApiKey(userId, moduleId).
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum AiModuleId {
    ollama          -- Local LLM via Ollama
    openai          -- OpenAI cloud API
    deepseek        -- DeepSeek cloud API
}

enum CredentialMode {
    endpoint_url    -- Ollama: URL to local/remote instance (default: localhost:11434)
    api_key         -- OpenAI, DeepSeek: bearer token
}

enum AIErrorType {
    unavailable     -- Service is down or returned error status
    auth_failed     -- API key invalid, expired, or missing
    rate_limited    -- Too many requests (may include retryAfter)
    network         -- Cannot connect (DNS failure, timeout, ECONNREFUSED)
}

------------------------------------------------------------
-- Core Interface
------------------------------------------------------------

-- The AIProviderConnector is the Published Language for all AI modules.
-- Every AI module implements this exact interface.

interface AIProviderConnector {
    id: AiModuleId
    name: String
    requires_api_key: Boolean

    -- Check if the provider is reachable and credentials are valid.
    health_check(user_id?: String): AIConnectorResult<Boolean>

    -- List available models from the provider.
    list_models(user_id?: String): AIConnectorResult<List<String>>

    -- Create a language model instance for inference.
    create_model(model_name: String, user_id?: String): AIConnectorResult<LanguageModel>
}

-- All operations return AIConnectorResult:
--   success: { success: true, data: T }
--   failure: { success: false, error: { type: AIErrorType, message: String } }

------------------------------------------------------------
-- Modules
------------------------------------------------------------

-- === Ollama ===

entity OllamaModule implements AIProviderConnector {
    id: "ollama"
    name: "Ollama"
    requires_api_key: false

    credential_mode: endpoint_url
    default_base_url: "http://127.0.0.1:11434"
    default_model: "llama3.2"
    health_check_timeout: 5000ms

    @invariant
        -- Ollama does NOT require an API key.
        -- The "credential" is the base URL to the Ollama instance.
        -- If no URL is configured, falls back to localhost.
        -- URL is resolved via: user DB key -> env OLLAMA_BASE_URL -> default.
}

entity OpenAIModule implements AIProviderConnector {
    id: "openai"
    name: "OpenAI"
    requires_api_key: true

    credential_mode: api_key
    api_base: "https://api.openai.com/v1"
    default_model: "gpt-4o-mini"
    health_check_timeout: 10000ms

    @invariant
        -- OpenAI REQUIRES an API key. All operations fail with auth_failed if missing.
        -- API key resolved via: user DB key -> env OPENAI_API_KEY.
}

entity DeepSeekModule implements AIProviderConnector {
    id: "deepseek"
    name: "DeepSeek"
    requires_api_key: true

    credential_mode: api_key
    api_base: "https://api.deepseek.com"
    default_model: "deepseek-chat"
    health_check_timeout: 10000ms

    @invariant
        -- DeepSeek REQUIRES an API key. Same pattern as OpenAI.
        -- API key resolved via: user DB key -> env DEEPSEEK_API_KEY.
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- === Module Registration ===

rule RegisterAIModules {
    when: Application starts (import-time side effect)

    ensures: moduleRegistry.register(ollamaManifest, createOllamaConnector)
    ensures: moduleRegistry.register(openaiManifest, createOpenAIConnector)
    ensures: moduleRegistry.register(deepseekManifest, createDeepSeekConnector)

    -- Registration happens at import time via the connectors.ts barrel file.
    -- The unified ModuleRegistry manages both Job Discovery and AI Provider modules.
    -- AIProviderRegistry is a thin facade over ModuleRegistry filtered by ConnectorType.
}

-- === Health Check ===

rule HealthCheck {
    when: Health check is requested for an AI module

    requires: Module is registered

    ensures:
        for Ollama:
            fetch GET {baseUrl}/api/tags with timeout
            if response ok: return success
            if network error: return { type: network }
        for OpenAI:
            resolve API key for user
            if no key: return { type: auth_failed }
            fetch GET api.openai.com/v1/models with Bearer token
            if 401/403: return { type: auth_failed }
            if 429: return { type: rate_limited }
        for DeepSeek:
            same pattern as OpenAI with api.deepseek.com
}

-- === Model Listing ===

rule ListModels {
    when: User requests available models from a provider

    requires: Module is registered
    requires: For cloud providers (OpenAI, DeepSeek): API key must be configured

    ensures:
        for Ollama:
            parse response.models[].name from /api/tags
        for OpenAI:
            parse response.data[].id from /models
        for DeepSeek:
            parse response.data[].id from /models
}

-- === Model Creation ===

rule CreateModel {
    when: System needs a language model instance for inference

    requires: Module is registered
    requires: For cloud providers: API key must be configured

    ensures: LanguageModel instance created using the provider's SDK
    ensures: Model can be used with Vercel AI SDK (streamText, generateText)
}

-- === Ollama Proxy (Server-Side) ===

rule OllamaProxyGenerate {
    when: Client sends POST /api/ai/ollama/generate

    requires: User is authenticated (session check)

    ensures: Request body filtered through field ALLOWLIST
    ensures: Only these fields forwarded to Ollama:
        - model (required)
        - prompt (required)
        - stream (forced to false)
        - system (optional)
        - template (optional)
        - context (optional)
    ensures: ALL other fields from client body are DROPPED
    ensures: Request proxied to {ollamaBaseUrl}/api/generate with 10s timeout

    -- This is a SECURITY-CRITICAL rule. The allowlist prevents parameter injection
    -- (CWE-20). Without it, a malicious client could inject arbitrary Ollama API
    -- parameters (e.g. raw_prompt, keep_alive, num_predict) to manipulate model behavior.
}

-- === Ollama URL Validation ===

rule ValidateOllamaUrl {
    when: Ollama base URL is resolved for any operation

    requires: URL is non-empty

    ensures:
        if URL protocol is not http or https: rejected
        if URL contains credentials (username/password): rejected
        if URL is valid: used as-is
        if URL fails validation: fall back to default (127.0.0.1:11434)

    -- Defense against SSRF. See security-rules.allium for full URL validation spec.
}

-- === Job-Resume Matching ===

rule JobResumeMatch {
    when: User requests AI match score for a resume-job pair

    requires: User is authenticated
    requires: resumeId, jobId, and selectedModel provided
    requires: User passes rate limit check

    ensures: Resume and Job loaded in parallel
    ensures: Both preprocessed (text normalization)
    ensures: LLM called with:
        - system prompt: JOB_MATCH_SYSTEM_PROMPT
        - user prompt: buildJobMatchPrompt(resumeText, jobText)
        - temperature: 0.3
        - output schema: JobMatchSchema (structured output)
    ensures: Streamed response returned to client

    -- The match endpoint uses Vercel AI SDK's streamText with structured output.
    -- The LLM produces a typed match result (score, analysis, recommendations).
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant OllamaFieldAllowlist {
    -- The Ollama proxy endpoint MUST use a field allowlist for body forwarding.
    -- Only explicitly listed fields (model, prompt, stream, system, template, context)
    -- may be forwarded to the Ollama API.
    -- Raw client body MUST NEVER be forwarded without filtering.
    -- This prevents parameter injection attacks (CWE-20).
    for POST /api/ai/ollama/generate:
        forwarded_body = allowlist_filter(client_body)
}

invariant OllamaUrlSafety {
    -- Ollama URLs MUST be validated before use:
    -- 1. Protocol must be http or https
    -- 2. No embedded credentials (username:password@host)
    -- 3. Cloud metadata endpoints are blocked (169.254.169.254, etc.)
    -- 4. If validation fails, fall back to localhost default
    for all Ollama operations:
        url = validateOllamaUrl(resolved_url) || default_url
}

invariant CredentialResolution {
    -- API keys/URLs are resolved per-user using the credential resolution chain:
    -- 1. User's encrypted key from DB (ApiKey table, decrypted at runtime)
    -- 2. Environment variable fallback (e.g. OPENAI_API_KEY)
    -- 3. Default value from manifest (only Ollama has a default URL)
    -- Cloud providers FAIL if no key is found (no silent fallback).
    for all AI operations:
        credential = resolveApiKey(userId, moduleId)
}

invariant AuthenticatedAIRoutes {
    -- ALL /api/ai/* routes MUST check auth() before processing.
    -- Unauthenticated requests receive 401.
    for all routes /api/ai/*:
        session = auth()
        if not session: reject(401)
}

invariant AIErrorClassification {
    -- All AI module operations return typed errors via AIConnectorResult.
    -- Error types map to specific HTTP status codes when surfaced via API:
    --   auth_failed -> 401/403
    --   rate_limited -> 429
    --   unavailable -> 503
    --   network -> 502
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

-- Q1: Should the Ollama proxy support streaming? Currently stream is forced
--     to false. The match endpoint uses streamText separately.

-- Q2: Should there be a unified "AI match" action that works through the
--     AIProviderConnector interface instead of the direct API route?

-- Q3: Should model listing results be cached? Currently every model list
--     request hits the upstream API.

-- Q4: Should the Ollama field allowlist be configurable rather than hardcoded?
--     Adding new Ollama features would require code changes.
