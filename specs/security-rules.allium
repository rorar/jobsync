-- allium: 3
-- security-rules.allium

-- Scope: Cross-cutting security rules and defense-in-depth patterns
-- Includes: IDOR ownership enforcement, SSRF URL validation, credential URL
--   protection (3-layer defense), security headers, AUTH_SECRET stability,
--   user enumeration prevention, form method=POST, Ollama field allowlisting,
--   ESCO URI validation, API key hashing, parameter injection prevention,
--   pre-auth IP rate limiting, "use server" export security, runtime union
--   validation, UUID route param validation, filePath exclusion, error sanitization
-- Excludes:
--   - Authentication flow (see auth-session.allium)
--   - API key lifecycle (see api-key-management.allium)
--   - Module resilience (see module-lifecycle.allium)

-- Owner: Cross-cutting (src/middleware.ts, src/lib/url-validation.ts,
--   src/actions/*.ts, src/components/auth/*, docker-entrypoint.sh)

-- THIS IS THE MOST IMPORTANT SPEC. It documents the security posture
-- of the entire application and the fixes applied during security review.

------------------------------------------------------------
-- Security Threat Model
------------------------------------------------------------

-- CWE-639: Insecure Direct Object Reference (IDOR)
-- CWE-918: Server-Side Request Forgery (SSRF)
-- CWE-204: User Enumeration via Observable Differences
-- CWE-20:  Improper Input Validation (Parameter Injection, Union Types)
-- CWE-598: Credential Exposure in GET Parameters
-- CWE-352: Cross-Site Request Forgery (CSRF)
-- CWE-614: Missing Security Headers
-- CWE-209: Information Exposure Through Error Messages
-- CWE-208: Observable Timing Discrepancy (API key validation)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity User {
    id: String
    email: String
    role: String
}

external entity HttpRequest {
    path: String
    method: String
    ip: String
    headers: String
    body: String
    query_params: String
}

external entity HttpResponse {
    status: Integer
    headers: String
    body: String
}

external entity ServerAction {
    name: String
    user_id_source: session | client_input
}

external entity ApiRoute {
    path: String
    auth_method: session | api_key | none
}

external entity File {
    id: String
    file_name: String
    file_type: String
    file_path: String
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum AuthOutcome { allowed | rejected | redirected | rate_limited }

enum ValidationOutcome { valid | blocked }

------------------------------------------------------------
-- Contracts
------------------------------------------------------------

contract IdorOwnershipEnforcement {
    -- The primary data access security contract.
    -- Every read, update, and delete on user-owned data MUST include
    -- the authenticated user's ID in the database query.

    verify_direct_ownership: (user: User, resource_id: String) -> Boolean
    -- Applies to: Job, Note, Automation, Tag, Company, Location, JobSource, etc.
    -- Pattern: findFirst({ where: { id, userId: user.id } })

    verify_relation_chain: (user: User, resource_id: String) -> Boolean
    -- Applies to: Resume, ContactInfo, ResumeSection, WorkExperience, Education
    -- Pattern: findFirst({ where: { id, profile: { userId: user.id } } })
    --   or deeper: { id, ResumeSection: { Resume: { profile: { userId: user.id } } } }
    -- Chain paths:
    --   Resume:          resume.profile.userId = user.id
    --   ContactInfo:     contactInfo.resume.profile.userId = user.id
    --   ResumeSection:   section.Resume.profile.userId = user.id
    --   WorkExperience:  exp.ResumeSection.Resume.profile.userId = user.id
    --   Education:       edu.ResumeSection.Resume.profile.userId = user.id

    verify_cross_aggregate: (user: User, resource_id: String) -> Boolean
    -- Applies to: References between aggregates (e.g. Job.resumeId, Automation.resumeId)
    -- Prevents a user from linking their Job/Automation to another user's Resume.
    -- Examples:
    --   Resume in Automation: findFirst({ id: resumeId, profile: { userId } })
    --   Resume in Job:        findFirst({ id: resumeId, profile: { userId } })
    --   Tags in Job:          tag.count({ id: { in: tagIds }, createdBy: userId })

    @invariant NeverTrustClientUserId
        -- The userId for database queries MUST come from the server session
        -- (getCurrentUser()) or API key validation (withApiAuth()).
        -- Client-submitted userId fields in form data are IGNORED.
        -- This is the foundational IDOR prevention principle.

    @invariant SessionOnlyUserId
        -- userId comes from SESSION, never from client input.
        -- Implementation: All server actions use getCurrentUser() which returns
        -- the session user. API v1 routes use withApiAuth() which injects userId.

    @guidance
        -- Each mutation (update, delete) MUST perform a findFirst with the
        -- chain traversal BEFORE executing the write operation.
        -- If the findFirst returns null, the operation is rejected.
}

contract SsrfUrlValidation {
    -- URL validation rules for all external URL inputs.

    validate_ollama_url: (url: String) -> ValidationOutcome
    -- Ensures URL protocol is http or https (no file://, ftp://, data://, etc.)
    -- Ensures URL does not contain embedded credentials (user:pass@host)
    -- Ensures unparseable URLs are blocked.
    -- On validation failure: fall back to default localhost URL.
    -- NOTE: Cloud metadata endpoint blocking (169.254.169.254, metadata.google.internal)
    -- is in isBlockedHealthCheckUrl(), a separate function used by the health monitor,
    -- not validateOllamaUrl(). Ollama URL validation focuses on protocol + credentials.
    -- Localhost (127.0.0.1, ::1) is intentionally ALLOWED because
    -- Ollama typically runs locally.

    validate_esco_uri: (uri: String) -> ValidationOutcome
    -- Ensures URI starts with "http://data.europa.eu/esco/"
    -- No other URI schemes or domains accepted.
    -- Prevents SSRF through the ESCO proxy endpoint.
    -- Without this, an attacker could use the proxy to reach internal services.

    validate_image_url: (url: String) -> ValidationOutcome
    -- Ensures URL protocol is http or https.
    -- Invalid URLs are rejected.
    -- Prevents injection of non-HTTP schemes (javascript:, data:, etc.)
    -- in company logo URLs that may be rendered in img tags.

    @invariant NoRawBodyForwarding
        -- When proxying requests to external services (Ollama, ESCO, EURES),
        -- the client request body MUST be filtered through an allowlist.
        -- Raw forwarding (spreading, Object.assign) creates parameter injection risk.

    @invariant AuthenticatedProxyRoutes
        -- All API proxy routes (/api/esco/*, /api/eures/*, /api/ai/*) MUST
        -- check auth() before processing.
        -- Never expose upstream APIs to unauthenticated users.
}

contract CredentialUrlProtection {
    -- Defense-in-depth against credentials appearing in URLs.
    -- Prevents password exposure via browser history, server logs, referrer headers.

    enforce_form_post: (form: Any) -> Boolean
    -- Layer 1: First line of defense. Prevent native browser GET submission.
    -- Ensures form element has method="POST" and action="" (empty, prevents
    -- cross-origin submission). If method="POST" is missing and JavaScript
    -- fails to load, the browser would submit credentials via GET query parameters.

    strip_credentials_client: (url: String) -> String
    -- Layer 2: Strip credentials from URL on page mount.
    -- On signin or signup page mount, useEffect runs. If URL contains email
    -- or password query parameters, remove them via replaceState. This handles
    -- the case where credentials ended up in the URL despite Layer 1 (e.g.,
    -- form modified by browser extension).

    redirect_clean_url: (request: HttpRequest) -> HttpResponse
    -- Layer 3: Server-side redirect strips credentials.
    -- When request to /signin or /signup contains email or password query params,
    -- 303 redirect to clean URL (same path, no query params).
    -- 303 status code forces GET, preventing POST replay.
    -- Even if both client-side layers fail, the middleware catches it.

    @invariant DefenseInDepth
        -- Security controls are layered. No single control is relied upon alone.
        -- Credential protection: form POST + client strip + middleware redirect.
        -- IDOR: session auth + userId in query + ownership verification.
        -- SSRF: protocol check + credential check + metadata block + fallback.
}

contract SecurityHeaderEnforcement {
    -- Security headers applied to all matched routes.

    apply_headers: (response: HttpResponse) -> HttpResponse
    -- Applied by middleware to all matched routes
    -- (/dashboard/*, /signin, /signup, /api/v1/:path*).
    -- Headers:
    --   Referrer-Policy: strict-origin-when-cross-origin
    --   X-Content-Type-Options: nosniff
    --   X-Frame-Options: DENY
    --   Permissions-Policy: camera=(), microphone=(), geolocation=()
    --   (Production only) Strict-Transport-Security: max-age=31536000; includeSubDomains
    -- API v1 routes also get withApiAuth() headers
    -- (Cache-Control: no-store, X-Content-Type-Options).

    @guidance
        -- Applied by middleware to all matched routes.
}

contract AuthSecretStability {
    -- AUTH_SECRET environment variable must be pre-configured and stable.

    validate_secret: (env: Any) -> Boolean
    -- On Docker container start (docker-entrypoint.sh):
    -- If AUTH_SECRET is empty or unset, FATAL error logged, container exits
    -- with code 1, server does NOT start.

    @invariant SecretNeverAutoGenerated
        -- An ephemeral or auto-generated AUTH_SECRET invalidates ALL active sessions
        -- on every container restart. This was a critical bug that locked out all users.
        -- The fix: docker-entrypoint.sh refuses to start without a pre-configured secret.

    @invariant SecureSecretManagement
        -- AUTH_SECRET: Pre-configured, stable, never auto-generated.
        -- Module API keys: AES-256-GCM encrypted at rest.
        -- Public API keys: SHA-256 hashed, raw shown once.
        -- No secrets in code, commits, logs, or URLs.
}

contract UserEnumerationPrevention {
    -- Prevent information leakage about registered accounts.

    generic_signin_error: (outcome: AuthOutcome) -> String
    -- Signin fails (email not found OR password wrong):
    -- Error message is "Invalid credentials." for BOTH cases.
    -- Error does NOT distinguish between unknown email and wrong password.
    -- CWE-204: If different messages were shown for "email not found" vs
    -- "wrong password", an attacker could enumerate valid email addresses.

    generic_signup_error: (outcome: AuthOutcome) -> String
    -- Signup fails because email already exists:
    -- Error message is generic:
    -- "Unable to create account. Please try a different email or sign in."
    -- Message does NOT confirm the email is registered.
    -- Same principle: prevents email enumeration during registration.

    @invariant GenericErrorMessages
        -- Authentication error messages MUST NOT leak information about:
        --   whether an email address is registered,
        --   whether a username exists,
        --   whether a specific resource exists for another user.
        -- All auth failures return generic messages.
}

contract OllamaFieldAllowlisting {
    -- Request body filtering for Ollama proxy.

    filter_body: (body: Any) -> Any
    -- POST /api/ai/ollama/generate proxies request to Ollama.
    -- Only allowlisted fields forwarded:
    --   model, prompt, stream (forced false), system, template, context.
    -- All other fields from client body are SILENTLY DROPPED.
    -- No raw body forwarding (Object.assign, spread, etc.).

    @invariant StrictAllowlist
        -- CWE-20: Without allowlisting, a malicious client could inject:
        --   raw_prompt: true (bypass template processing)
        --   num_predict: 99999 (resource exhaustion)
        --   keep_alive: "999h" (prevent model unloading)
        -- The allowlist is the ONLY safe pattern for request proxying.
}

contract ApiKeySecurity {
    -- API key creation, storage and validation rules.

    hash_public_key: (raw_key: String) -> String
    -- Raw key hashed with SHA-256 before storage.
    -- Raw key shown to user ONCE at creation, then never again.
    -- Only key prefix (pk_live_ + 4 chars) visible after creation.
    -- Revoked keys (revokedAt != null) are rejected.
    -- Max 10 active keys per user.

    validate_key: (key_hash: String) -> Boolean
    -- Validation uses constant-time evaluation pattern:
    -- Always perform the same DB lookup and boolean operations
    -- regardless of whether the key exists or is revoked.
    -- This prevents timing oracles that could distinguish
    -- "key not found" from "key revoked" (SEC-17).

    encrypt_module_key: (raw_key: String) -> String
    -- Module credential (e.g. OpenAI API key) encrypted with AES-256-GCM.
    -- IV stored alongside encrypted key.
    -- Only last 4 characters stored in plaintext (for display).
    -- Unique constraint on (userId, moduleId) — one key per module per user.

    @guidance
        -- See api-key-management.allium for full lifecycle.
}

contract RateLimiting {
    -- Rate limiting rules across all entry points.

    check_pre_auth_ip_limit: (ip: String) -> AuthOutcome
    -- Any request to /api/v1/*:
    -- Rate limit checked by IP BEFORE API key authentication.
    -- Limit: 120 requests per minute per IP address.
    -- IP extracted from X-Forwarded-For (first entry), X-Real-IP, or "unknown".
    -- If over limit: reject with 429 RATE_LIMITED + Retry-After header.
    -- If under limit: proceed to API key authentication.
    -- Prevents DoS via invalid key flooding. Without this, an attacker
    -- could exhaust database lookups by sending millions of requests with
    -- random API keys. The IP rate limit catches this BEFORE the DB query.
    -- CAVEAT: X-Forwarded-For is forgeable without a trusted reverse proxy.

    check_signin_limit: (ip: String) -> AuthOutcome
    -- IP-based sliding window rate limit:
    -- 5 attempts per 15 minutes per IP address.
    -- On rate limit exceeded:
    -- reject with i18n error "auth.rateLimitExceeded" + retry-after seconds.
    -- 1-second delay before processing credentials (timing-oracle prevention).
    -- FL-3 fix: replaced fixed delay with proper rate limiting.
    -- Delay preserved for timing-oracle prevention (CWE-208).
    -- See auth-session.allium for full config values.

    check_signup_limit: (ip: String) -> AuthOutcome
    -- IP-based sliding window rate limit:
    -- 3 attempts per 60 minutes per IP address.
    -- On rate limit exceeded:
    -- reject with i18n error "auth.rateLimitExceeded" + retry-after seconds.
    -- FL-3 fix: signup previously had NO rate limiting at all.
    -- Stricter than signin (3 vs 5) because account creation is a heavier operation.

    check_api_key_limit: (api_key: String) -> AuthOutcome
    -- Sliding window rate limit: 60 requests per minute per API key.
    -- Rate limit headers on every response.
    -- See public-api-v1.allium for full details.

    check_ai_match_limit: (user: User) -> AuthOutcome
    -- Per-user rate limit checked before processing.
    -- Prevents abuse of expensive LLM inference.
}

contract MiddlewareRouteProtection {
    -- Route-level access control via middleware.

    check_dashboard_access: (request: HttpRequest, user: User) -> AuthOutcome
    -- Request to /dashboard or /dashboard/*:
    -- If authenticated: allow.
    -- If not authenticated: redirect to /signin.
    -- Middleware matcher includes /dashboard paths.

    check_auth_route: (request: HttpRequest, user: User) -> AuthOutcome
    -- Request to /signin or /signup:
    -- Credential query params sanitized (Layer 3).
    -- Security headers added.
    -- If authenticated AND visiting auth route: redirect to /dashboard.
    -- Prevents authenticated users from seeing the login page.

    check_api_route: (request: HttpRequest) -> AuthOutcome
    -- Request to /api/* routes:
    -- Each API route handler checks auth() independently.
    -- /api/v1/* routes use withApiAuth() wrapper.
    -- Middleware matcher includes /api/v1/:path* for security headers.
    -- The authorized() callback redirects to /dashboard for non-dashboard
    -- matched paths when a session exists (prevents authenticated users
    -- from hitting raw API routes in the browser). For unauthenticated
    -- requests (typical for API v1 with API key auth), authorized()
    -- returns true — letting the route handler's own auth gate decide.
    -- API routes are responsible for their own authentication.
    -- This is by design — API v1 uses API key auth, not session auth.
}

contract UseServerExportPolicy {
    -- "use server" export security rules.

    validate_export: (function_name: String, accepts_user_id: Boolean) -> ValidationOutcome
    -- A server-side function accepting a raw userId parameter
    -- MUST NOT reside in a "use server" file.
    -- Instead, it lives in a server-only module (import "server-only").
    -- "use server" exports are callable from the browser. A function
    -- accepting raw userId in a "use server" file allows any authenticated
    -- user to pass another user's ID and access their data (IDOR).
    -- Example fix (SEC-13): getBlacklistEntriesForUser was moved from
    -- companyBlacklist.actions.ts ("use server") to src/lib/blacklist-query.ts
    -- (import "server-only"). The caller (Runner) is trusted to pass a
    -- valid userId from the automation context.
    -- Functions that accept userId but remain in "use server" files
    -- (e.g. getAutomationSettingsForUser, getNotificationPreferencesForUser)
    -- MUST verify caller === userId via getCurrentUser() before proceeding.

    @guidance
        -- Pattern A (preferred): Move to a file with import "server-only".
        -- Pattern B: Add getCurrentUser() check and verify user.id === userId.
}

contract RuntimeUnionValidationPolicy {
    -- Runtime validation of TypeScript union/enum parameters.

    validate_union: (value: String, allowlist: Any) -> ValidationOutcome
    -- A "use server" function accepting a TypeScript union/enum parameter
    -- MUST validate at runtime against an explicit allowlist BEFORE use.
    -- TypeScript type erasure means the TS type provides NO protection.
    -- Examples of validated union types:
    --   matchType (BlacklistMatchType): validated against VALID_MATCH_TYPES (SEC-14)
    --   status (TaskStatus): validated against TASK_STATUSES (BS-8)
    --   actionType (BulkActionType): validated against VALID_BULK_ACTIONS (BS-8)
    -- Without runtime validation, a malicious client can send any string
    -- for a parameter typed as a union, potentially corrupting data or
    -- bypassing business logic.

    @guidance
        -- Always use a const array or Set for the allowlist, never a TS type.
}

contract UuidValidation {
    -- UUID validation on API route parameters.

    validate_uuid: (param: String) -> ValidationOutcome
    -- API route handler receives a path parameter (e.g. :id).
    -- Parameter validated against strict UUID regex:
    -- /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i
    -- Invalid UUIDs rejected with 400 VALIDATION_ERROR before any DB query.
    -- Prevents injection of non-UUID strings into Prisma queries.
    -- Applied to all /api/v1/jobs/:id and /api/v1/jobs/:id/notes routes.
}

contract FilePathExclusionPolicy {
    -- File.filePath must never leak to clients.

    select_safe_fields: (file: File) -> Any
    -- Server response includes File entity data.
    -- File.filePath is NEVER included in the response.
    -- Only File.id, File.fileName, File.fileType are returned.
    -- Prisma queries use select with id, fileName, fileType for File.
    -- File.filePath contains the server filesystem path, which is an
    -- information disclosure risk. Exposing it reveals the deployment
    -- directory structure. Applied to:
    --   getResumeById (profile.actions.ts)
    --   getJobDetails (job.actions.ts)
    --   GET /api/v1/jobs/:id (route.ts)
}

contract ErrorSanitization {
    -- Error message sanitization for API responses.

    sanitize_error: (status: Integer, message: String) -> String
    -- API v1 response has HTTP status 500:
    -- Response message is generic: "An unexpected error occurred."
    -- Raw Prisma errors, stack traces, and internal details are NEVER exposed.
    -- Non-500 errors (400, 401, 404, 409) pass through their messages.
    -- Implemented in src/lib/api/response.ts (SEC-18).
    -- The actionToResponse() function checks the inferred status code.
    -- If it resolves to 500 (no recognized pattern in the message),
    -- the message is replaced with the generic text.
}

------------------------------------------------------------
-- Known Gaps (from security review)
------------------------------------------------------------

-- GAP-1: RESOLVED. deleteWorkExperience and deleteEducation now verify
--   ownership via chain traversal (WorkExperience/Education -> ResumeSection
--   -> Resume -> profile -> userId) before deletion. See profile-resume.allium.

-- GAP-2: RESOLVED. deleteResumeById now verifies ownership via
--   resume -> profile -> userId before cascade delete. deleteFile accepts
--   callerUserId for File -> Resume -> Profile -> User chain verification.
--   See profile-resume.allium.

-- GAP-3: RESOLVED. Export endpoint (/api/jobs/export) now has route-level
--   auth via middleware matcher (/api/v1/:path*) and getCurrentUser() internally.
--   The authorized() function returns true for non-dashboard matched paths,
--   so the route handler's own getCurrentUser() call is the auth gate.
--   This is consistent with ApiRouteSelfProtection.

-- GAP-4: RESOLVED (FL-3). IP-based sliding window rate limiting added for
--   both signin (5/15min) and signup (3/60min). Account lockout still not
--   implemented (heavy UX impact for self-hosted), but brute force is now
--   rate-limited beyond the original 1-second delay.

-- GAP-5: Rate limiting for Public API is in-memory only.
--   Does not persist across restarts or work in multi-instance deployments.
--   Severity: Low (self-hosted, single-instance typical).

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should all delete operations require ownership verification, even if the ID is a UUID (hard to guess)? UUIDs reduce but do not eliminate the IDOR risk."

open question "Should the middleware matcher be expanded to include /api/* routes? This would add a second layer of protection but may complicate API key authentication for public API routes."

open question "Should Content-Security-Policy be added? Currently not set. Would require careful configuration to avoid breaking inline styles from UI component libraries."

open question "Should there be automated security scanning (e.g., OWASP ZAP) as part of the CI pipeline?"
