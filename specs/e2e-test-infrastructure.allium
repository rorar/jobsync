-- allium: 3
-- e2e-test-infrastructure.allium

-- Scope: E2E test execution infrastructure for JobSync
-- Includes: Test categorization, auth state management, execution pipeline, data isolation
-- Excludes:
--   - Individual test assertions (domain-level, not infrastructure)
--   - Unit/component test infrastructure (Jest, separate concern)
--   - CI/CD pipeline definition (GitHub Actions, separate concern)
-- Dependencies: User entity defined in jobsync.allium

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity PlaywrightRunner {
    projects: List<Project>
    global_setup: GlobalSetup?
    workers: Integer
    timeout: Duration
    web_server: WebServerConfig
}

external entity NextAuthSession {
    cookies: String                -- serialized cookie jar
    expires_at: Timestamp
}

external entity SQLiteDatabase {
    path: String                   -- "prisma/dev.db"
    -- Shared across all tests and dev server; no per-test isolation
}

external entity WebServerConfig {
    command: String
    reuse_existing_server: Boolean
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value AuthState {
    storage_state_path: String     -- "e2e/.auth/user.json"
    user_email: String             -- "admin@example.com"
    created_at: Timestamp
    session: NextAuthSession
}

value TestDataIdentifier {
    uid: String                    -- Date.now().toString(36), e.g. "m1abc2d"
    -- Note: prefix is not used in practice. Tests use "{Label} {uid}" format
    -- (e.g., "Co m1abc2d", "Tag m1abc2d") which is sufficiently unique.
}

------------------------------------------------------------
-- Contracts
------------------------------------------------------------

contract TestConventions {
    @invariant ChromiumOnly
        -- Only Chromium is configured as a browser project.
        -- Firefox and WebKit are not included.

    @invariant BunNotNpm
        -- webServer fallback command uses "bun run dev", not "npm run dev".

    @invariant NoSerialDescribes
        -- No test file uses test.describe.serial.
        -- All tests within a file are independently runnable.

    @invariant NoCrossTestDependency
        -- No test reads data created by a different test.
        -- Each test is hermetic — it can run alone and in any order.

    @invariant StorageStateGitignored
        -- The .auth/ directory containing session cookies is never committed.

    @invariant SingleSourceHelpers
        -- ALL reusable E2E utilities live in e2e/helpers/index.ts.
        -- No test file duplicates login(), selectOrCreateComboboxOption(),
        -- expectToast(), or uniqueId().
        -- Exception: signin.spec.ts may define inline login (tests the auth flow itself).
        -- Exception: locale-switching.spec.ts may define locale-aware login variant.

    @invariant SharedDatabaseIsolation
        -- All E2E tests share a single SQLite database (prisma/dev.db).
        -- No test modifies seed data (admin user, job sources, job statuses).
        -- No test reads data created by another test.
        -- All test-created data uses uniqueId() for identification.

    @invariant SeedDataReadOnly
        -- Seed data (admin user, job sources, job statuses, default profile)
        -- is shared infrastructure. Tests may READ seed data but never MODIFY it.

    @invariant OneSpecPerAggregate
        -- Each domain aggregate generally has one E2E spec file.
        -- Exception: automation has two files (automation-crud + automation-wizard-modules)
        -- because the wizard's module-specific flows are complex enough
        -- to warrant separation.
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum TestCategory {
    smoke                          -- auth-free, read-only tests
    crud                           -- authenticated CRUD flows
}

enum DomainAggregate {
    auth
    locale
    job
    task
    activity
    automation
    question
    profile
    company
    module_settings
    keyboard_ux
}
-- Note: automation has two spec files (automation-crud + automation-wizard-modules)
-- because the wizard is complex enough to warrant a dedicated test file.
-- keyboard-ux is a cross-cutting spec, not strictly one DDD aggregate.

enum ProjectStatus {
    pending
    running
    passed
    failed
    skipped
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity Project {
    name: String                   -- "smoke" | "crud"
    category: TestCategory
    test_dir: String               -- relative path, e.g. "e2e/smoke"
    storage_state: AuthState?      -- null for smoke, set for crud
    status: ProjectStatus
    dependencies: List<Project>    -- smoke has none, crud depends on smoke
    files: List<TestFile>
}

entity TestFile {
    path: String                   -- e.g. "e2e/crud/job-crud.spec.ts"
    aggregate: DomainAggregate
    category: TestCategory
    test_count: Integer
    uses_storage_state: Boolean
}

entity GlobalSetup {
    -- Runs once before any project. Performs UI login and persists auth state.
    auth_state: AuthState
    executable_path: String?       -- PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH for NixOS
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    workers_local: Integer = 3
    workers_ci: Integer = 1
    timeout_default: Duration = 60.seconds
    timeout_expect: Duration = 10.seconds
    timeout_action: Duration = 10.seconds
    retries_ci: Integer = 2
    retries_local: Integer = 0
    base_url: String = "http://localhost:3737"
    chromium_executable: String = "/run/current-system/sw/bin/chromium"
    stability_runs: Integer = 5   -- number of repeated runs for anti-flaky verification
}

------------------------------------------------------------
-- Rules: Pipeline Execution
------------------------------------------------------------

rule GlobalSetupRunsFirst {
    -- WHEN a test run starts, the global setup authenticates once
    -- and saves the session to storageState before any project runs.
    when: TestRunStarted(setup)
    requires: setup.auth_state.storage_state_path != null
    ensures: setup.auth_state.created_at = now

    @guidance
        -- The global setup must complete and persist auth state
        -- before any Project begins execution.
}

rule PipelineDependencies {
    -- WHEN projects are scheduled, smoke runs before crud.
    -- If smoke fails, crud is skipped entirely (fail-fast).
    when: ProjectScheduled(project)
    requires: project.dependencies.all(dep => dep.status = passed)
    ensures: project.status = running

    @guidance
        -- A project executes only after all its dependencies pass.
        -- If any dependency has failed, this project is skipped.
}

rule SmokeProjectConfig {
    -- Smoke tests run WITHOUT storageState.
    -- They test the authentication flow itself (signin, locale-switching).
    when: ProjectConfigured(project)
    requires: project.category = smoke
    ensures: project.storage_state = null

    @guidance
        -- All files in a smoke project must not use storageState.
        -- Smoke tests verify the authentication flow itself.
}

rule CrudProjectConfig {
    -- CRUD tests run WITH storageState from global setup.
    -- No per-test login is needed.
    when: ProjectConfigured(project, setup)
    requires: project.category = crud
    requires: setup.auth_state != null
    ensures: project.storage_state = setup.auth_state

    @guidance
        -- All files in a crud project use the storageState from global setup.
        -- No per-test login is needed.
}

------------------------------------------------------------
-- Rules: Self-Contained Tests (Anti-Flaky)
------------------------------------------------------------

rule SelfContainedCrudTest {
    -- EVERY CRUD test must be independently runnable.
    -- Each test creates its own data, asserts, and cleans up.
    -- No test depends on state from a previous test.
    when: CrudTestExecutes(test)
    requires: test.category = crud
    ensures: test.uses_storage_state = true

    @guidance
        -- Each test creates own test data with unique TestDataIdentifier.
        -- Each test cleans up own data (via afterEach or inline cleanup).
        -- No test reads data created by another test.
}

rule UniqueTestData {
    -- WHEN a CRUD test creates data, it uses a unique identifier
    -- derived from Date.now().toString(36) to prevent collision
    -- when tests run in parallel across workers.
    when: CrudTestCreatesData(test, entity_name)
    let uid = TestDataIdentifier{uid: timestamp_base36()}
    ensures: test.uses_storage_state = true

    @guidance
        -- The entity_name must contain the uid to ensure uniqueness
        -- across parallel workers.
}

rule CleanupOnFailure {
    -- WHEN a test fails during assertion, cleanup must still execute.
    -- Use test.afterEach hooks, not inline cleanup after assertions.
    when: CrudTestFails(test)
    ensures: test.uses_storage_state = true

    @guidance
        -- test.afterEach must execute cleanup regardless of assertion outcome.
        -- All test data created by this test must be removed.
}

------------------------------------------------------------
-- Rules: Shared Helpers
------------------------------------------------------------

-- SingleSourceHelpers and HelperExceptions describe code structure conventions
-- that cannot be expressed as entity state transitions. They are captured
-- as prose invariants below in the Invariants section.

------------------------------------------------------------
-- Rules: Data Isolation
------------------------------------------------------------

-- SharedDatabaseConstraint and SeedDataIsReadOnly describe test isolation
-- conventions. They are captured as prose invariants below.

------------------------------------------------------------
-- Rules: One Spec Per Aggregate
------------------------------------------------------------

-- OneSpecPerAggregate describes a file-organisation convention.
-- Captured as a prose invariant below.

------------------------------------------------------------
-- Rules: Dev Server
------------------------------------------------------------

rule ExternalDevServer {
    -- The dev server MUST be started externally before running E2E tests.
    -- Playwright config uses reuseExistingServer: true.
    -- Agents must never start/stop the dev server themselves.
    when: TestRunStarted(setup)
    requires: setup.auth_state != null
    ensures: setup.auth_state.created_at = now

    @guidance
        -- PlaywrightRunner.web_server.reuse_existing_server must be true.
        -- The dev server is started externally; agents must never start or stop it.
}

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

actor Developer {
    identified_by: PlaywrightRunner where workers > 1
}

actor CI {
    identified_by: PlaywrightRunner where workers = 1
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface LocalExecution {
    facing runner: Developer
    context suite: PlaywrightRunner

    contracts:
        demands TestConventions

    provides:
        RunAll(runner, suite)
            -- npx playwright test --workers=4
        RunSmoke(runner, suite)
            -- npx playwright test --project=smoke
        RunCrud(runner, suite)
            -- npx playwright test --project=crud
        RunSingleFile(runner, suite, path: String)
            -- npx playwright test <path>

    exposes:
        suite.projects
        suite.workers
        suite.timeout

    @guidance
        -- Also exposes html_report, test_results and timing_metrics
        -- which are Playwright output artifacts outside this entity model.
}

surface CIExecution {
    facing runner: CI
    context suite: PlaywrightRunner

    contracts:
        demands TestConventions

    provides:
        RunAll(runner, suite)
            -- nice -n 10 npx playwright test --project=chromium --workers=1

    exposes:
        suite.projects
        suite.workers

    @guarantee ResourceSafe
        -- CI execution uses nice -n 10 and --workers=1 to avoid
        -- race conditions under tight NixOS VM resources.
}

surface PlaywrightConfig {
    facing runner: Developer
    context suite: PlaywrightRunner

    exposes:
        suite.global_setup
        suite.projects
        suite.workers
        suite.timeout
        suite.web_server

    @guarantee PipelineOrder
        -- Projects execute in dependency order: smoke first, then crud.
        -- Smoke failure prevents crud execution.
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should storageState be refreshed mid-run if NextAuth session expires during long test suites?"
open question "Should a future Phase introduce per-test database transactions for stronger isolation (e.g., SQLite savepoints)?"
open question "Should waitForTimeout calls be systematically replaced with event-based waits, or is the debounce pattern acceptable?"
