// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Step: 1 run `npx prisma generate`
// Step: 2 run `npx prisma migrate dev` after update, make sure code is updated afterwards
//
// ---------------------------------------------------------------------------
// JSON / JSONB columns on SQLite (Sprint 4 L-A-06 documentation note)
// ---------------------------------------------------------------------------
//
// Several models below declare columns as Prisma's cross-DB `Json?` type —
// notably `Notification.data`, `Notification.titleParams`, `Notification.
// reasonParams`, `StagedVacancy.industryCodes`, `StagedVacancy.
// occupationUris`, `StagedVacancy.workingLanguages`. `Json` is Prisma's
// DB-portable abstraction: on PostgreSQL it maps to `jsonb`, on MySQL to
// `JSON`, and on SQLite — which is what JobSync ships with today — it
// becomes a plain `TEXT` column. SQLite 3.38+ still exposes the full
// `json_*()` function family over that TEXT blob (indexing, extraction,
// path queries), so the storage choice is semantically equivalent. DB
// tooling (Prisma Studio, sqlite3 .schema, Prisma migration diffs) will
// show the column type as `TEXT` rather than `JSONB`, and that is NOT a
// bug — it is the expected SQLite rendering of Prisma's `Json`.
//
// When JobSync migrates to PostgreSQL (ROADMAP 8.x), these same columns
// will automatically be created as `jsonb` without any schema rewrite. If
// you are debugging a column that appears as TEXT in `sqlite3` but shows
// up as `Json?` in Prisma, look for the `Json?` declaration on the model
// and cross-reference this comment.
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  name                 String
  email                String                @unique
  password             String
  createdAt            DateTime              @default(now())
  deletionScheduledAt  DateTime? // F-4: GDPR cooling-off period target date
  jobsApplied          Job[]
  JobTitle             JobTitle[]
  Location             Location[]
  Company              Company[]
  JobSource            JobSource[]
  Contact              Contact[]
  Profile              Profile[]
  Activity             Activity[]
  ActivityType         ActivityType[]
  Task                 Task[]
  Automation           Automation[]
  Settings             UserSettings?
  ApiKey               ApiKey[]
  Note                 Note[]
  Tag                  Tag[]
  Question             Question[]
  Notification         Notification[]
  StagedVacancy        StagedVacancy[]
  DedupHash            DedupHash[]
  PublicApiKey         PublicApiKey[]
  CompanyBlacklist     CompanyBlacklist[]
  JobStatusHistory     JobStatusHistory[]
  EnrichmentResult     EnrichmentResult[]
  EnrichmentLog        EnrichmentLog[]
  WebhookEndpoint      WebhookEndpoint[]
  smtpConfig           SmtpConfig?
  vapidConfig          VapidConfig?
  webPushSubscriptions WebPushSubscription[]
  LogoAsset            LogoAsset[]
  // CRM Core (specs/crm.allium)
  Person               Person[]
  CrmInterview         CrmInterview[]
  CrmTask              CrmTask[]
  CrmNote              CrmNote[]
  CrmActivityLog       CrmActivityLog[]
  CrmBlocklist         CrmBlocklist[]
  ConnectedAccount     ConnectedAccount[]
  JobContact           JobContact[]
}

model ApiKey {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String    @map("provider")
  encryptedKey String
  iv           String
  last4        String
  label        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastUsedAt   DateTime?

  @@unique([userId, moduleId])
  @@index([userId])
}

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id      String   @id @default(uuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes Resume[]

  @@index([userId])
}

model Resume {
  id             String          @id @default(uuid())
  profileId      String
  title          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ContactInfo    ContactInfo?
  ResumeSections ResumeSection[]
  profile        Profile         @relation(fields: [profileId], references: [id])
  File           File?           @relation(fields: [FileId], references: [id])
  FileId         String?         @unique
  Job            Job[]
  Automation     Automation[]

  @@index([profileId])
}

model File {
  id         String   @id @default(uuid())
  fileName   String
  filePath   String
  fileType   String
  uploadedAt DateTime @default(now())
  Resume     Resume?
}

model ResumeSection {
  id                      String                   @id @default(uuid())
  resumeId                String
  sectionTitle            String
  sectionType             String
  summaryId               String?                  @unique
  summary                 Summary?                 @relation(fields: [summaryId], references: [id])
  workExperiences         WorkExperience[]
  educations              Education[]
  licenseOrCertifications LicenseOrCertification[]
  others                  OtherSection[]
  Resume                  Resume                   @relation(fields: [resumeId], references: [id])

  @@index([resumeId])
}

model ContactInfo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resumeId  String   @unique
  firstName String
  lastName  String
  headline  String
  email     String
  phone     String
  address   String?
  resume    Resume   @relation(fields: [resumeId], references: [id])
}

model Summary {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  content       String
  ResumeSection ResumeSection? @relation
}

model WorkExperience {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  companyId       String
  Company         Company        @relation(fields: [companyId], references: [id])
  jobTitleId      String
  jobTitle        JobTitle       @relation(fields: [jobTitleId], references: [id])
  startDate       DateTime
  endDate         DateTime?
  description     String
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id])
  resumeSectionId String?
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])

  @@index([companyId])
  @@index([jobTitleId])
  @@index([locationId])
  @@index([resumeSectionId])
}

model Education {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  institution     String
  degree          String
  fieldOfStudy    String
  startDate       DateTime
  endDate         DateTime?
  description     String?
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id])
  resumeSectionId String?
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])

  @@index([locationId])
  @@index([resumeSectionId])
}

model LicenseOrCertification {
  id              String         @id @default(uuid())
  title           String
  organization    String
  issueDate       DateTime?
  expirationDate  DateTime?
  credentialUrl   String?
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])
  resumeSectionId String?

  @@index([resumeSectionId])
}

model OtherSection {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  title           String
  content         String
  ResumeSection   ResumeSection? @relation(fields: [resumeSectionId], references: [id])
  resumeSectionId String?

  @@index([resumeSectionId])
}

model Contact {
  id          String     @id @default(uuid())
  name        String
  email       String
  createdAt   DateTime
  createdBy   String // userId
  user        User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  Interview   Interview? @relation(fields: [interviewId], references: [id])
  interviewId String?

  @@index([createdBy])
  @@index([interviewId])
}

model JobTitle {
  id              String           @id @default(uuid())
  label           String
  value           String
  jobs            Job[]
  createdBy       String // userId
  user            User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  workExperiences WorkExperience[]

  @@unique([value, createdBy])
}

model JobStatus {
  id    String @id @default(uuid())
  label String
  value String @unique
  jobs  Job[]

  historyAsPrevious JobStatusHistory[] @relation("PreviousStatus")
  historyAsNew      JobStatusHistory[] @relation("NewStatus")
}

model Location {
  id             String           @id @default(uuid())
  label          String
  value          String
  stateProv      String?
  country        String?
  jobsApplied    Job[]
  createdBy      String // userId
  user           User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  educations     Education[]
  workExperience WorkExperience[]

  @@unique([value, createdBy])
}

model Company {
  id                String             @id @default(uuid())
  label             String
  value             String
  domain            String? // Kette A: Email-Domain→Company Matching (e.g. "acme.com")
  jobsApplied       Job[]
  logoUrl           String? // field is optional
  logoAssetId       String?            @unique
  logoAsset         LogoAsset?         @relation("CompanyActiveLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)
  logoAssets        LogoAsset[]        @relation("LogoAssetCompany")
  createdBy         String // userId
  user              User               @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  workExperiences   WorkExperience[]
  enrichmentResults EnrichmentResult[]
  // CRM back-relations
  crmTaskTargets    CrmTaskTarget[]    @relation("CrmTaskTargetCompany")
  crmNoteTargets    CrmNoteTarget[]    @relation("CrmNoteTargetCompany")
  crmActivityLogs   CrmActivityLog[]   @relation("ActivityLogCompany")

  @@unique([value, createdBy])
}

model JobSource {
  id          String @id @default(uuid())
  label       String
  value       String
  jobsApplied Job[]
  createdBy   String // userId
  user        User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([value, createdBy])
}

model Interview {
  id           String    @id @default(uuid())
  createdAt    DateTime
  jobId        String
  job          Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviewers Contact[]

  @@index([jobId])
}

model Job {
  id          String      @id @default(uuid())
  userId      String
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobUrl      String?
  description String
  jobType     String
  createdAt   DateTime
  applied     Boolean     @default(false)
  appliedDate DateTime?
  dueDate     DateTime?
  statusId    String
  Status      JobStatus   @relation(fields: [statusId], references: [id])
  JobTitle    JobTitle    @relation(fields: [jobTitleId], references: [id])
  jobTitleId  String
  Company     Company     @relation(fields: [companyId], references: [id])
  companyId   String
  JobSource   JobSource?  @relation(fields: [jobSourceId], references: [id])
  jobSourceId String?
  salaryRange String?
  Location    Location?   @relation(fields: [locationId], references: [id])
  locationId  String?
  Interview   Interview[]
  Resume      Resume?     @relation(fields: [resumeId], references: [id])
  resumeId    String?
  Notes       Note[]
  tags        Tag[]

  // CRM fields
  version       Int                @default(0)
  sortOrder     Float              @default(0)
  statusHistory JobStatusHistory[]

  // Automation discovery fields
  automationId    String?
  automation      Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  matchScore      Int?
  matchData       String?
  discoveryStatus String?
  discoveredAt    DateTime?

  // Back-relation from StagedVacancy promotion
  stagedVacancyPromotion StagedVacancy?

  // CRM back-relations
  crmInterviews   CrmInterview[]   @relation("CrmInterviewJob")
  jobContacts     JobContact[]     @relation("JobContactJob")
  crmTaskTargets  CrmTaskTarget[]  @relation("CrmTaskTargetJob")
  crmNoteTargets  CrmNoteTarget[]  @relation("CrmNoteTargetJob")
  crmActivityLogs CrmActivityLog[] @relation("ActivityLogJob")

  @@index([userId, automationId])
  @@index([userId, discoveryStatus])
  @@index([userId, statusId, sortOrder])
  @@index([jobTitleId])
  @@index([companyId])
  @@index([jobSourceId])
  @@index([locationId])
  @@index([resumeId])
  @@index([automationId])
  @@index([statusId])
}

model ActivityType {
  id          String   @id @default(uuid())
  label       String
  value       String
  description String?
  createdBy   String // userId
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Activities Activity[]
  Tasks      Task[]

  @@unique([value, createdBy])
}

model Activity {
  id           String    @id @default(uuid())
  userId       String
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityName String
  startTime    DateTime
  endTime      DateTime?
  duration     Int?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityType   ActivityType @relation(fields: [activityTypeId], references: [id])
  activityTypeId String

  taskId String? @unique
  task   Task?   @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([activityTypeId])
}

model Task {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  status          String    @default("in-progress")
  priority        Int       @default(5)
  percentComplete Int       @default(0)
  dueDate         DateTime?

  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])

  activity Activity?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, activityTypeId])
  @@index([userId, dueDate])
}

model Automation {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  jobBoard        String
  keywords        String
  location        String
  connectorParams String?
  resumeId        String
  resume          Resume  @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  matchThreshold  Int     @default(80)

  scheduleHour      Int
  scheduleFrequency String    @default("daily")
  nextRunAt         DateTime?
  lastRunAt         DateTime?

  status      String  @default("active")
  pauseReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs            AutomationRun[]
  discoveredJobs  Job[]
  stagedVacancies StagedVacancy[]

  @@index([userId])
  @@index([status, nextRunAt])
  @@index([resumeId])
}

model AutomationRun {
  id           String     @id @default(uuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  jobsSearched     Int @default(0)
  jobsDeduplicated Int @default(0)
  jobsProcessed    Int @default(0)
  jobsMatched      Int @default(0)
  jobsSaved        Int @default(0)

  status        String  @default("running")
  runSource     String  @default("scheduler")
  errorMessage  String?
  blockedReason String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([automationId])
  @@index([startedAt])
}

model ModuleRegistration {
  id            String    @id @default(uuid())
  moduleId      String    @unique
  connectorType String
  status        String    @default("active")
  healthStatus  String    @default("unknown")
  activatedAt   DateTime?
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([moduleId])
  @@index([connectorType, status])
}

model Notification {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  message      String
  moduleId     String?
  automationId String?
  data         Json?
  // 5W+H structured notification fields (ADR-030)
  // Promoted from Notification.data JSON during the Prisma migration sprint.
  // Legacy `data.*` writers continue to work during rollout via fallback.
  severity     String? // "info" | "success" | "warning" | "error"
  actorType    String? // "module" | "automation" | "system" | "user"
  actorId      String? // e.g. "eures", "arbeitsagentur", or a user id
  titleKey     String? // i18n key for the notification title (late-bound at render time)
  titleParams  Json? // { moduleName: "EURES", count: 5, ... }
  reasonKey    String? // optional i18n key for the reason/context line
  reasonParams Json? // params for reasonKey
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model StagedVacancy {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Discovery identity (dedup key)
  sourceBoard String
  externalId  String?
  sourceUrl   String?

  // Vacancy data
  title                   String
  employerName            String?
  location                String?
  description             String?
  salary                  String?
  employmentType          String?
  postedAt                DateTime?
  applicationDeadline     String?
  applicationInstructions String?

  // Extended vacancy data (ROADMAP 1.1b Phase 1)
  companyUrl              String?
  companyDescription      String?
  industryCodes           Json? // string[] — NACE sector codes
  companySize             String?
  positionOfferingCode    String? // apprenticeship, contract, directhire, internship, etc.
  numberOfPosts           Int?
  occupationUris          Json? // string[] — ESCO Occupation URIs
  requiredEducationLevel  String? // basic, medium, bachelor, master, tertiary, doctoral
  requiredExperienceYears Int?
  workingLanguages        Json? // string[] — ISO 639-1 codes
  salaryMin               Float?
  salaryMax               Float?
  salaryCurrency          String? // ISO 4217 (EUR, USD, etc.)
  salaryPeriod            String? // monthly, yearly, hourly
  immediateStart          Boolean?
  contractStartDate       String?
  contractEndDate         String?
  euresFlag               Boolean?

  // Source tracking
  source       String      @default("automation") // "manual" | "automation"
  automationId String?
  automation   Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)

  // Match data (optional)
  matchScore Int?
  matchData  String?

  // Pipeline state
  status String @default("staged")

  // Promotion link
  promotedToJobId String? @unique
  promotedJob     Job?    @relation(fields: [promotedToJobId], references: [id], onDelete: SetNull)

  // Archive / Trash
  archivedAt DateTime?
  trashedAt  DateTime?

  // Timestamps
  discoveredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, sourceBoard, externalId])
  @@index([userId, status])
  @@index([userId, automationId])
  @@index([userId, createdAt])
  @@index([userId, trashedAt])
  // Accelerates CompanyBlacklist retroactive-trash updateMany (Sprint 2 Stream C H-P-02).
  // Satisfies the (userId = ? AND employerName = ?) and (userId = ? AND employerName LIKE 'x%')
  // seeks emitted by the `exact` and `starts_with` match types; `contains`/`ends_with`
  // still scan but only over (userId, employerName) b-tree leaves instead of heap pages.
  @@index([userId, employerName])
  // Sprint 5 Stream D — close Sprint 3 Stream D deferred item: getStagedVacancies
  // sorts ORDER BY discoveredAt DESC and the existing (userId, createdAt) index
  // does not match. A dedicated (userId, discoveredAt) composite lets the
  // staging list query be served as an index range scan instead of a heap sort.
  // discoveredAt and createdAt usually agree, but the spec uses discoveredAt as
  // the ordering key (specs/staging-deck.allium) so the index must match.
  @@index([userId, discoveredAt])
}

model DedupHash {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash        String
  sourceBoard String
  createdAt   DateTime @default(now())

  @@unique([userId, hash])
  @@index([userId, sourceBoard])
}

model Note {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([userId])
}

model CompanyBlacklist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern   String
  matchType String   @default("contains") // "exact" | "contains" | "starts_with" | "ends_with"
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pattern, matchType])
  @@index([userId])
}

model Tag {
  id        String     @id @default(uuid())
  label     String
  value     String
  createdBy String
  user      User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  jobs      Job[]
  questions Question[]

  @@unique([value, createdBy])
}

model Question {
  id        String   @id @default(uuid())
  question  String
  answer    String?
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
}

model PublicApiKey {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyPrefix   String
  permissions String    @default("[]")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([userId])
}

model JobStatusHistory {
  id               String     @id @default(cuid())
  jobId            String
  job              Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousStatusId String?
  previousStatus   JobStatus? @relation("PreviousStatus", fields: [previousStatusId], references: [id])
  newStatusId      String
  newStatus        JobStatus  @relation("NewStatus", fields: [newStatusId], references: [id])
  note             String?
  changedAt        DateTime   @default(now())

  @@index([jobId, changedAt])
  @@index([userId, changedAt])
  @@index([jobId, userId])
  @@index([previousStatusId])
  @@index([newStatusId])
}

model EnrichmentResult {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimension      String
  domainKey      String
  companyId      String?
  company        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  status         String
  data           String
  sourceModuleId String
  ttlSeconds     Int
  expiresAt      DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  logs           EnrichmentLog[]

  @@unique([userId, dimension, domainKey])
  @@index([userId, dimension, status])
  @@index([expiresAt])
  @@index([companyId])
}

model EnrichmentLog {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrichmentResultId String?
  enrichmentResult   EnrichmentResult? @relation(fields: [enrichmentResultId], references: [id], onDelete: SetNull)
  dimension          String
  domainKey          String
  moduleId           String
  chainPosition      Int
  outcome            String
  latencyMs          Int
  errorMessage       String?
  createdAt          DateTime          @default(now())

  @@index([userId, dimension, domainKey])
  @@index([moduleId, outcome])
  @@index([createdAt])
  @@index([enrichmentResultId])
}

model WebhookEndpoint {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  secret       String // AES-encrypted HMAC secret
  iv           String // IV for AES decryption
  events       String // JSON array of NotificationType values
  active       Boolean  @default(true)
  failureCount Int      @default(0) // consecutive failures for auto-deactivation
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, active])
}

model VapidConfig {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKey  String
  privateKey String // AES-encrypted
  iv         String // IV for AES decryption
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WebPushSubscription {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint       String
  p256dh         String // AES-encrypted
  auth           String // AES-encrypted
  iv             String // IV for AES decryption (shared for p256dh + auth)
  expirationTime DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
}

model SmtpConfig {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  host        String
  port        Int      @default(587)
  username    String
  password    String // AES-encrypted via src/lib/encryption.ts
  iv          String // IV for AES decryption
  fromAddress String
  tlsRequired Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model LogoAsset {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company  @relation("LogoAssetCompany", fields: [companyId], references: [id], onDelete: Cascade)
  sourceUrl    String
  filePath     String
  mimeType     String
  fileSize     Int
  width        Int?
  height       Int?
  status       String   @default("pending") // "pending" | "ready" | "failed"
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activeOnCompany Company? @relation("CompanyActiveLogo")

  @@unique([userId, companyId])
  @@index([userId, status])
  @@index([companyId])
}

/// Sprint 5 Stream D — closes Sprint 1.5 CRIT-S-04 deferred item.
///
/// Append-only audit trail for admin-only actions (module activate/deactivate
/// today, more system-toggle actions in the future). The hotfix that introduced
/// `writeAdminAuditLog()` in src/lib/auth/admin.ts could only emit a JSON line
/// to stderr because the hotfix pipeline could not run migrations. This model
/// promotes the same schema to a Prisma table so audit entries become
/// queryable for the admin review UI and for retention sweeps.
///
/// Design notes:
/// - NO foreign key to User: an admin's actions must remain in the audit log
///   even after the actor has been deleted (forensic durability). `actorId` is
///   stored as a bare String. The matching `actorEmail` is denormalised so the
///   audit row is self-contained when the User row is gone.
/// - The structured stderr line in `writeAdminAuditLog()` is kept as the
///   "always available" port (Hexagonal Architecture). This Prisma model is
///   the convenience adapter for queries — if the DB write fails, the stderr
///   line is still the source of truth, so we never lose a row.
/// - SQLite has no jsonb. The optional `extra` column stores a JSON string;
///   readers must `JSON.parse()` it. Same convention as `Notification.data`.
/// - Spec: specs/module-lifecycle.allium invariant `AdminOnlyModuleLifecycle`.
model AdminAuditLog {
  id         String   @id @default(cuid())
  /// Maps to the legacy `ts` field in the stderr JSON line.
  timestamp  DateTime @default(now())
  /// Action verb, e.g. "activateModule" / "deactivateModule".
  action     String
  /// Optional target identifier (module id, automation id, job id, person id …).
  targetId   String?
  /// Discriminates the kind of entity `targetId` points at (Welle 1 / IF-S6).
  /// "module" | "automation" | "job" | "person" | "company". Nullable so legacy
  /// admin rows (pre-extension) and rows where the kind is implied by `action`
  /// remain valid. Spec: specs/audit-trail.allium (AuditTargetType).
  targetType String?
  /// Required: id of the user who attempted the action. NOT a foreign key —
  /// see model docstring for the reason.
  actorId    String
  /// Denormalised actor email for audit-readability after user deletion.
  actorEmail String?
  /// Did the call succeed (true) or get denied (false).
  allowed    Boolean
  /// Which authorization tier matched: "explicit_list" / "single_user_implicit"
  /// / "denied". Mirrors `AdminAuthorizationResult.tier`.
  tier       String?
  /// Generic deny-reason key when `allowed = false`, e.g. "errors.notAuthorized".
  reason     String?
  /// JSON-encoded blob for any additional structured context the caller
  /// attached via `AdminAuditContext.extra`. SQLite has no jsonb so we store a
  /// string and parse on read.
  extra      String?

  /// Per-user audit queries (admin review UI: "show all actions by user X").
  @@index([actorId, timestamp])
  /// Retention sweep ("delete entries older than N days").
  @@index([timestamp])
}

// =============================================================================
// CRM Core Models (specs/crm.allium)
// =============================================================================

/// CRM contact entity — a recruiter, hiring manager, referral, or other
/// person the user interacts with during their job search.
/// Independent aggregate root, NOT part of the Job aggregate.
/// Spec: specs/crm.allium entity Person
model Person {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // FullName (value object, flattened — both nullable for anonymization)
  firstName String?
  lastName  String?

  // TypedEmail[] and TypedPhone[] stored as JSON strings (SQLite TEXT)
  // Shape: [{ email: string, type: "work"|"home"|"other", isPrimary: boolean }]
  emails String @default("[]")
  // Shape: [{ number: string, type: "work"|"home"|"other", isPrimary: boolean }]
  phones String @default("[]")

  // Professional — Kette B: job_title→headline, linkedin_url→social_profiles
  headline       String?
  socialProfiles String  @default("[]") // JSON: SocialProfile[]
  avatarUrl      String?

  // Address (value object, flattened)
  addressStreet     String?
  addressCity       String?
  addressPostalCode String?
  addressCountry         String?
  addressCountryCode     String?
  addressSubdivisionCode String?

  // Company associations (N:M via JSON value objects — specs/crm.allium CompanyAssociation)
  // Shape: [{ companyId, companyLabel, role, isPrimary, startDate, endDate }]
  companies String @default("[]")

  // Status state machine: active -> archived -> (active), active -> anonymized (terminal)
  status String @default("active")

  // GDPR fields (specs/crm-gdpr.allium)
  dataSource         String    @default("manual")
  processingBasis    String    @default("legitimate_interest")
  retentionExpiresAt DateTime?

  // Actor metadata — who/what created/updated this record (Kette A: updated_by)
  createdBySource String  @default("manual")
  createdByName   String?
  updatedBySource String  @default("manual")
  updatedByName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CRM relations
  crmInterviews  CrmInterview[]
  jobContacts    JobContact[]
  crmTaskTargets CrmTaskTarget[]
  crmNoteTargets CrmNoteTarget[]
  activityLogs   CrmActivityLog[] @relation("ActivityLogPerson")

  @@index([userId])
  @@index([userId, status])
}

/// A scheduled or completed interview linked to a Job and optionally to a Person.
/// Status machine: scheduled -> completed|cancelled|rescheduled,
///                 rescheduled -> completed|cancelled
/// Spec: specs/crm.allium entity Interview
model CrmInterview {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job      @relation("CrmInterviewJob", fields: [jobId], references: [id], onDelete: Cascade)
  personId      String?
  person        Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  interviewDate DateTime
  location      String?
  notes         String?
  status        String   @default("scheduled")
  outcome       String?
  outcomeNotes  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([userId, jobId])
  @@index([userId, status])
  @@index([userId, interviewDate])
}

/// Kette C: Links a Person to a Job as a contact/stakeholder (N:M).
/// One Job can have multiple contact persons (recruiter, hiring manager, referral),
/// and one Person can be the contact for multiple Jobs.
/// Spec: specs/crm.allium entity JobContact
model JobContact {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation("JobContactJob", fields: [jobId], references: [id], onDelete: Cascade)
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  role      String?
  createdAt DateTime @default(now())

  @@unique([jobId, personId])
  @@index([userId])
  @@index([personId])
  @@index([jobId])
}

/// A to-do item linked to CRM entities via polymorphic CrmTaskTarget.
/// Status machine: pending -> in_progress|done|cancelled,
///                 in_progress -> done|cancelled
/// Spec: specs/crm.allium entity Task
model CrmTask {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  targets CrmTaskTarget[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
}

/// Polymorphic join: exactly one of targetPersonId/targetCompanyId/targetJobId
/// must be set (ExactlyOneTaskTarget invariant, enforced at app level).
/// Spec: specs/crm.allium entity TaskTarget
model CrmTaskTarget {
  id              String   @id @default(uuid())
  taskId          String
  task            CrmTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  targetPersonId  String?
  targetPerson    Person?  @relation(fields: [targetPersonId], references: [id], onDelete: Cascade)
  targetCompanyId String?
  targetCompany   Company? @relation("CrmTaskTargetCompany", fields: [targetCompanyId], references: [id], onDelete: Cascade)
  targetJobId     String?
  targetJob       Job?     @relation("CrmTaskTargetJob", fields: [targetJobId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([targetPersonId])
  @@index([targetCompanyId])
  @@index([targetJobId])
}

/// Free-text note linked to CRM entities via polymorphic CrmNoteTarget.
/// Spec: specs/crm.allium entity Note
model CrmNote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targets CrmNoteTarget[]

  @@index([userId])
}

/// Polymorphic join: exactly one of targetPersonId/targetCompanyId/targetJobId
/// must be set (ExactlyOneNoteTarget invariant, enforced at app level).
/// Spec: specs/crm.allium entity NoteTarget
model CrmNoteTarget {
  id              String   @id @default(uuid())
  noteId          String
  note            CrmNote  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  targetPersonId  String?
  targetPerson    Person?  @relation(fields: [targetPersonId], references: [id], onDelete: Cascade)
  targetCompanyId String?
  targetCompany   Company? @relation("CrmNoteTargetCompany", fields: [targetCompanyId], references: [id], onDelete: Cascade)
  targetJobId     String?
  targetJob       Job?     @relation("CrmNoteTargetJob", fields: [targetJobId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([targetPersonId])
  @@index([targetCompanyId])
  @@index([targetJobId])
}

/// Immutable timeline entry. Materialized read model projected from domain
/// events, never updated after creation.
/// Spec: specs/crm.allium entity ActivityLog + contract TimelineProjection
model CrmActivityLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityType     String
  happenedAt       DateTime @default(now())
  actorId          String?
  targetPersonId   String?
  targetPerson     Person?  @relation("ActivityLogPerson", fields: [targetPersonId], references: [id], onDelete: SetNull)
  targetCompanyId  String?
  targetCompany    Company? @relation("ActivityLogCompany", fields: [targetCompanyId], references: [id], onDelete: SetNull)
  targetJobId      String?
  targetJob        Job?     @relation("ActivityLogJob", fields: [targetJobId], references: [id], onDelete: SetNull)
  details          String?
  linkedRecordName String?

  @@index([userId, happenedAt])
  @@index([targetPersonId, happenedAt])
  @@index([targetJobId, happenedAt])
  @@index([userId, activityType])
  @@index([targetCompanyId])
}

/// Suppresses Person auto-creation for specific handles during email/calendar sync.
/// Spec: specs/crm.allium entity Blocklist
model CrmBlocklist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  handle    String
  type      String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([userId, handle])
  @@index([userId])
  @@index([userId, type])
}

/// OAuth connection for future email/calendar sync (ROADMAP 1.7/1.12).
/// Structural only — no rules govern this entity yet.
/// Spec: specs/crm.allium entity ConnectedAccount
model ConnectedAccount {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String
  handle        String
  accessToken   String
  refreshToken  String?
  iv            String
  isSyncEnabled Boolean   @default(false)
  lastSyncedAt  DateTime?
  authFailedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, provider, handle])
  @@index([userId])
}

/// F-2: Email confirmation token for account deletion.
/// Single-use, 24h TTL. At most one active token per user.
/// No FK to User (forensic durability pattern, same as AdminAuditLog).
model DeletionConfirmationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
