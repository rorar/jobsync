-- allium: 3

-- JobSync Domain Specification
-- A job search management application with automation, activity tracking, and AI matching.

-- =============================================================================
-- External Entities
-- =============================================================================

-- External system: JSearch job board API
external entity JSearchAPI {
    query: String
    location: String
    date_posted: String                     -- e.g. "week"
    page: Integer
}

-- External system: EURES job portal API (European Employment Services)
external entity EuresAPI {
    base_url: String
    -- No API key required (public API)
    -- Returns: vacancy listings with multilingual titles, descriptions, employer info
    -- Filters: keywords, location (NUTS codes), occupation codes, contract type
}

-- External system: LLM module for AI matching
external entity LLMModule {
    module_id: ollama | openai | deepseek
    model: String
    prompt: String
    resume_content: String
    job_description: String
}

-- =============================================================================
-- Value Types
-- =============================================================================

value ContactInfo {
    first_name: String
    last_name: String
    headline: String
    email: String
    phone: String
    address: String?
}

value Summary {
    content: String
}

-- Canonical domain type: what "a job discovered by automation" means in JobSync
value DiscoveredVacancy {
    title: String
    employer_name: String
    location: String
    description: String                     -- plain text, HTML stripped
    source_url: String
    source_board: String                    -- connector id
    posted_at: Timestamp?
    salary: String?
    employment_type: full_time | part_time | contract
    external_id: String?                    -- source system's native ID for dedup
    application_deadline: String?           -- ISO date, e.g. "2025-06-30"
    application_instructions: String?       -- plain text, HTML stripped
}

value SearchParams {
    keywords: String
    location: String
    connector_params: String?              -- JSON blob for module-specific config
}

value ConnectorError {
    type: blocked | rate_limited | network | parse
    reason: String?                        -- present when type = blocked
    message: String?                       -- present when type = network | parse
    retry_after: Integer?                  -- present when type = rate_limited
}

-- =============================================================================
-- Contracts
-- =============================================================================

-- Behavioral interface: each data source implements this contract
contract DataSourceConnector {
    search: (params: SearchParams) -> Set<DiscoveredVacancy>
    get_details: (external_id: String) -> DiscoveredVacancy

    @invariant ConnectorIdentity
        -- Each connector has a unique id, display name, and declares
        -- whether it requires an API key.

    @guidance
        -- Connectors translate external API responses to DiscoveredVacancy
        -- values. They implement resilience (circuit breaker, retry) and
        -- return ConnectorError on failure rather than raw exceptions.
}

-- =============================================================================
-- Enumerations
-- =============================================================================

enum JobStatusValue { bookmarked | applied | interview | offer | rejected | withdrawn | archived }
enum JobSourceValue { linkedin | indeed | glassdoor | company_website | referral | eures | other }
enum SectionType { summary | experience | education | license | other }
enum EmploymentType { full_time | part_time | contract }
enum DiscoveryStatus { new | accepted | dismissed }
enum TaskStatus { in_progress | complete | needs_attention | cancelled }
enum AutomationStatus { active | paused }
enum RunStatus { running | completed | failed | completed_with_errors | blocked | rate_limited }

-- =============================================================================
-- Entities and Variants
-- =============================================================================

------------------------------------------------------------
-- Bounded Context: Identity & Tenant Isolation
------------------------------------------------------------

entity User {
    name: String
    email: String                           -- unique
    password: String                        -- bcrypt hashed
    created_at: Timestamp

    -- relationships
    settings: UserSettings with user = this
    profile: Profile with user = this
    jobs: Job with user = this
    tasks: Task with user = this
    activities: Activity with user = this
    automations: Automation with user = this
    contacts: Contact with created_by = this
    companies: Company with created_by = this
    job_titles: JobTitle with created_by = this
    locations: Location with created_by = this
    activity_types: ActivityType with created_by = this
}

entity UserSettings {
    user: User                              -- 1:1
    settings_json: String                   -- JSON blob
    created_at: Timestamp
    updated_at: Timestamp
}

------------------------------------------------------------
-- Bounded Context: Resume & Profile
------------------------------------------------------------

entity Profile {
    user: User                              -- 1:1 via userId
    resumes: Resume with profile = this
}

entity Resume {
    profile: Profile
    title: String
    file: File?                             -- 1:1 optional attachment
    contact_info: ContactInfo?              -- 1:1 optional embedded value
    sections: ResumeSection with resume = this
    created_at: Timestamp
    updated_at: Timestamp
}

entity File {
    file_name: String
    file_path: String
    file_type: String
    uploaded_at: Timestamp
    resume: Resume?                         -- 1:1 back-reference
}

entity ResumeSection {
    resume: Resume
    section_title: String
    section_type: SectionType
    summary: Summary?                       -- 1:1 optional embedded value
    work_experiences: WorkExperience with section = this
    educations: Education with section = this
    license_or_certifications: LicenseOrCertification with section = this
    others: OtherSection with section = this
}

entity WorkExperience {
    section: ResumeSection?
    company: Company
    job_title: JobTitle
    start_date: Timestamp
    end_date: Timestamp?
    description: String
    location: Location
    created_at: Timestamp
    updated_at: Timestamp
}

entity Education {
    section: ResumeSection?
    institution: String
    degree: String
    field_of_study: String
    start_date: Timestamp
    end_date: Timestamp?
    description: String?
    location: Location
    created_at: Timestamp
    updated_at: Timestamp
}

entity LicenseOrCertification {
    section: ResumeSection?
    title: String
    organization: String
    issue_date: Timestamp?
    expiration_date: Timestamp?
    credential_url: String?
}

entity OtherSection {
    section: ResumeSection?
    title: String
    content: String
    created_at: Timestamp
    updated_at: Timestamp
}

------------------------------------------------------------
-- Bounded Context: Reference Data (user-scoped lookups)
------------------------------------------------------------

entity Company {
    label: String
    value: String                           -- unique per user
    logo_url: String?
    created_by: User
    jobs: Job with company = this
    work_experiences: WorkExperience with company = this
}

entity JobTitle {
    label: String
    value: String                           -- unique (see open question below)
    created_by: User
    jobs: Job with job_title = this
    work_experiences: WorkExperience with job_title = this
}

entity Location {
    label: String
    value: String
    state_prov: String?
    country: String?
    created_by: User
    jobs: Job with location = this
    educations: Education with location = this
    work_experiences: WorkExperience with location = this
}

entity ActivityType {
    label: String
    value: String                           -- unique
    description: String?
    created_by: User
    activities: Activity with activity_type = this
    tasks: Task with activity_type = this
    created_at: Timestamp
    updated_at: Timestamp
}

------------------------------------------------------------
-- Bounded Context: Job Board (pre-seeded reference enums)
------------------------------------------------------------

-- Pre-seeded in database; not user-scoped. Acts as enum tables.

entity JobStatus {
    label: String
    value: JobStatusValue
    jobs: Job with status = this
}

entity JobSource {
    label: String
    value: JobSourceValue
    jobs: Job with source = this
}

------------------------------------------------------------
-- Bounded Context: Job Tracking
------------------------------------------------------------

entity Job {
    user: User
    description: String
    job_type: EmploymentType
    applied: Boolean = false
    applied_date: Timestamp?
    due_date: Timestamp?
    job_url: String?
    salary_range: String?
    created_at: Timestamp

    -- relationships
    status: JobStatus
    job_title: JobTitle
    company: Company
    location: Location?
    source: JobSource?
    resume: Resume?
    interviews: Interview with job = this

    -- automation discovery fields
    automation: Automation?
    match_score: Integer?
    match_data: String?                     -- JSON string with match reasoning
    discovery_status: DiscoveryStatus
    discovered_at: Timestamp?

    -- derived
    is_discovered: automation != null       -- true when found by automation
}

entity Interview {
    created_at: Timestamp
    job: Job
    interviewers: Contact with interview = this
}

entity Contact {
    name: String
    email: String
    created_by: User
    created_at: Timestamp
    interview: Interview?
}

------------------------------------------------------------
-- Bounded Context: Task & Activity Management
------------------------------------------------------------

entity Task {
    user: User
    title: String
    description: String?
    status: TaskStatus
    priority: Integer = 5
    percent_complete: Integer = 0
    due_date: Timestamp?
    activity_type: ActivityType?
    activity: Activity?                     -- 1:1 optional link
    created_at: Timestamp
    updated_at: Timestamp
}

entity Activity {
    user: User
    activity_name: String
    start_time: Timestamp
    end_time: Timestamp?
    duration: Integer?                      -- minutes
    description: String?
    activity_type: ActivityType
    task: Task?                             -- 1:1 optional link via taskId
    created_at: Timestamp
    updated_at: Timestamp

    -- derived
    is_running: end_time = null
}

------------------------------------------------------------
-- Bounded Context: Automation & Discovery
------------------------------------------------------------

entity Automation {
    user: User
    name: String
    job_board: jsearch | eures
    keywords: String
    location: String
    connector_params: String?               -- JSON blob for module-specific search config
    resume: Resume
    match_threshold: Integer = 80           -- 0-100
    schedule_hour: Integer                  -- hour of day (0-23)
    next_run_at: Timestamp?
    last_run_at: Timestamp?
    status: AutomationStatus
    runs: AutomationRun with automation = this
    discovered_jobs: Job with automation = this
    created_at: Timestamp
    updated_at: Timestamp
}

entity AutomationRun {
    automation: Automation                  -- cascade delete
    jobs_searched: Integer = 0
    jobs_deduplicated: Integer = 0
    jobs_processed: Integer = 0
    jobs_matched: Integer = 0
    jobs_saved: Integer = 0
    status: RunStatus
    error_message: String?
    blocked_reason: String?
    started_at: Timestamp
    completed_at: Timestamp?
}

-- =============================================================================
-- Config
-- =============================================================================

config {
    records_per_page: Integer = 25
    activity_max_duration_minutes: Integer = 480
    scheduler_cron: String = "0 * * * *"
    max_automations_per_user: Integer = 10
    max_jobs_per_automation_run: Integer = 10
    ai_rate_limit_per_minute: Integer = 5
    automation_manual_run_limit_per_hour: Integer = 5
}

-- =============================================================================
-- Rules: Authentication & Isolation
-- =============================================================================

rule UserRegistration {
    when: RegisterRequest(name, email, password)
    requires: not exists User{email: email}
    ensures: User.created(name: name, email: email, password: hash(password), created_at: now)
}

rule UserLogin {
    when: LoginRequest(email, password)
    let user = User{email: email}
    requires: exists user
    requires: verify(password, user.password)
    ensures: SessionCreated(user: user)
}

rule TenantIsolation {
    -- The system filters all data queries by the authenticated user's id.
    when: DataQuery(user, entity_type)
    ensures: DataFiltered(user: user, entity_type: entity_type)

    @guidance
        -- Every Prisma read/write MUST include userId in the where clause.
        -- Never query by resource ID alone. See ADR-015.
}

-- =============================================================================
-- Rules: Job Status Transitions
-- =============================================================================

rule JobAppliedTransition {
    -- When a job's status transitions to "applied", set applied=true and applied_date=now.
    when: job: Job.status.value transitions_to applied
    ensures:
        job.applied = true
        job.applied_date = now
}

rule JobInterviewTransition {
    -- When a job's status transitions to "interview", set applied=true.
    -- The system does not overwrite an existing applied_date.
    when: job: Job.status.value transitions_to interview
    ensures: job.applied = true
}

-- =============================================================================
-- Rules: Activity Management
-- =============================================================================

rule ActivityMutualExclusion {
    -- The system rejects starting a new activity when another is already running for the same user.
    when: StartActivity(user, activity_name, activity_type)
    let running = Activity{user: user}
    requires: not exists running or not running.is_running
    ensures: Activity.created(
        user: user,
        activity_name: activity_name,
        activity_type: activity_type,
        start_time: now,
        end_time: null
    )
}

rule ActivityMaxDuration {
    -- When an activity exceeds the max duration, auto-stop it.
    when: activity: Activity.start_time + config.activity_max_duration_minutes.minutes <= now
    requires: activity.is_running
    ensures:
        activity.end_time = activity.start_time + config.activity_max_duration_minutes.minutes
        activity.duration = config.activity_max_duration_minutes
}

rule ActivityCloneOnStart {
    -- When a user "starts" an existing activity, create a new activity
    -- cloned from the original (same name, type, description) with start_time=now.
    when: StartExistingActivity(user, source)
    requires: source.end_time != null
    ensures: Activity.created(
        user: user,
        activity_name: source.activity_name,
        activity_type: source.activity_type,
        description: source.description,
        start_time: now,
        end_time: null
    )
}

rule ActivityStop {
    -- When a user stops a running activity, set end_time to now.
    when: StopActivity(activity)
    requires: activity.is_running
    ensures: activity.end_time = now
}

-- =============================================================================
-- Rules: Task Management
-- =============================================================================

rule TaskStartActivity {
    -- When a user starts an activity from a task, verify preconditions and create activity.
    when: StartActivityFromTask(user, task)
    requires: task.activity_type != null
    requires: task.activity = null
    requires: task.status != complete
    requires: task.status != cancelled
    ensures: Activity.created(
        user: user,
        activity_name: task.title,
        activity_type: task.activity_type,
        task: task,
        start_time: now,
        end_time: null
    )
}

rule TaskDeletionGuard {
    -- If a task has a linked activity, reject deletion.
    when: DeleteTask(task)
    requires: task.activity = null
    ensures: not exists task
}

-- =============================================================================
-- Rules: Connector Dispatch
-- =============================================================================

rule ConnectorDispatch {
    -- When an automation run searches for jobs, resolve the connector
    -- from the registry using automation.job_board, not import directly.
    when: AutomationRunTriggered(automation)
    ensures: ConnectorSearchRequested(
        job_board: automation.job_board,
        keywords: automation.keywords,
        location: automation.location,
        connector_params: automation.connector_params
    )

    @guidance
        -- The connector is resolved from the registry at runtime.
        -- See ConnectorRegistry.resolve(automation.jobBoard).
}

-- =============================================================================
-- Rules: Automation & Discovery
-- =============================================================================

rule AutomationLimit {
    -- The system rejects creating an automation when the user has reached the limit.
    when: CreateAutomation(user, name, job_board, keywords, location, resume)
    requires: user.automations.count < config.max_automations_per_user
    ensures: Automation.created(
        user: user,
        name: name,
        job_board: job_board,
        keywords: keywords,
        location: location,
        resume: resume,
        status: active,
        created_at: now,
        updated_at: now
    )
}

rule AutomationScheduler {
    -- When an active automation's next_run_at passes, trigger a run.
    when: automation: Automation.next_run_at <= now
    requires: automation.status = active
    requires: automation.resume != null
    ensures: AutomationRunTriggered(automation: automation)
}

rule AutomationRunFlow {
    -- When an automation run is triggered, execute the discovery pipeline.
    when: AutomationRunTriggered(automation)
    ensures:
        AutomationRun.created(
            automation: automation,
            status: running,
            started_at: now
        )
        automation.last_run_at = now
        automation.next_run_at = next_schedule_time(automation.schedule_hour)

    @guidance
        -- Pipeline steps:
        -- 1. Search via connector (resolved from automation.job_board)
        -- 2. Deduplicate against existing job URLs (normalized)
        -- 3. Cap at config.max_jobs_per_automation_run
        -- 4. Score each job via LLM
        -- 5. Filter by match_threshold
        -- 6. Save matched jobs with discovery_status = new
        -- Run status set to completed/failed/completed_with_errors/blocked/rate_limited.
}

rule AutomationPause {
    -- When an automation is paused, clear next_run_at.
    when: PauseAutomation(automation)
    requires: automation.status = active
    ensures:
        automation.status = paused
        automation.next_run_at = null
}

rule AutomationResume {
    -- When an automation is resumed, recalculate next_run_at from schedule_hour.
    when: ResumeAutomation(automation)
    requires: automation.status = paused
    ensures:
        automation.status = active
        automation.next_run_at = next_schedule_time(automation.schedule_hour)
}

rule DiscoveredJobTriage {
    -- When a user triages a discovered job, update discovery_status.
    when: TriageDiscoveredJob(job, decision)
    requires: job.discovery_status = new
    requires: decision = accepted or decision = dismissed
    ensures: job.discovery_status = decision
}

-- =============================================================================
-- Rules: Rate Limiting
-- =============================================================================

rule AutomationManualRunRateLimit {
    -- When a user triggers a manual run, enforce rate limiting
    -- and delegate to the standard run flow.
    when: TriggerRun(automation)
    let recent_runs = automation.runs where started_at > now - 1.hour
    requires: recent_runs.count < config.automation_manual_run_limit_per_hour
    ensures: AutomationRunTriggered(automation: automation)
}

rule AIRateLimit {
    -- The system limits AI endpoint requests per user per minute.
    when: AIRequest(user)
    ensures: AIRequestProcessed(user: user)

    @guidance
        -- Rate limiting is enforced by the inbound rate-limit factory
        -- at the server action boundary. See src/lib/rate-limit.ts.
        -- Limit: config.ai_rate_limit_per_minute requests per minute per user.
}

-- =============================================================================
-- Rules: AI Features
-- =============================================================================

rule AIResumeReview {
    -- When a user requests an AI resume review, stream LLM analysis.
    when: RequestAIReview(user, resume)
    requires: resume.profile.user = user
    ensures: StreamingLLMResponse(resume: resume)
}

rule AIJobMatch {
    -- When a user requests a job match score, return a 0-100 score with reasoning.
    when: RequestJobMatch(user, resume, job_description)
    requires: resume.profile.user = user
    ensures: MatchResult(resume: resume, job_description: job_description)

    @guidance
        -- Returns a score (0-100) and reasoning string from the LLM module.
}

-- =============================================================================
-- Rules: Export
-- =============================================================================

rule JobExport {
    -- When a user exports jobs, generate a CSV of all their jobs.
    when: ExportJobs(user)
    ensures: CSVGenerated(user: user)
}

-- =============================================================================
-- Surfaces
-- =============================================================================

surface AuthSurface {
    facing visitor: User

    provides:
        RegisterRequest(visitor)
        LoginRequest(visitor)

    @guidance
        -- Visitor is unauthenticated. The facing type is User because
        -- registration creates a User and login authenticates one.
}

surface DashboardSurface {
    facing viewer: User

    exposes:
        viewer.jobs
        viewer.activities

    related:
        JobListSurface(viewer)
        TaskListSurface(viewer)
        ActivityListSurface(viewer)
}

surface JobListSurface {
    facing viewer: User

    exposes:
        viewer.jobs

    provides:
        AddJob(viewer)
        UpdateJob(viewer)
        DeleteJob(viewer)
        ExportJobs(viewer)

    related:
        JobDetailSurface(viewer)
}

surface JobDetailSurface {
    facing viewer: User
    context job: Job where user = viewer

    exposes:
        job.description
        job.company
        job.job_title
        job.location
        job.source
        job.resume
        job.interviews
        job.match_score
        job.match_data

    related:
        JobListSurface(viewer)
        JobMatchSurface(job)
}

surface AutomationListSurface {
    facing viewer: User

    exposes:
        viewer.automations

    provides:
        CreateAutomation(viewer)
        PauseAutomation(viewer)
        ResumeAutomation(viewer)
        TriggerRun(viewer)

    related:
        AutomationDetailSurface(viewer)
}

surface AutomationDetailSurface {
    facing viewer: User
    context automation: Automation where user = viewer

    exposes:
        automation.name
        automation.status
        automation.runs
        automation.discovered_jobs

    provides:
        TriggerRun(automation)
        TriageDiscoveredJob(automation)
}

surface TaskListSurface {
    facing viewer: User

    exposes:
        viewer.tasks

    provides:
        StartActivityFromTask(viewer)
        DeleteTask(viewer)

    related:
        ActivityListSurface(viewer)
}

surface ActivityListSurface {
    facing viewer: User

    exposes:
        viewer.activities

    provides:
        StartActivity(viewer)
        StopActivity(viewer)
        StartExistingActivity(viewer)

    related:
        TaskListSurface(viewer)
}

surface ProfileSurface {
    facing viewer: User
    context profile: Profile where user = viewer

    exposes:
        profile.resumes

    provides:
        RequestAIReview(viewer)

    related:
        ResumeReviewSurface(profile)
}

surface AdminSurface {
    facing viewer: User

    exposes:
        viewer.companies
        viewer.job_titles
        viewer.locations
        viewer.activity_types

    @guidance
        -- Manage user-scoped reference data: companies, job titles,
        -- locations, activity types. CRUD operations available.
}

surface ResumeReviewSurface {
    facing viewer: User
    context resume: Resume where profile.user = viewer

    provides:
        RequestAIReview(viewer, resume)

    related:
        ProfileSurface(resume.profile)
}

surface JobMatchSurface {
    facing viewer: User
    context job: Job where user = viewer

    provides:
        RequestJobMatch(viewer, job)

    related:
        JobDetailSurface(viewer)
}

-- =============================================================================
-- Deferred Specifications
-- =============================================================================

deferred AutomationRunFlow.pipeline         -- see: specs/automation-pipeline.allium
deferred DataSourceConnector.search         -- see: specs/connector-dispatch.allium

-- =============================================================================
-- Open Questions
-- =============================================================================

open question "JobTitle unique constraint should be composite (value + userId), not just value alone. Current schema allows collisions across tenants."
open question "Should the connector dispatch rule include retry/fallback logic, or should that be deferred to the connector implementation?"
open question "Activity mutual exclusion: should the system auto-stop the running activity instead of rejecting the new one?"
